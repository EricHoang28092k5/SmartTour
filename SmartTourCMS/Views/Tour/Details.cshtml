@model SmartTour.Shared.Models.Tour
@{
    var deepLink = $"smarttour://tour/{Model.Id}";
    var qrEntryUrl = Url.Action("Open", "Qr", new { type = "tour", id = Model.Id }, Context.Request.Scheme);
    var qrUrl = $"https://api.qrserver.com/v1/create-qr-code/?size=220x220&data={Uri.EscapeDataString(qrEntryUrl ?? deepLink)}";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h3 class="mb-0">🗺️ Chi tiết hành trình: @Model.Name</h3>
            <a href="/Tour/Index" class="btn btn-light btn-sm">Quay lại danh sách</a>
        </div>
        <div class="card-body">
            <div class="row mb-4">
                <hr />
                <h3>🌐 Các bản dịch tự động</h3>
                @if (Model.TourTranslations != null && Model.TourTranslations.Any())
                {
                    <div class="row">
                        @foreach (var trans in Model.TourTranslations)
                        {
                            <div class="col-md-4 mb-3">
                                <div class="card">
                                    <div class="card-header bg-info text-white">
                                        <strong>Ngôn ngữ: @trans.LanguageCode.ToUpper()</strong>
                                    </div>
                                    <div class="card-body">
                                        <h5 class="card-title">@trans.Name</h5>
                                        <p class="card-text">@trans.Description</p>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-danger">Tour này chưa có bản dịch nào!</p>
                }
                <div class="col-md-8">
                    <h5>Mô tả:</h5>
                    <p class="lead">@Model.Description</p>
                </div>
                <div class="col-md-4 text-end text-muted">
                    <small>Được tạo ngày: @Model.CreatedAt.AddHours(7).ToString("dd/MM/yyyy HH:mm")</small>
                </div>
            </div>

            <h4 class="border-bottom pb-2">📍 Lộ trình di chuyển</h4>
            <div class="timeline mt-3">
                @if (Model.TourPois != null && Model.TourPois.Any())
                {
                    @foreach (var tp in Model.TourPois.OrderBy(x => x.OrderIndex))
                    {
                        <div class="d-flex mb-3 align-items-center p-3 border rounded bg-light">
                            <div class="me-4">
                                <span class="badge bg-dark rounded-circle p-3" style="width: 45px;">@tp.OrderIndex</span>
                            </div>
                            <div>
                                <h5 class="mb-1 text-primary">@tp.Poi?.Name</h5>
                                <p class="mb-0 text-muted small">Tọa độ: @tp.Poi?.Lat, @tp.Poi?.Lng</p>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="alert alert-warning">Hành trình này hiện chưa có địa điểm nào được chọn.</div>
                }
            </div>
        </div>
        <div class="card-footer text-end">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div class="text-start">
                    <div class="fw-bold mb-1">QR mở app SmartTour</div>
                    <div class="small text-muted mb-2">QR URL: @qrEntryUrl</div>
                    <img src="@qrUrl" alt="QR Tour @Model.Id" class="border rounded" style="width:120px;height:120px;" />
                </div>
                <div>
                    <a href="@deepLink" class="btn btn-outline-primary me-2">Mở bằng app</a>
                    <a href="/Tour/Edit/@Model.Id" class="btn btn-warning">Sửa hành trình</a>
                </div>
            </div>
        </div>
    </div>
</div>