@model SmartTour.Shared.Models.Tour

<div class="container mt-4">
    <h2>➕ Tạo Hành Trình Mới</h2>
    <hr />
    <form asp-action="Create" method="post">
        <div class="row">
            <div class="col-md-5">
                <div class="mb-3">
                    <label class="form-label">Tên Tour</label>
                    <input asp-for="Name" class="form-control" placeholder="Ví dụ: Tour Di Tích Quận 1" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Mô tả</label>
                    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                </div>
                <button type="submit" class="btn btn-primary w-100">Lưu Hành Trình</button>
            </div>

            <div class="col-md-7">
                <label class="form-label">Chọn các địa điểm vào Tour:</label>
                <div class="card p-3" style="max-height: 400px; overflow-y: auto;">
                    @foreach (var poi in ViewBag.Pois)
                    {
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" name="selectedPoiIds" value="@poi.Id" id="poi_@poi.Id">
                            <label class="form-check-label" for="poi_@poi.Id">
                                <strong>@poi.Name</strong> <br />
                                <small class="text-muted">@poi.Lat, @poi.Lng</small>
                            </label>
                        </div>
                    }
                </div>
            </div>
        </div>
    </form>
</div>