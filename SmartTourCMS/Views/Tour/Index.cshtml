@model IEnumerable<SmartTour.Shared.Models.Tour>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>🗺️ Quản lý hành trình (Tour)</h2>
        <a href="/Tour/Create" class="btn btn-success">+ Tạo Tour mới</a>
    </div>

    <table class="table table-hover border">
        <thead class="table-dark">
            <tr>
                <th>Tên hành trình</th>
                <th>Mô tả</th>
                <th>Số địa điểm</th>
                <th>Ngày tạo</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><strong>@item.Name</strong></td>
                    <td>@item.Description</td>
                    <td><span class="badge bg-info">@(item.TourPois?.Count ?? 0) POIs</span></td>
                    <td>@item.CreatedAt.ToString("dd/MM/yyyy")</td>
                    <td>
                        <a href="/Tour/Edit/@item.Id" class="btn btn-sm btn-warning">Sửa</a>
                        <a href="/Tour/Details/@item.Id" class="btn btn-sm btn-primary">Xem</a>
                        <button class="btn btn-sm btn-danger">Xóa</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>