@{
    ViewData["Title"] = "Bảng điều khiển Admin";
    var deviceStatuses = ViewBag.DeviceStatuses as List<SmartTourCMS.Models.DeviceStatusViewModel>
        ?? new List<SmartTourCMS.Models.DeviceStatusViewModel>();
}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="container-fluid pt-4">
    <div class="row">
        <div class="col-lg-3 col-6">
            <div class="small-box bg-info p-3 rounded shadow-sm text-white mb-4">
                <div class="inner">
                    <h3>@ViewBag.TotalPois</h3>
                    <p>Địa điểm (POI)</p>
                </div>
                <div class="icon"><i class="fa-solid fa-map-location-dot fa-2x"></i></div>
            </div>
        </div>

        <div class="col-lg-3 col-6">
            <div class="small-box bg-success p-3 rounded shadow-sm text-white mb-4">
                <div class="inner">
                    <h3>@ViewBag.TotalTranslations</h3>
                    <p>Bản dịch đa ngôn ngữ</p>
                </div>
                <div class="icon"><i class="fa-solid fa-language fa-2x"></i></div>
            </div>
        </div>

        <div class="col-lg-3 col-6">
            <div class="small-box bg-primary p-3 rounded shadow-sm text-white mb-4">
                <div class="inner">
                    <h3>@ViewBag.TotalVisits</h3>
                    <p>Tổng lượt nghe audio</p>
                </div>
                <div class="icon"><i class="fa-solid fa-headphones fa-2x"></i></div>
            </div>
        </div>

        <div class="col-lg-3 col-6">
            <div class="small-box bg-warning p-3 rounded shadow-sm text-white mb-4">
                <div class="inner">
                    <h3>@ViewBag.ActivePoisWithPlays</h3>
                    <p>POI đã có lượt nghe</p>
                </div>
                <div class="icon"><i class="fa-solid fa-wave-square fa-2x"></i></div>
            </div>
        </div>

        @if (User.IsInRole("Admin"))
        {
            <div class="col-lg-3 col-6">
                <div class="small-box bg-secondary p-3 rounded shadow-sm text-white mb-4">
                    <div class="inner">
                        <h3 id="onlineDevicesCount">@(ViewBag.OnlineDevices ?? 0)</h3>
                        <p id="onlineDevicesLabel">Thiết bị online (20 giây)</p>
                    </div>
                    <div class="icon"><i class="fa-solid fa-mobile-screen-button fa-2x"></i></div>
                </div>
            </div>
        }
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white fw-bold">
                    <i class="fa-solid fa-chart-bar text-success"></i> Thống kê lượt nghe Audio theo địa điểm
                </div>
                <div class="card-body">
                    <div style="height: 320px;">
                        <canvas id="poiAudioChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white fw-bold">
                    <i class="fa-solid fa-bolt text-warning"></i> Thao tác nhanh
                </div>
                <div class="card-body">
                    <a href="/Poi/Create" class="btn btn-outline-primary w-100 mb-2 text-start">
                        <i class="fa-solid fa-plus"></i> Thêm địa điểm mới
                    </a>
                    <a href="/Premium/Index" class="btn btn-outline-warning w-100 mb-2 text-start">
                        <i class="fa-solid fa-crown"></i> Nâng cấp Premium (MoMo)
                    </a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Heatmap/Index" class="btn btn-outline-danger w-100 mb-2 text-start">
                            <i class="fa-solid fa-fire"></i> Xem Bản đồ nhiệt (Heatmap)
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (User.IsInRole("Admin"))
    {
        <div class="row">
            <div class="col-12">
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-header bg-white fw-bold d-flex justify-content-between align-items-center">
                        <span><i class="fa-solid fa-mobile-screen-button text-secondary"></i> Thiết bị đang sử dụng</span>
                        <small id="onlineThresholdHint" class="text-muted">Trạng thái Online = có heartbeat trong 20 giây gần nhất</small>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Thiết bị</th>
                                        <th>IP</th>
                                        <th>Nền tảng</th>
                                        <th>Phiên bản</th>
                                        <th>Lần cuối hoạt động (UTC)</th>
                                        <th>Trạng thái</th>
                                    </tr>
                                </thead>
                                <tbody id="deviceStatusBody">
                                    @if (deviceStatuses.Count == 0)
                                    {
                                        <tr>
                                            <td colspan="6" class="text-center text-muted py-4">
                                                Chưa có dữ liệu thiết bị. Mở app để gửi heartbeat rồi tải lại trang.
                                            </td>
                                        </tr>
                                    }
                                    else
                                    {
                                        @foreach (var d in deviceStatuses)
                                        {
                                            <tr>
                                                <td>
                                                    <div class="fw-semibold">@(string.IsNullOrWhiteSpace(d.DeviceModel) ? "Unknown device" : d.DeviceModel)</div>
                                                    <small class="text-muted">@d.DeviceId</small><br />
                                                    <small class="text-muted">@d.UserAgent</small>
                                                </td>
                                                <td>@(string.IsNullOrWhiteSpace(d.IpAddress) ? "-" : d.IpAddress)</td>
                                                <td>@(string.IsNullOrWhiteSpace(d.Platform) ? "-" : $"{d.Platform} {d.OsVersion}".Trim())</td>
                                                <td>@(string.IsNullOrWhiteSpace(d.AppVersion) ? "-" : d.AppVersion)</td>
                                                <td>@d.LastSeenUtc.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                                <td>
                                                    @if (d.IsActive)
                                                    {
                                                        <span class="badge bg-success">Đang hoạt động</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-secondary">Không hoạt động</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<script>
document.addEventListener("DOMContentLoaded", function () {
    const canViewDeviceStats = @User.IsInRole("Admin").ToString().ToLowerInvariant();
    fetch('/api/cms-dashboard/poi-stats').then(r => r.json())
    .then((poiStats) => {
        // 1. Đổ dữ liệu vào Biểu đồ Audio
        if (poiStats.success && poiStats.data.length > 0) {
            new Chart(document.getElementById('poiAudioChart'), {
                type: 'bar',
                data: {
                    labels: poiStats.data.map(p => p.poiName),
                    datasets: [{
                        label: 'Lượt nghe',
                        data: poiStats.data.map(p => p.totalPlays),
                        backgroundColor: '#1cc88a',
                        borderRadius: 5
                    }]
                },
                options: {
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: { y: { beginAtZero: true } }
                }
            });
        }
    })
    .catch(err => console.error("Lỗi Dashboard:", err));

    const onlineCountEl = document.getElementById('onlineDevicesCount');
    const onlineLabelEl = document.getElementById('onlineDevicesLabel');
    const thresholdHintEl = document.getElementById('onlineThresholdHint');
    const deviceBodyEl = document.getElementById('deviceStatusBody');

    function esc(v) {
        return (v ?? '').toString()
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;');
    }

    function renderDevices(payload) {
        if (!payload || !payload.success || !deviceBodyEl) return;

        const threshold = payload.thresholdSeconds ?? 20;
        if (onlineCountEl) onlineCountEl.textContent = payload.onlineDevices ?? 0;
        if (onlineLabelEl) onlineLabelEl.textContent = `Thiết bị online (${threshold} giây)`;
        if (thresholdHintEl) thresholdHintEl.textContent = `Trạng thái Online = có heartbeat trong ${threshold} giây gần nhất`;

        const rows = payload.data ?? [];
        if (rows.length === 0) {
            deviceBodyEl.innerHTML = `<tr><td colspan="6" class="text-center text-muted py-4">Chưa có dữ liệu thiết bị.</td></tr>`;
            return;
        }

        deviceBodyEl.innerHTML = rows.map(d => {
            const isActive = !!d.isActive;
            const badge = isActive
                ? '<span class="badge bg-success">Đang hoạt động</span>'
                : '<span class="badge bg-secondary">Không hoạt động</span>';
            const deviceModel = d.deviceModel && d.deviceModel.trim() ? d.deviceModel : 'Unknown device';
            const ip = d.ipAddress && d.ipAddress.trim() ? d.ipAddress : '-';
            const platform = `${d.platform ?? ''} ${d.osVersion ?? ''}`.trim() || '-';
            const appVersion = d.appVersion && d.appVersion.trim() ? d.appVersion : '-';
            const lastSeen = d.lastSeenUtc ? d.lastSeenUtc.replace('T', ' ').replace('Z', '') : '-';
            return `
                <tr>
                    <td>
                        <div class="fw-semibold">${esc(deviceModel)}</div>
                        <small class="text-muted">${esc(d.deviceId)}</small><br />
                        <small class="text-muted">${esc(d.userAgent)}</small>
                    </td>
                    <td>${esc(ip)}</td>
                    <td>${esc(platform)}</td>
                    <td>${esc(appVersion)}</td>
                    <td>${esc(lastSeen)}</td>
                    <td>${badge}</td>
                </tr>`;
        }).join('');
    }

    async function refreshDeviceStatus() {
        try {
            const res = await fetch('/api/cms-dashboard/device-status', { cache: 'no-store' });
            if (!res.ok) return;
            const payload = await res.json();
            renderDevices(payload);
        } catch (e) {
            console.warn('device-status refresh failed', e);
        }
    }

    if (canViewDeviceStats) {
        refreshDeviceStatus();
        setInterval(refreshDeviceStatus, 3000);
    }
});
</script>

<style>
    .small-box { position: relative; overflow: hidden; transition: transform 0.2s; }
    .small-box:hover { transform: translateY(-5px); }
    .small-box .icon { position: absolute; right: 15px; top: 15px; opacity: 0.2; }
    .bg-gradient-light { background: linear-gradient(135deg, #f8f9fc 0%, #e2e6ea 100%); }
</style>