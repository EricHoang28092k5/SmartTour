@{
    ViewData["Title"] = "Bảng điều khiển Admin";
}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="container-fluid pt-4">
    <div class="row">
        <div class="col-lg-3 col-6">
            <div class="small-box bg-info p-3 rounded shadow-sm text-white mb-4">
                <div class="inner">
                    <h3>@ViewBag.TotalPois</h3>
                    <p>Địa điểm (POI)</p>
                </div>
                <div class="icon"><i class="fa-solid fa-map-location-dot fa-2x"></i></div>
            </div>
        </div>

        <div class="col-lg-3 col-6">
            <div class="small-box bg-success p-3 rounded shadow-sm text-white mb-4">
                <div class="inner">
                    <h3>@ViewBag.TotalTranslations</h3>
                    <p>Bản dịch đa ngôn ngữ</p>
                </div>
                <div class="icon"><i class="fa-solid fa-language fa-2x"></i></div>
            </div>
        </div>

        <div class="col-lg-3 col-6">
            <div class="small-box bg-primary p-3 rounded shadow-sm text-white mb-4">
                <div class="inner">
                    <h3 id="stat-sessions">0</h3>
                    <p>Tổng phiên hành trình</p>
                </div>
                <div class="icon"><i class="fa-solid fa-shoe-prints fa-2x"></i></div>
            </div>
        </div>

        <div class="col-lg-3 col-6">
            <div class="small-box bg-warning p-3 rounded shadow-sm text-white mb-4">
                <div class="inner">
                    <h3 id="stat-stops">0</h3>
                    <p>Trạm dừng trung bình</p>
                </div>
                <div class="icon"><i class="fa-solid fa-street-view fa-2x"></i></div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white fw-bold">
                    <i class="fa-solid fa-chart-bar text-success"></i> Thống kê lượt nghe Audio theo địa điểm
                </div>
                <div class="card-body">
                    <div style="height: 320px;">
                        <canvas id="poiAudioChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 mb-4 bg-gradient-light">
                <div class="card-body text-center">
                    <div class="text-xs font-weight-bold text-uppercase mb-1">Thời gian di chuyển trung bình</div>
                    <div id="stat-duration" class="h2 mb-0 font-weight-bold text-primary">0 phút</div>
                </div>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-white fw-bold">
                    <i class="fa-solid fa-bolt text-warning"></i> Thao tác nhanh
                </div>
                <div class="card-body">
                    <a href="/Poi/Create" class="btn btn-outline-primary w-100 mb-2 text-start">
                        <i class="fa-solid fa-plus"></i> Thêm địa điểm mới
                    </a>
                    <a href="/Audio/Upload" class="btn btn-outline-success w-100 mb-2 text-start">
                        <i class="fa-solid fa-microphone"></i> Quản lý âm thanh
                    </a>
                    <a href="/Heatmap/Index" class="btn btn-outline-danger w-100 mb-2 text-start">
                        <i class="fa-solid fa-fire"></i> Xem Bản đồ nhiệt (Heatmap)
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", function () {
    // Gọi API lấy thống kê thật
    Promise.all([
        fetch('/api/pois/stats').then(r => r.json()),
        fetch('/api/routes/stats').then(r => r.json())
    ])
    .then(([poiStats, routeStats]) => {
        // 1. Đổ dữ liệu vào Biểu đồ Audio
        if (poiStats.success && poiStats.data.length > 0) {
            new Chart(document.getElementById('poiAudioChart'), {
                type: 'bar',
                data: {
                    labels: poiStats.data.map(p => p.poiName),
                    datasets: [{
                        label: 'Lượt nghe',
                        data: poiStats.data.map(p => p.totalPlays),
                        backgroundColor: '#1cc88a',
                        borderRadius: 5
                    }]
                },
                options: {
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: { y: { beginAtZero: true } }
                }
            });
        }

        // 2. Đổ dữ liệu vào các ô chỉ số
        if (routeStats.success) {
            document.getElementById('stat-sessions').innerText = routeStats.totalSessions;
            document.getElementById('stat-stops').innerText = routeStats.avgStops;
            document.getElementById('stat-duration').innerText = routeStats.avgDurationMinutes + " phút";
        }
    })
    .catch(err => console.error("Lỗi Dashboard:", err));
});
</script>

<style>
    .small-box { position: relative; overflow: hidden; transition: transform 0.2s; }
    .small-box:hover { transform: translateY(-5px); }
    .small-box .icon { position: absolute; right: 15px; top: 15px; opacity: 0.2; }
    .bg-gradient-light { background: linear-gradient(135deg, #f8f9fc 0%, #e2e6ea 100%); }
</style>