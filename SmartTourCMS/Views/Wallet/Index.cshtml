@model SmartTourCMS.Models.WalletIndexViewModel
@{
    ViewData["Title"] = "Ví vendor";
}

<div class="container py-3" style="max-width: 560px;">
    <h3 class="mb-3"><i class="fa-solid fa-wallet text-success me-2"></i>Ví tiền vendor</h3>

    @if (TempData["Error"] is string err && !string.IsNullOrWhiteSpace(err))
    {
        <div class="alert alert-danger">@err</div>
    }

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body text-center">
            <div class="text-muted small">Số dư hiện tại</div>
            <div class="display-5 fw-bold text-success">@Model.BalanceVnd.ToString("N0") đ</div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white fw-bold">Nạp tiền qua MoMo</div>
        <div class="card-body">
            <p class="text-muted small">Tối thiểu mỗi lần nạp: <strong>@Model.MinTopUpVnd.ToString("N0") đ</strong>. Sau khi thanh toán thành công, số dư ví sẽ tăng tương ứng.</p>
            <form method="post" asp-action="StartTopUp">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label">Số tiền nạp (VNĐ)</label>
                    <input type="number" name="amountVnd" class="form-control form-control-lg" min="@Model.MinTopUpVnd" step="1000" value="@Model.MinTopUpVnd" required />
                </div>
                <button type="submit" class="btn btn-primary w-100 btn-lg">
                    <i class="fa-solid fa-qrcode me-2"></i>Tạo QR MoMo
                </button>
            </form>
        </div>
    </div>

    <div class="mt-3">
        <a asp-controller="Premium" asp-action="Index" class="btn btn-link">← Nâng cấp Premium</a>
        <a asp-controller="Poi" asp-action="Create" class="btn btn-link">Tạo POI mới</a>
    </div>
</div>
