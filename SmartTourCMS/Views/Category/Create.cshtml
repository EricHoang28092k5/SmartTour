@model SmartTour.Shared.Models.Category

<div class="card shadow border-0 mt-4 mx-auto" style="max-width: 600px;">
    <div class="card-header bg-primary text-white">
        <h4 class="mb-0"><i class="fa-solid fa-plus-circle"></i> Thêm Danh mục mới</h4>
    </div>
    <div class="card-body p-4">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            
            <div class="mb-3">
                <label class="form-label fw-bold">Tên Danh mục</label>
                <input asp-for="Name" class="form-control" placeholder="VD: Quán ăn, Tham quan..." required />
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Mô tả ngắn</label>
                <textarea asp-for="Description" class="form-control" rows="2"></textarea>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold text-success"><i class="fa-solid fa-image"></i> Hình ảnh Icon (.png, .svg)</label>
                <input type="file" name="iconFile" class="form-control" accept="image/*" />
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold text-danger"><i class="fa-solid fa-map-pin"></i> Màu Ghim trên Bản đồ</label>
                <input asp-for="ColorCode" type="color" class="form-control form-control-color" value="#FF3366" title="Chọn màu cho danh mục này" />
            </div>

            <hr />
            <div class="d-flex justify-content-end gap-2">
                <a asp-action="Index" class="btn btn-light border">Hủy</a>
                <button type="submit" class="btn btn-primary px-4"><i class="fa-solid fa-save"></i> Lưu Danh mục</button>
            </div>
        </form>
    </div>
</div>