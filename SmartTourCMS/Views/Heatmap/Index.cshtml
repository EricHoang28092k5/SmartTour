@{
    ViewData["Title"] = "Bản đồ nhiệt độ tương tác POI";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://unpkg.com/leaflet.heat/dist/leaflet-heat.js"></script>

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-primary">Bản đồ nhiệt độ tương tác POI</h6>
        <button id="btn-find-heatmap" class="btn btn-sm btn-danger">
            <i class="fa-solid fa-fire"></i> Bay về Sài Gòn xem Heatmap
        </button>
    </div>
    <div class="card-body">
        <div id="heatmap-container" style="width: 100%; height: 600px; border-radius: 8px;"></div>
    </div>
</div>

<script>
    // Bắt đầu sự kiện tải trang - Đừng có lỡ tay xóa dấu ngoặc của tao!
    document.addEventListener("DOMContentLoaded", function () {
        
    // 1. Khởi tạo bản đồ
    var map = L.map('heatmap-container');

    // 2. Thêm lớp bản đồ nền
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '© OpenStreetMap contributors'
    }).addTo(map);

    // 3. Xin quyền GPS
    map.locate({setView: true, maxZoom: 16});

    map.on('locationfound', function(e) {
    console.log("Đã tìm thấy vị trí GPS.");
    L.marker(e.latlng).addTo(map).bindPopup("<b>Mày đang đứng đây này!</b>").openPopup();
    });

    map.on('locationerror', function(e) {
    console.warn("Lỗi GPS, ném về Sài Gòn mặc định.");
    map.setView([10.779, 106.684], 13);
    });

    // 4. Sự kiện bấm nút bay về Sài Gòn
    document.getElementById('btn-find-heatmap').addEventListener('click', function() {
    map.flyTo([10.779, 106.684], 13);
    });

    // 5. GỌI API ĐỒNG THỜI (Lấy dữ liệu TẤT CẢ và dữ liệu HEATMAP)
    Promise.all([
    fetch('/api/cms-pois').then(res => res.json()),       // Nếu mày đổi cả tên API này
    fetch('/api/cms-heatmap').then(res => res.json())
    ])
    .then(([poiRes, heatRes]) => {
            
    if (poiRes.success && heatRes.success) {
    var allPois = poiRes.data;
    var hotPois = heatRes.data;

    // A. VẼ HEATMAP (Cho mấy điểm có data)
    var heatData = hotPois.map(item => [item.lat, item.lng, item.sum]);
    if (heatData.length > 0) {
    L.heatLayer(heatData, {
    radius: 35,         // Bán kính đốm nhiệt (vừa đủ để không che mất icon)
    blur: 15,           // Độ nhòe (giảm bớt blur để màu nó tập trung, trông sẽ đậm hơn)
    max: 1.0,           // CHIÊU CUỐI: Để max cực thấp (ví dụ 1.0 hoặc 2.0)
    minOpacity: 0.5,    // Độ hiển thị tối thiểu (không cho nó mờ quá)
    gradient: {         // Định nghĩa lại bảng màu cho nó rực rỡ
    0.2: 'blue',
    0.4: 'cyan',
    0.6: 'lime',
    0.8: 'yellow',
    1.0: 'red'      // Chỉ cần đạt mốc 1.0 là đỏ rực ngay!
    }
    }).addTo(map);
    }

    // B. CẮM CỌC (Chỉ cắm cho mấy điểm KHÔNG NẰM TRONG danh sách Heatmap)
    var hotPoiIds = hotPois.map(item => item.poiId);
                
    allPois.forEach(poi => {
    // Kiểm tra xem thằng POI này có nằm trong danh sách "Hot" không để hiện thông tin cho ngầu
    var hotInfo = hotPois.find(h => h.poiId === poi.id);
    var viewCount = hotInfo ? hotInfo.sum : 0;

    L.marker([poi.latitude, poi.longitude])
    .addTo(map)
    .bindPopup(`
    <div style="text-align:center">
    <b>${poi.name}</b><br>
    <span style="color:${viewCount > 0 ? 'red' : 'gray'}">
    Lượt tương tác: ${viewCount}
    </span>
    </div>
    `);
    });

    } else {
    console.error("API trả về lỗi hoặc thiếu dữ liệu!");
    }
    })
    .catch(error => {
    console.error("Lỗi khi kết nối API: ", error);
    });

    }); // <-- CHỐT HẠ ĐÓNG NGOẶC CỦA DOMContentLoaded! CẤM XÓA CÁI DÒNG NÀY!!!
</script>