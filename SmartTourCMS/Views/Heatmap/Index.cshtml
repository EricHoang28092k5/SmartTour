@{
    ViewData["Title"] = "Phân tích Tuyến đường & Heatmap";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://unpkg.com/leaflet.heat/dist/leaflet-heat.js"></script>

<div class="container-fluid">
    <div class="row">
        <div class="col-md-4">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Tuyến người dùng hay đi</h6>
                </div>
                <div class="card-body" style="height: 600px; overflow-y: auto;">
                    <div id="route-list" class="list-group">
                        <div class="text-center p-5">
                            <div class="spinner-border text-primary" role="status"></div>
                            <p class="mt-2">Đang tải dữ liệu...</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow mb-4">
                <div class="card-header py-3 d-flex justify-content-between align-items-center">
                    <h6 class="m-0 font-weight-bold text-primary">Bản đồ tương tác POI</h6>
                    <button id="btn-reset" class="btn btn-sm btn-outline-primary">Đặt lại bản đồ</button>
                </div>
                <div class="card-body p-0">
                    <div id="map" style="width: 100%; height: 600px; border-radius: 0 0 0.35rem 0.35rem;"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", function () {
    // 1. Khởi tạo Map
    var map = L.map('map').setView([10.779, 106.684], 14);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap'
    }).addTo(map);

    var currentRouteLayer = null;

    // 2. Gọi 3 API cùng lúc (Nhớ check kỹ tên API của mày!)
    Promise.all([
        fetch('/api/cms-pois').then(res => res.json()),
        fetch('/api/cms-heatmap').then(res => res.json()),
        fetch('/api/routes/popular?limit=10').then(res => res.json())
    ])
    .then(([poiRes, heatRes, routeRes]) => {
        console.log("Data nhận về:", { poiRes, heatRes, routeRes });

        // Logic bóc tách dữ liệu an toàn (đề phòng API không có .data)
        const allPois = poiRes.data || poiRes || [];
        const heatDataRaw = heatRes.data || heatRes || [];
        const routes = routeRes.data || routeRes || [];

        // --- VẼ HEATMAP ---
        if (heatDataRaw.length > 0) {
            var heatPoints = heatDataRaw.map(h => [h.lat, h.lng, h.sum]);
            L.heatLayer(heatPoints, { 
                radius: 40, 
                blur: 20, 
                max: 0.5, 
                minOpacity: 0.4,
                gradient: { 0.4: 'blue', 0.6: 'lime', 0.8: 'yellow', 1.0: 'red' }
            }).addTo(map);
        }

        // --- CẮM MARKER ---
        allPois.forEach(poi => {
            L.marker([poi.latitude, poi.longitude])
             .addTo(map)
             .bindPopup(`<b>${poi.name}</b>`);
        });

        // --- ĐỔ DANH SÁCH SANG CỘT TRÁI ---
        const listContainer = document.getElementById('route-list');
        listContainer.innerHTML = '';

        if (routes.length > 0) {
            routes.forEach((route, index) => {
                // Biến chuỗi "24,3" thành tên POI
                var ids = route.poiSequence.split(',').map(Number);
                var names = ids.map(id => {
                    var found = allPois.find(p => p.id === id);
                    return found ? found.name : "POI " + id;
                }).join(" → ");

                var itemHtml = `
                    <a href="javascript:void(0)" class="list-group-item list-group-item-action mb-2 shadow-sm border-left-primary" 
                       onclick="drawRoute('${route.poiSequence}', this)">
                        <div class="fw-bold text-dark" style="font-size: 0.85rem;">${names}</div>
                        <div class="d-flex justify-content-between mt-1">
                            <small class="text-primary font-weight-bold">${route.count} lượt đi</small>
                            <small class="text-muted">Tuyến #${index + 1}</small>
                        </div>
                    </a>`;
                listContainer.innerHTML += itemHtml;
            });
        } else {
            listContainer.innerHTML = '<div class="alert alert-warning">Không có dữ liệu tuyến đường.</div>';
        }

        // --- HÀM VẼ TUYẾN ĐƯỜNG KHI CLICK ---
        window.drawRoute = function(sequence, element) {
            if (currentRouteLayer) map.removeLayer(currentRouteLayer);
            
            // Highlight item được chọn
            document.querySelectorAll('.list-group-item').forEach(i => i.classList.remove('active'));
            element.classList.add('active');

            var ids = sequence.split(',').map(Number);
            var latlngs = ids.map(id => {
                var p = allPois.find(poi => poi.id === id);
                return p ? [p.latitude, p.longitude] : null;
            }).filter(l => l !== null);

            if (latlngs.length >= 2) {
                currentRouteLayer = L.polyline(latlngs, {
                    color: '#e74c3c', weight: 6, opacity: 0.8, dashArray: '10, 10'
                }).addTo(map);
                
                // Tự động zoom vào tuyến đường
                map.fitBounds(currentRouteLayer.getBounds(), { padding: [50, 50] });
            }
        };
    })
    .catch(err => {
        console.error("Lỗi sấp mặt:", err);
        document.getElementById('route-list').innerHTML = '<div class="alert alert-danger">Lỗi kết nối API!</div>';
    });

    // Nút reset bản đồ
    document.getElementById('btn-reset').addEventListener('click', function() {
        map.setView([10.779, 106.684], 14);
        if (currentRouteLayer) map.removeLayer(currentRouteLayer);
        document.querySelectorAll('.list-group-item').forEach(i => i.classList.remove('active'));
    });
});
</script>

<style>
    .border-left-primary { border-left: 0.25rem solid #4e73df !important; }
    .list-group-item-action:hover { background-color: #f8f9fc; }
    .list-group-item.active { 
        background-color: #eaecf4 !important; 
        color: #4e73df !important; 
        border-color: #4e73df !important; 
    }
    #route-list::-webkit-scrollbar { width: 5px; }
    #route-list::-webkit-scrollbar-thumb { background: #dddfeb; border-radius: 10px; }
</style>