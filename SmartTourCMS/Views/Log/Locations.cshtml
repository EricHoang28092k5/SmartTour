@model IEnumerable<SmartTour.Shared.Models.UserLocationLog>

<div class="container-fluid">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0"><i class="fa-solid fa-shoe-prints me-2"></i> Lịch sử di chuyển của người dùng</h4>
        </div>
        <div class="card-body">
            <table class="table table-hover border">
                <thead class="table-light">
                    <tr>
                        <th>Người dùng (ID)</th>
                        <th>Vĩ độ (Lat)</th>
                        <th>Kinh độ (Lng)</th>
                        <th>Thời gian (VN)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model)
                    {
                        <tr>
                            <td><span class="badge bg-secondary">@log.UserId</span></td>
                            <td>@log.Latitude</td>
                            <td>@log.Longitude</td>
                            <td>@log.Timestamp.AddHours(7).ToString("dd/MM/yyyy HH:mm:ss")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>