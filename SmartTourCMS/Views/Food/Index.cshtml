@using X.PagedList.Mvc.Core
@model X.PagedList.IPagedList<SmartTour.Shared.Models.Food>


<div class="d-flex justify-content-between align-items-center mb-4 mt-3">
    <h2 class="fw-bold text-primary"><i class="fa-solid fa-utensils"></i> Quản lý Thực Đơn</h2>
    <a asp-action="Create" class="btn btn-success shadow-sm">
        <i class="fa-solid fa-plus"></i> Thêm món mới
    </a>
</div>

<form id="foodFilterForm" asp-action="Index" method="get" class="card shadow-sm border-0 mb-3">
    <div class="card-body row g-2 align-items-end">
        <div class="col-md-5">
            <label class="form-label mb-1">Tìm kiếm món ăn</label>
            <input id="searchInput" type="text" name="search" value="@ViewBag.CurrentSearch" class="form-control" placeholder="Nhập tên món..." />
        </div>
        <div class="col-md-5">
            <label class="form-label mb-1">Lọc theo POI</label>
            <select id="poiFilter" name="poiId" class="form-select" asp-items="ViewBag.PoiFilterList">
                <option value="">-- Tất cả POI --</option>
            </select>
        </div>
        <div class="col-md-2 d-grid">
            <a asp-action="Index" class="btn btn-outline-secondary"><i class="fa-solid fa-rotate-left"></i> Xóa lọc</a>
        </div>
    </div>
</form>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="ps-3">Ảnh</th>
                    <th>Tên món</th>
                    <th>Giá bán</th>
                    <th>Thuộc Quán (POI)</th>
                    <th class="text-center">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="5" class="text-center py-4 text-muted">Chưa có món ăn nào trong thực đơn.</td></tr>
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-3">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" class="rounded shadow-sm" style="width: 70px; height: 70px; object-fit: cover;" />
                            }
                            else
                            {
                                <div class="bg-light rounded d-flex justify-content-center align-items-center" style="width: 70px; height: 70px;">
                                    <i class="fa-solid fa-image text-muted opacity-50"></i>
                                </div>
                            }
                        </td>
                        <td class="fw-bold fs-5">@item.Name</td>
                        <td><span class="text-danger fw-bold">@item.Price.ToString("N0") VNĐ</span></td>
                        <td>
                            <span class="badge bg-info text-dark border border-info">
                                <i class="fa-solid fa-store"></i> @item.Poi?.Name
                            </span>
                        </td>
                        <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Sửa món">
                                        <i class="fa-solid fa-pen-to-square"></i> Sửa
                                    </a>

                                    <form asp-action="RegenerateTranslations" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Tạo lại toàn bộ bản dịch cho món @item.Name?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-info" title="Tạo lại bản dịch Food">
                                            <i class="fa-solid fa-language"></i> Tạo lại dịch
                                        </button>
                                    </form>
        
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bác có chắc muốn xóa món @item.Name này khỏi thực đơn không?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa món">
                                            <i class="fa-solid fa-trash"></i> Xóa
                                        </button>
                                    </form>
                                </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
            <div class="card-footer bg-white d-flex justify-content-center pt-3 pb-1 border-top-0 mt-3">
                @Html.PagedListPager(Model, page => Url.Action("Index", new
                {
                    page = page,
                    search = ViewBag.CurrentSearch,
                    poiId = ViewBag.CurrentPoiId
                }), new PagedListRenderOptions
                {
                    LiElementClasses = new string[] { "page-item" },
                    PageClasses = new string[] { "page-link" }
                })
            </div>
    </div>
</div>

<script>
    (function () {
        const form = document.getElementById('foodFilterForm');
        const searchInput = document.getElementById('searchInput');
        const poiFilter = document.getElementById('poiFilter');
        if (!form || !searchInput || !poiFilter) return;

        let timer = null;
        searchInput.addEventListener('input', function () {
            clearTimeout(timer);
            timer = setTimeout(() => form.submit(), 300);
        });

        poiFilter.addEventListener('change', function () {
            form.submit();
        });
    })();
</script>