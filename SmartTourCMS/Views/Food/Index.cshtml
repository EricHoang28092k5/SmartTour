@model IEnumerable<SmartTour.Shared.Models.Food>

<div class="d-flex justify-content-between align-items-center mb-4 mt-3">
    <h2 class="fw-bold text-primary"><i class="fa-solid fa-utensils"></i> Quản lý Thực Đơn</h2>
    <a asp-action="Create" class="btn btn-success shadow-sm">
        <i class="fa-solid fa-plus"></i> Thêm món mới
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="ps-3">Ảnh</th>
                    <th>Tên món</th>
                    <th>Giá bán</th>
                    <th>Thuộc Quán (POI)</th>
                    <th class="text-center">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="5" class="text-center py-4 text-muted">Chưa có món ăn nào trong thực đơn.</td></tr>
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-3">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" class="rounded shadow-sm" style="width: 70px; height: 70px; object-fit: cover;" />
                            }
                            else
                            {
                                <div class="bg-light rounded d-flex justify-content-center align-items-center" style="width: 70px; height: 70px;">
                                    <i class="fa-solid fa-image text-muted opacity-50"></i>
                                </div>
                            }
                        </td>
                        <td class="fw-bold fs-5">@item.Name</td>
                        <td><span class="text-danger fw-bold">@item.Price.ToString("N0") VNĐ</span></td>
                        <td>
                            <span class="badge bg-info text-dark border border-info">
                                <i class="fa-solid fa-store"></i> @item.Poi?.Name
                            </span>
                        </td>
                        <td class="text-center">
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bác có chắc muốn xóa món @item.Name này khỏi thực đơn không?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa món">
                                    <i class="fa-solid fa-trash"></i> Xóa
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>