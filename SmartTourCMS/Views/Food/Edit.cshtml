@model SmartTour.Shared.Models.Food

<div class="card shadow border-0 mt-4 mx-auto" style="max-width: 800px;">
    <div class="card-header bg-primary bg-gradient text-white">
        <h4 class="mb-0"><i class="fa-solid fa-pen-to-square"></i> Sửa thông tin món ăn</h4>
    </div>
    <div class="card-body p-4">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />
            
            <div class="mb-4">
                <label class="form-label fw-bold text-primary">Thuộc Quán / Địa điểm</label>
                <select asp-for="PoiId" class="form-select border-primary" asp-items="ViewBag.PoiList" required></select>
            </div>

            <div class="row">
                <div class="col-md-7 mb-3">
                    <label class="form-label fw-bold">Tên món ăn</label>
                    <input asp-for="Name" class="form-control" required />
                </div>
                <div class="col-md-5 mb-3">
                    <label class="form-label fw-bold">Giá tiền (VNĐ)</label>
                    <input asp-for="Price" type="number" class="form-control" required />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Mô tả hấp dẫn</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>

            @{
                var langs = ViewBag.FoodLangs as List<SmartTour.Shared.Models.Language> ?? new List<SmartTour.Shared.Models.Language>();
                var transMap = ViewBag.FoodTransMap as Dictionary<int, SmartTour.Shared.Models.FoodTranslation> ?? new Dictionary<int, SmartTour.Shared.Models.FoodTranslation>();
            }
            @if (langs.Any())
            {
                <div class="mb-4">
                    <h6 class="fw-bold text-primary mb-3">
                        <i class="fa-solid fa-language"></i> Bản dịch theo ngôn ngữ
                    </h6>
                    <div class="alert alert-info py-2 mb-3">
                        Nếu muốn chỉnh tay, nhập vào ô bên dưới. Để trống thì giữ bản dịch tự động.
                    </div>

                    @foreach (var lang in langs)
                    {
                        transMap.TryGetValue(lang.Id, out var tr);
                        <div class="border rounded p-3 mb-3 bg-light-subtle">
                            <div class="fw-bold mb-2">@lang.Name (@lang.Code)</div>
                            <div class="mb-2">
                                <label class="form-label mb-1">Tên món (@lang.Code)</label>
                                <input type="text"
                                       name="trans_name_@lang.Id"
                                       class="form-control"
                                       value="@tr?.Name" />
                            </div>
                            <div>
                                <label class="form-label mb-1">Mô tả (@lang.Code)</label>
                                <textarea name="trans_desc_@lang.Id" class="form-control" rows="2">@tr?.Description</textarea>
                            </div>
                        </div>
                    }
                </div>
            }

            <div class="mb-4">
                <label class="form-label fw-bold">Ảnh đại diện</label>
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div class="mb-2">
                        <img src="@Model.ImageUrl" class="rounded shadow-sm" style="height: 120px; object-fit: cover;" />
                    </div>
                    <small class="text-muted d-block mb-2"><i>(Bỏ trống nếu muốn giữ nguyên ảnh hiện tại)</i></small>
                }
                <input type="file" name="imageFile" class="form-control" accept="image/*" />
            </div>

            <hr class="text-muted" />

            <div class="d-flex justify-content-end gap-2">
                <a asp-action="Index" class="btn btn-light border"><i class="fa-solid fa-arrow-left"></i> Hủy</a>
                <button type="submit" class="btn btn-primary px-4"><i class="fa-solid fa-floppy-disk"></i> Lưu thay đổi</button>
            </div>
        </form>
    </div>
</div>