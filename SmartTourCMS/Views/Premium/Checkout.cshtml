@model SmartTourCMS.Models.PremiumCheckoutViewModel
@{
    ViewData["Title"] = "Thanh toán Premium";
}

<div class="container py-3">
    <div class="card shadow-sm border-0 mx-auto" style="max-width: 760px;">
        <div class="card-header bg-white fw-bold">
            <i class="fa-solid fa-money-bill-wave me-2 text-success"></i>@(Model.PoiId > 0 ? "Thanh toán Premium qua MoMo" : "Nạp tiền ví qua MoMo")
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-7">
                    <p class="mb-1"><strong>POI:</strong> @Model.PoiName</p>
                    <p class="mb-1"><strong>Gói:</strong> @Model.PackageName</p>
                    <p class="mb-1"><strong>Số tiền:</strong> @Model.AmountVnd.ToString("N0")đ</p>
                    <p class="mb-3"><strong>Mã đơn:</strong> <code>@Model.OrderId</code></p>

                    <a href="@Model.CheckoutUrl" target="_blank" class="btn btn-primary mb-2">
                        <i class="fa-solid fa-up-right-from-square me-2"></i>Mở MoMo để thanh toán
                    </a>
                    <div class="text-muted small">
                        Sau khi thanh toán thành công, hệ thống sẽ tự kiểm tra và tự động chuyển sang màn hình thành công.
                    </div>
                    <div id="autoStatus" class="small text-muted mt-2">
                        Đang chờ xác nhận thanh toán...
                    </div>
                </div>
                <div class="col-md-5 text-center">
                    <img src="@Model.QrImageUrl" alt="MoMo QR" class="img-fluid border rounded p-2 bg-white" />
                    <div class="small text-muted mt-2">Quét QR bằng app MoMo</div>
                </div>
            </div>
        </div>
        <div class="card-footer bg-white d-flex justify-content-between">
            <a class="btn btn-outline-secondary" href="@(Model.PoiId > 0 ? Url.Action("Index", "Premium", new { poiId = Model.PoiId }) : Url.Action("Index", "Wallet"))">Quay lại</a>
            <a class="btn btn-success" href="@Model.ReturnUrl">Tôi đã thanh toán, kiểm tra trạng thái</a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const statusText = document.getElementById('autoStatus');
            const statusApiUrl = '@Model.StatusApiUrl';
            const returnUrl = '@Model.ReturnUrl';
            const pollingIntervalMs = @Model.PollingIntervalMs;
            if (!statusApiUrl || !returnUrl) return;

            let attempts = 0;
            let forceCheck = false;
            let stopped = false;

            async function pollStatus() {
                if (stopped) return;
                attempts += 1;
                if (attempts >= 8) {
                    forceCheck = true;
                }

                try {
                    const url = new URL(statusApiUrl, window.location.origin);
                    url.searchParams.set('forceProviderCheck', forceCheck ? 'true' : 'false');
                    const response = await fetch(url.toString(), {
                        method: 'GET',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    });
                    const result = await response.json();
                    if (!response.ok || !result.success || !result.data) {
                        throw new Error(result.message || 'Không đọc được trạng thái thanh toán.');
                    }

                    if (result.data.status === 'paid') {
                        if (statusText) {
                            statusText.classList.remove('text-muted');
                            statusText.classList.add('text-success');
                            statusText.textContent = 'Thanh toán thành công. Đang chuyển trang...';
                        }
                        stopped = true;
                        window.location.href = returnUrl;
                        return;
                    }

                    if (statusText) {
                        statusText.classList.remove('text-success');
                        statusText.classList.add('text-muted');
                        statusText.textContent = forceCheck
                            ? 'Đang đồng bộ trạng thái từ MoMo...'
                            : 'Đang chờ xác nhận thanh toán...';
                    }
                } catch (error) {
                    if (statusText) {
                        statusText.classList.remove('text-success');
                        statusText.classList.add('text-warning');
                        statusText.textContent = 'Kết nối kiểm tra trạng thái đang chậm. Bạn có thể bấm nút kiểm tra thủ công.';
                    }
                }

                setTimeout(pollStatus, pollingIntervalMs);
            }

            setTimeout(pollStatus, pollingIntervalMs);
        })();
    </script>
}
