@{
    var currentPage = (int)(ViewBag.CurrentPage ?? 1);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
    var pageSize = (int)(ViewBag.PageSize ?? 10);
    var totalItems = (int)(ViewBag.TotalItems ?? 0);
}

<div class="container-fluid mt-4 mb-5">
    <div class="card shadow-lg border-0 rounded-3">
        
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-3">
            <h4 class="mb-0 fw-bold"><i class="fas fa-users me-2"></i> Danh Sách Tài Khoản</h4>
            <a asp-action="CreateVendor" class="btn btn-success fw-bold shadow-sm">
                <i class="fas fa-plus-circle me-1"></i> Thêm Vendor Mới
            </a>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-4 py-3">Email / Username</th>
                            <th class="text-center py-3">Trạng thái</th>
                            <th class="text-center py-3">Vai trò</th>
                            <th class="text-center py-3">Thao tác</th>

                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null)
                        {
                            @foreach (var user in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-semibold text-secondary">@user.Email</td>
                                    
                                    <td class="text-center">
                                        @if (user.IsLockedOut)
                                        {
                                            <span class="badge rounded-pill bg-danger px-3 py-2 shadow-sm">
                                                <i class="fas fa-lock me-1"></i> Đang bị khóa
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-pill bg-success px-3 py-2 shadow-sm">
                                                <i class="fas fa-check-circle me-1"></i> Hoạt động
                                            </span>
                                        }
                                    </td>

                                    <td>
                                        @if (user.Roles.Contains("Admin"))
                                        {
                                            <span class="badge bg-danger">Trùm cuối (Admin)</span>
                                        }
                                        else if (user.Roles.Contains("Vendor"))
                                        {
                                            <span class="badge bg-success">Chủ quán (Vendor)</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Khách hàng (User)</span>
                                        }
                                    </td>

                                    <td>
                                        <div class="d-flex justify-content-center gap-2">
                                            <form asp-action="ToggleLock" asp-route-id="@user.Id" method="post" class="m-0">
                                                <button type="submit" class="btn btn-sm @(user.IsLockedOut ? "btn-outline-success" : "btn-outline-danger") fw-bold">
                                                    @(user.IsLockedOut ? "Mở khóa" : "Khóa tài khoản")
                                                </button>
                                            </form>

                                            <a asp-controller="User" asp-action="ResetPassword" asp-route-id="@user.Id" class="btn btn-info btn-sm text-white fw-bold">
                                                <i class="fas fa-key me-1"></i> Đổi mật khẩu
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer d-flex justify-content-between align-items-center">
            <small class="text-muted">Tổng tài khoản: @totalItems</small>
            <nav aria-label="User pagination">
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@(currentPage - 1)" asp-route-pageSize="@pageSize">Trước</a>
                    </li>
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-pageSize="@pageSize">@i</a>
                        </li>
                    }
                    <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@(currentPage + 1)" asp-route-pageSize="@pageSize">Sau</a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</div>