@model SmartTourCMS.Models.CreateVendorViewModel

@{
    ViewData["Title"] = "Thêm mới Vendor";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0">
                <div class="card-header bg-success text-white">
                    <h3 class="mb-0"><i class="fas fa-user-plus"></i> Cấp tài khoản Vendor mới</h3>
                </div>
                <div class="card-body">
                    <form asp-action="CreateVendor" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Email (Tên đăng nhập)</label>
                            <input asp-for="Email" class="form-control" placeholder="nguyenvana@gmail.com" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Mật khẩu cấp phát</label>
                            <input asp-for="Password" type="password" class="form-control" placeholder="Nhập mật khẩu..." />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Xác nhận mật khẩu</label>
                            <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Nhập lại mật khẩu..." />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Chọn Vai Trò (Quyền hạn)</label>
                            <select asp-for="Role" class="form-select border-primary" required>
                                <option value="">-- Chọn chức vụ cho tài khoản này --</option>
                                @foreach (var role in ViewBag.Roles as List<string>)
                                {
                                    <option value="@role">@role</option>
                                }
                            </select>
                        </div>
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success">Tạo Tài Khoản</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Hủy / Quay lại</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>