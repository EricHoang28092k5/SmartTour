@model IEnumerable<SmartTour.Shared.Models.PoiTranslation>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>🌐 Bản dịch của: <span class="text-primary">@ViewBag.PoiName</span></h3>
        <a href="/Translation/Create?poiId=@ViewBag.PoiId" class="btn btn-success">+ Thêm ngôn ngữ</a>
    </div>

    <table class="table table-bordered shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Ngôn ngữ</th>
                <th>Tiêu đề (Dịch)</th>
                <th>Mô tả</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><span class="badge bg-info text-dark">@item.Language?.Name (@item.Language?.Code)</span></td>
                    <td><strong>@item.Title</strong></td>
                    <td class="text-truncate" style="max-width: 250px;">@item.Description</td>
                    <td class="text-center">
                        <div class="btn-group">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="Xem chi tiết">
                                <i class="fa-solid fa-eye"></i>
                            </a>
        
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning" title="Chỉnh sửa">
                                <i class="fa-solid fa-pen-to-square"></i>
                            </a>

                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Xóa thiệt không bác?')" style="display:inline;">
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <a href="/Poi/Index" class="btn btn-secondary">⬅️ Quay lại danh sách địa điểm</a>
</div>