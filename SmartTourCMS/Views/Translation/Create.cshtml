@model SmartTour.Shared.Models.PoiTranslation

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0">
                <div class="card-header bg-info text-white p-3">
                    <h4 class="mb-0">🌐 Thêm bản dịch mới</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <input type="hidden" asp-for="PoiId" value="@ViewBag.PoiId" />

                        <div class="mb-3">
                            <label class="form-label font-weight-bold">Địa điểm đang dịch:</label>
                            <input id="originalName" class="form-control bg-light" value="@ViewBag.PoiName" readonly />
                        </div>

                        <div class="mb-3">
                            <label class="form-label font-weight-bold">Ngôn ngữ đích</label>
                            <select asp-for="LanguageId" id="langSelect" class="form-select border-primary"
                                    asp-items="@(new SelectList(ViewBag.Languages, "Id", "Code"))"
                                    onchange="suggestTranslation()" required>
                                <option value="">-- Chọn ngôn ngữ --</option>
                            </select>
                            <div class="form-text small text-info"><i class="fa-solid fa-wand-magic-sparkles"></i> Hệ thống sẽ tự động gợi ý bản dịch khi bác chọn ngôn ngữ.</div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label font-weight-bold">Tiêu đề (Dịch)</label>
                            <input asp-for="Title" id="translatedTitle" class="form-control" required placeholder="Nhập tên đã dịch..." />
                        </div>

                        <div class="mb-3">
                            <label class="form-label font-weight-bold">Mô tả chi tiết</label>
                            <textarea asp-for="Description" id="translatedDesc" class="form-control" rows="4" placeholder="Viết mô tả bằng ngôn ngữ đã chọn..."></textarea>
                        </div>

                        <div class="mb-4">
                            <label class="form-label font-weight-bold">Kịch bản Audio (TTS Script)</label>
                            <textarea asp-for="TtsScript" id="translatedTts" class="form-control" rows="3" placeholder="Nội dung này sẽ dùng để AI đọc thành tiếng cho khách nghe..."></textarea>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a href="/Translation/Index?poiId=@ViewBag.PoiId" class="btn btn-outline-secondary">Quay lại</a>
                            <button type="submit" class="btn btn-info text-white px-4">🚀 Lưu bản dịch</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function suggestTranslation() {
            const selectElement = document.getElementById('langSelect');
            // Lấy tên từ ô input, nếu ô input trống thì lấy trực tiếp từ giá trị gõ tay
            const originalName = document.getElementById('originalName').value.trim();
            const langCode = selectElement.options[selectElement.selectedIndex].text.toLowerCase().trim();

            if (!originalName) {
                console.log("❌ Ô tên gốc đang trống, không có gì để dịch!");
                return;
            }

            console.log("🚀 Đang dịch:", originalName, "sang:", langCode);

            const titleInput = document.getElementById('translatedTitle');
            titleInput.placeholder = "⌛ Đang lấy gợi ý...";

            try {
                const url = `https://translate.googleapis.com/translate_a/single?client=gtx&sl=vi&tl=${langCode}&dt=t&q=${encodeURIComponent(originalName)}`;
                const response = await fetch(url);
                const data = await response.json();
        
                if (data && data[0] && data[0][0]) {
                    const result = data[0][0][0];
                    titleInput.value = result;
                    document.getElementById('translatedTts').value = result;
                }
            } catch (error) {
                console.error("❌ Lỗi API:", error);
            } finally {
                titleInput.placeholder = "Nhập tên đã dịch...";
            }
        }
    </script>
}