@model SmartTour.Shared.Models.Poi

<h2>Thêm địa điểm mới</h2>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div class="mb-3">
                <label class="form-label">Tên địa điểm</label>
                <input asp-for="Name" class="form-control" placeholder="Nhập tên..." required />
            </div>
            <div class="mb-3">
                <label class="form-label">Kinh độ (Latitude)</label>
                <input asp-for="Lat" id="lat" class="form-control" readonly />
            </div>
            <div class="mb-3">
                <label class="form-label">Vĩ độ (Longitude)</label>
                <input asp-for="Lng" id="lng" class="form-control" readonly />
            </div>
            <div class="mb-3">
                <label class="form-label">Bán kính (m)</label>
                <input asp-for="Radius" type="number" class="form-control" value="100" />
            </div>
            <button type="submit" class="btn btn-primary w-100">Lưu lại</button>
        </form>
    </div>
    <div class="col-md-8">
        <div id="map" style="height: 500px; border-radius: 10px;" class="shadow"></div>
        <p class="text-muted mt-2 small">* Click chuột vào bản đồ để lấy tọa độ tự động</p>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        var map = L.map('map').setView([21.0285, 105.8542], 13); // Mặc định ở Hà Nội
        L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);

        var marker;
        map.on('click', function(e) {
        var lat = e.latlng.lat;
        var lng = e.latlng.lng;

        if (marker) { map.removeLayer(marker); }
        marker = L.marker([lat, lng]).addTo(map);

        document.getElementById('lat').value = lat;
        document.getElementById('lng').value = lng;
        });
    </script>
}