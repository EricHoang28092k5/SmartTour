@model SmartTour.Shared.Models.Poi

@{
    ViewData["Title"] = "Thêm địa điểm mới";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<h2><i class="fa-solid fa-plus-circle text-success"></i> Thêm địa điểm mới</h2>
<hr />

@if (TempData["Error"] is string terr && !string.IsNullOrWhiteSpace(terr))
{
    <div class="alert alert-danger">@terr</div>
}

<div asp-validation-summary="All" class="alert alert-danger @(ViewData.ModelState.IsValid ? "d-none" : "")" role="alert"></div>

@if (User.IsInRole("Vendor"))
{
    <div class="alert alert-warning">
        <strong>Vendor:</strong> Sau khi bấm <strong>Tiếp tục — xem phí và xác nhận</strong>, hệ thống hiển thị màn <strong>xác nhận</strong> (phí cố định @(ViewBag.FixedVendorPoiCreateChargeVnd is long fx ? fx.ToString("N0") : "100.000") đ, số dư ví). Chỉ khi bấm <strong>Mua / Tạo POI</strong> mới trừ ví và tạo audio.
        Nạp tiền tại <a asp-controller="Wallet" asp-action="Index">Ví vendor</a> (tối thiểu @(ViewBag.MinWalletTopUpVnd is long mt ? mt.ToString("N0") : "20.000") đ).
    </div>
}

<form asp-action="Create" enctype="multipart/form-data">
    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tên địa điểm</label>
                        <input asp-for="Name" class="form-control" placeholder="Ví dụ: Thác Trị An..." required />
                    </div>
                    
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold">Kinh độ (Lat)</label>
                            <input asp-for="Lat" id="lat" class="form-control bg-light"  required />
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold">Vĩ độ (Lng)</label>
                            <input asp-for="Lng" id="lng" class="form-control bg-light"  required />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Bán kính kích hoạt (m)</label>
                        <input asp-for="Radius" type="number" class="form-control" value="100" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="Description" class="control-label fw-bold">Mô tả địa điểm <span class="text-danger">*</span></label>
                        <textarea asp-for="Description" class="form-control" rows="4" placeholder="Nhập mô tả địa điểm (bắt buộc)..." required maxlength="8000"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="TtsScript" class="control-label fw-bold">TTS Script gốc (tuỳ chọn, tối đa 255 ký tự)</label>
                        <textarea asp-for="TtsScript" class="form-control" rows="3" maxlength="255" placeholder="Để trống: hệ thống dùng câu mặc định “Chào mừng bạn đến với” + tên địa điểm."></textarea>
                        <div class="form-text text-muted">Nếu không nhập, script đọc là: Chào mừng bạn đến với [tên POI].</div>
                        <span asp-validation-for="TtsScript" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Ảnh bìa chính (1 ảnh)</label>
                        @if (User.IsInRole("Vendor"))
                        {
                            <input type="file" name="imageFile" class="form-control" accept="image/*" required />
                            <div class="form-text text-muted">Vendor: bắt buộc trước bước xem phí / xác nhận.</div>
                        }
                        else
                        {
                            <input type="file" name="imageFile" class="form-control" accept="image/*" />
                        }
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold text-primary">Album ảnh phụ (Có thể chọn nhiều ảnh cùng lúc)</label>
                        <input type="file" name="galleryFiles" class="form-control" accept="image/*" multiple />
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="OpenTime" class="form-label fw-bold">Giờ mở cửa</label>
                            <input asp-for="OpenTime" type="time" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CloseTime" class="form-label fw-bold">Giờ đóng cửa</label>
                            <input asp-for="CloseTime" type="time" class="form-control" />
                        </div>
                    </div>
                    <hr />
                    <button type="submit" class="btn btn-primary w-100 shadow">
                        @if (User.IsInRole("Vendor"))
                        {
                            <span><i class="fa-solid fa-arrow-right me-2"></i>Tiếp tục — xem phí và xác nhận</span>
                        }
                        else
                        {
                            <span><i class="fa-solid fa-save"></i> Lưu địa điểm</span>
                        }
                    </button>
                    <a asp-action="Index" class="btn btn-link w-100 mt-2 text-decoration-none text-muted">Quay lại danh sách</a>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="input-group mb-2">
                <input type="text" id="addressSearch" class="form-control" placeholder="Nhập địa chỉ để tìm nhanh...">
                <button class="btn btn-outline-secondary" type="button" onclick="searchLocation()">Tìm</button>
            </div>
            
            <div id="map" style="height: 520px; border-radius: 12px;" class="shadow-sm border"></div>
            
            <div class="alert alert-info mt-2 p-2 small text-center">
                <i class="fa-solid fa-circle-info"></i> Click trực tiếp vào bản đồ để lấy tọa độ.
            </div>
        </div>
    </div>
</form>
@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        // JS preview ảnh
        function previewImage(input) {
        if (input.files && input.files[0]) {
        var reader = new FileReader();
        reader.onload = function(e) {
        document.getElementById('preview').src = e.target.result;
        document.getElementById('imagePreview').style.display = 'block';
        }
        reader.readAsDataURL(input.files[0]);
        }
        }

        // JS Bản đồ (giữ nguyên code cũ của bác)
        var map = L.map('map').setView([10.9482, 106.8123], 13);
        L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
        setTimeout(function() { map.invalidateSize(); }, 500);

        var marker;
        map.on('click', function(e) { updateMarker(e.latlng.lat, e.latlng.lng); });

        function updateMarker(lat, lng) {
        if (marker) { map.removeLayer(marker); }
        marker = L.marker([lat, lng], { draggable: true }).addTo(map);
        document.getElementById('lat').value = lat.toFixed(6);
        document.getElementById('lng').value = lng.toFixed(6);
        marker.on('dragend', function (event) {
        var position = marker.getLatLng();
        document.getElementById('lat').value = position.lat.toFixed(6);
        document.getElementById('lng').value = position.lng.toFixed(6);
        });
        }

        function searchLocation() {
        var query = document.getElementById('addressSearch').value;
        fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${query}`)
        .then(res => res.json())
        .then(data => {
        if (data.length > 0) {
        map.setView([data[0].lat, data[0].lon], 16);
        updateMarker(parseFloat(data[0].lat), parseFloat(data[0].lon));
        }
        });
        }
    </script>
}