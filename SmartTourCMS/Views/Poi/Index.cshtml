@model IEnumerable<SmartTour.Shared.Models.Poi>

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0"><i class="fa-solid fa-map-location-dot me-2"></i>Quản lý Địa điểm (POI)</h4>
            <a asp-action="Create" class="btn btn-light btn-sm font-weight-bold">
                <i class="fa-solid fa-plus me-1"></i> Thêm mới
            </a>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th><i class="fa-solid fa-tag me-1"></i> Tên</th>
                        <th><i class="fa-solid fa-location-crosshairs me-1"></i> Vĩ độ (Lat)</th>
                        <th><i class="fa-solid fa-location-dot me-1"></i> Kinh độ (Lng)</th>
                        <th><i class="fa-solid fa-circle-nodes me-1"></i> Bán kính</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model) {
                        <tr>
                            <td class="fw-bold text-primary">@item.Name</td>
                            <td>@item.Lat</td>
                            <td>@item.Lng</td>
                            <td><span class="badge bg-info text-dark">@item.Radius m</span></td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm me-1" title="Sửa">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" 
                                   onclick="return confirm('Xác nhận xoá?')" 
                                   class="btn btn-outline-danger btn-sm" title="Xóa">
                                    <i class="fa-solid fa-trash-can"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
@section Scripts {
    @if (TempData["success"] != null)
    {
        <script type="text/javascript">
            toastr.options = {
                "closeButton": true,
                "progressBar": true,
                "positionClass": "toast-top-right",
                "showDuration": "300",
                "hideDuration": "1000",
                "timeOut": "5000",
                "extendedTimeOut": "1000",
                "showEasing": "swing",
                "hideEasing": "linear",
                "showMethod": "fadeIn",
                "hideMethod": "fadeOut"
            };
            toastr.success('@TempData["success"]');
        </script>
    }
}