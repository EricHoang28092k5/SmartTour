@using X.PagedList.Mvc.Core
@model X.PagedList.IPagedList<SmartTour.Shared.Models.Poi>

@{
    ViewData["Title"] = "Quản lý địa điểm";
}

@if (TempData["AudioWarning"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        @TempData["AudioWarning"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@* 1. TIÊU ĐỀ VÀ Ô TÌM KIẾM *@
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fa-solid fa-map-location-dot text-primary"></i> Quản lý địa điểm</h2>
    <div class="d-flex gap-2">
        <div class="input-group">
            <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-magnifying-glass text-muted"></i></span>
            <input type="text" id="searchInput" class="form-control border-start-0" placeholder="Tìm tên địa điểm..." onkeyup="filterTable()">
        </div>
        <a asp-action="Create" class="btn btn-success shadow-sm" style="min-width: 120px;">
            <i class="fa-solid fa-plus"></i> Thêm mới
        </a>
    </div>
</div>

@* 2. BẢNG DỮ LIỆU *@
<div class="card shadow border-0 mb-4">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0" id="poiTable">
            <thead class="table-dark">
                <tr>
                    <th>Ảnh</th>
                    <th>Tên địa điểm</th>
                    <th>Tọa độ</th>
                    <th>Bán kính</th>
                    <th>Giờ hoạt động</th>
                    <th>Hành động</th>
                    
                    @if (ViewBag.IsAdmin != null && (bool)ViewBag.IsAdmin)
                    {
                        <th>Người tạo (Vendor)</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-3">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" class="rounded shadow-sm border"
                                     style="width: 70px; height: 50px; object-fit: cover;"
                                     onerror="this.src='https://placehold.co/70x50?text=No+Image'" />
                            }
                            else
                            {
                                <div class="bg-light rounded border text-center" style="width: 70px; height: 50px; line-height: 50px;">
                                    <i class="fa-solid fa-image text-muted opacity-50"></i>
                                </div>
                            }
                        </td>
                        <td><strong>@item.Name</strong></td>
                        <td>
                            <span class="badge rounded-pill bg-light text-dark border">
                                @item.Lat.ToString("F4"), @item.Lng.ToString("F4")
                            </span>
                        </td>
                        <td>@item.Radius m</td>
                        <td>
                            @if (item.OpenTime.HasValue && item.CloseTime.HasValue)
                            {
                                <span class="badge bg-success">
                                    <i class="fa-regular fa-clock"></i>
                                    @item.OpenTime.Value.ToString(@"hh\:mm") - @item.CloseTime.Value.ToString(@"hh\:mm")
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Cả ngày</span>
                            }
                        </td>
                        <td class="text-center">
                            @* NÚT NGHE THỬ AUDIO *@
                            @if (item.AudioFiles != null && item.AudioFiles.Any())
                            {
                                var firstAudio = item.AudioFiles.First().FileUrl;
                                <button class="btn btn-sm btn-outline-primary me-1" title="Nghe thử" onclick="playPreview('@firstAudio')">
                                    <i class="fa-solid fa-volume-high"></i>
                                </button>
                            }
                            
                            <a href="/Translation/Index?poiId=@item.Id" class="btn btn-sm btn-outline-info me-1">
                                <i class="fa-solid fa-language"></i> Dịch
                            </a>

                            @* NÚT XEM BẢN ĐỒ *@
                            <button class="btn btn-sm btn-info text-white me-1" title="Xem vị trí"
                                    onclick="showMapModal('@item.Name', @item.Lat, @item.Lng)">
                                <i class="fa-solid fa-eye"></i>
                            </button>

                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning me-1" title="Sửa">
                                <i class="fa-solid fa-pen"></i>
                            </a>

                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return confirm('Bác có chắc chắn muốn xóa tận gốc địa điểm này không?');">
                                <button type="submit" class="btn btn-danger btn-sm">
                                    <i class="fa fa-trash"></i> Xóa
                                </button>
                            </form>
                        </td>
                        @if (ViewBag.IsAdmin != null && (bool)ViewBag.IsAdmin)
                        {
                            <td>
                                @if (!string.IsNullOrEmpty(item.VendorId) && ViewBag.VendorDict != null && ViewBag.VendorDict.ContainsKey(item.VendorId))
                                {
                                    <span class="badge bg-info text-dark">@ViewBag.VendorDict[item.VendorId]</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Hệ thống / Admin</span>
                                }
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    @* THANH PHÂN TRANG THÊM VÀO ĐÂY *@
    <div class="card-footer bg-white d-flex justify-content-center pt-3 pb-1 border-top-0">
        @Html.PagedListPager(Model, page => Url.Action("Index", new { page = page }), new PagedListRenderOptions
        {
            LiElementClasses = new string[] { "page-item" },
            PageClasses = new string[] { "page-link" }
        })
    </div>
</div>

@* 3. KHUNG MODAL HIỆN BẢN ĐỒ (POPUP) *@
<div class="modal fade" id="mapModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title font-weight-bold"><i class="fa-solid fa-earth-asia me-2"></i>Vị trí trên bản đồ</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <div id="quickMap" style="height: 450px; width: 100%;"></div>
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

@* 4. SCRIPTS XỬ LÝ *@
@section Scripts {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    
    <script>
        var quickMap;
        var currentMarker;

        function showMapModal(name, lat, lng) {
        var modalEl = document.getElementById('mapModal');
        var myModal = bootstrap.Modal.getOrCreateInstance(modalEl);
        myModal.show();

        modalEl.addEventListener('shown.bs.modal', function () {
        if (!quickMap) {
        quickMap = L.map('quickMap').setView([lat, lng], 15);
        L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; OpenStreetMap'
        }).addTo(quickMap);
        } else {
        quickMap.setView([lat, lng], 15);
        }

        if (currentMarker) quickMap.removeLayer(currentMarker);
        currentMarker = L.marker([lat, lng]).addTo(quickMap)
        .bindPopup("<b>" + name + "</b>").openPopup();
                    
        setTimeout(function(){
        quickMap.invalidateSize();
        }, 250);
        }, { once: false });
        }

        function filterTable() {
        var input = document.getElementById("searchInput");
        var filter = input.value.toUpperCase();
        var table = document.getElementById("poiTable");
        var tr = table.getElementsByTagName("tr");

        for (var i = 1; i < tr.length; i++) {
        // Đã sửa thành td[1] để tìm kiếm theo cột "Tên địa điểm"
        var tdName = tr[i].getElementsByTagName("td")[1];
        if (tdName) {
        var txtValue = tdName.textContent || tdName.innerText;
        tr[i].style.display = txtValue.toUpperCase().indexOf(filter) > -1 ? "" : "none";
        }
        }
        }

        function playPreview(url) {
        var audio = new Audio(url);
        audio.play().catch(e => {
        alert("Lỗi phát audio: File không tồn tại hoặc sai đường dẫn cu ơi!");
        console.error(e);
        });
        }
    </script>
}