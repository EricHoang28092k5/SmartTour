@model IEnumerable<SmartTour.Shared.Models.Poi>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fa-solid fa-list text-primary"></i> Danh sách địa điểm</h2>
    <a asp-action="Create" class="btn btn-success shadow">
        <i class="fa-solid fa-plus"></i> Thêm địa điểm mới
    </a>
</div>

<div class="card shadow border-0">
    <div class="card-body">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Tên địa điểm</th>
                    <th>Tọa độ (Lat, Lng)</th>
                    <th>Bán kính</th>
                    <th class="text-center">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td><strong>@item.Name</strong></td>
                        <td><span class="badge bg-info text-dark">@item.Lat, @item.Lng</span></td>
                        <td>@item.Radius (m)</td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">
                                <i class="fa-solid fa-pen-to-square"></i> Sửa
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm" onclick="return confirm('Có chắc là muốn xóa địa điểm này không cu?')">
                                <i class="fa-solid fa-trash"></i> Xóa
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>