@model SmartTourCMS.Models.PoiCreateConfirmViewModel
@{
    ViewData["Title"] = "Xác nhận tạo POI";
    var d = Model.Draft;
}

@if (TempData["Error"] is string terr && !string.IsNullOrWhiteSpace(terr))
{
    <div class="alert alert-danger">@terr</div>
}

<h2 class="mb-3"><i class="fa-solid fa-cart-shopping text-primary me-2"></i>Xác nhận tạo địa điểm</h2>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-white fw-bold">Thông tin POI</div>
    <div class="card-body">
        <p class="mb-1"><strong>Tên:</strong> @d.Name</p>
        <p class="mb-1"><strong>Tọa độ:</strong> @d.Lat.ToString("F6"), @d.Lng.ToString("F6") — bán kính @d.Radius m</p>
        <p class="mb-1"><strong>Mô tả (rút gọn):</strong> @(d.Description.Length > 200 ? d.Description[..200] + "…" : d.Description)</p>
        <p class="mb-0"><strong>Script TTS gốc (rút gọn):</strong> @((d.TtsScript ?? d.Description).Length > 200 ? (d.TtsScript ?? d.Description)[..200] + "…" : (d.TtsScript ?? d.Description))</p>
    </div>
</div>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-white fw-bold">Thanh toán từ ví (phí tạo POI cố định)</div>
    <div class="card-body">
        <p class="mb-1"><strong>Phí tạo POI:</strong> <span class="text-primary fs-4 fw-bold">@d.ChargeVnd.ToString("N0") đ</span></p>
        <p class="mb-1"><strong>Số dư ví hiện tại:</strong> @Model.BalanceVnd.ToString("N0") đ</p>
        @if (!Model.SufficientBalance)
        {
            <div class="alert alert-warning mt-2 mb-0">
                Số dư không đủ. Nạp tối thiểu @Model.MinWalletTopUpVnd.ToString("N0") đ tại
                <a asp-controller="Wallet" asp-action="Index">Ví vendor</a>.
            </div>
        }
    </div>
</div>

<div class="d-flex flex-wrap gap-2">
    @if (Model.SufficientBalance)
    {
        <form asp-action="CreateConfirmPost" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-success btn-lg">
                <i class="fa-solid fa-check me-2"></i>Mua / Tạo POI
            </button>
        </form>
    }
    <form asp-action="CreateConfirmCancel" method="post" class="d-inline">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-outline-secondary btn-lg">Quay lại</button>
    </form>
</div>
