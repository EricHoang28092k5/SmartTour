<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SmartTour Admin - Dashboard</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <style>
        :root { --sidebar-width: 260px; }
        body { background-color: #f4f7f6; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        
        /* Sidebar xịn sò có Flexbox để ép nút Logout xuống đáy */
        .sidebar { 
            width: var(--sidebar-width); 
            height: 100vh; 
            background: #2c3e50; 
            position: fixed; 
            left: 0; top: 0; 
            transition: all 0.3s;
            z-index: 1000;
            box-shadow: 4px 0 10px rgba(0,0,0,0.1);
            display: flex;
            flex-direction: column;
        }
        
        .sidebar-header { padding: 20px; text-align: center; background: #1a252f; color: #f1c40f; font-weight: bold; }
        
        .nav-link { 
            color: #bdc3c7 !important; /* Đã set màu sáng ở đây rồi thì đừng có nhét text-dark vào nữa! */
            padding: 15px 25px !important; 
            border-left: 4px solid transparent;
            transition: 0.3s;
        }
        
        .nav-link:hover { background: #34495e; color: #fff !important; border-left: 4px solid #f1c40f; }
        .nav-link.active { background: #34495e; color: #fff !important; border-left: 4px solid #3498db; }

        .main-content { 
            margin-left: var(--sidebar-width); 
            padding: 30px; 
            min-height: 100vh;
        }

        hr { border-top: 1px solid #46545f; margin: 10px 20px; }
        
        /* Container đẩy nút logout xuống dưới cùng */
        .logout-container { margin-top: auto; padding-bottom: 20px; }
    </style>
</head>
<body>

    <div class="sidebar">
        <div class="sidebar-header">
            <h3>🚏 SMART TOUR</h3>
        </div>
        
        <ul class="nav flex-column mt-3 w-100">
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")" asp-controller="Home" asp-action="Index">
                    <i class="fa-solid fa-chart-line me-2"></i> Bảng điều khiển
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Poi" ? "active" : "")" asp-controller="Poi" asp-action="Index">
                    <i class="fa-solid fa-location-dot me-2"></i> Quản lý địa điểm
                </a>
            </li>
            @if (User.IsInRole("Admin"))
            {
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "PendingApprovals" ? "active" : "")" asp-controller="Poi" asp-action="PendingApprovals">
                        <i class="fa-solid fa-hourglass-half me-2"></i> POI chờ duyệt
                    </a>
                </li>
            }
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Food" ? "active" : "")" asp-controller="Food" asp-action="Index">
                    <i class="fa-solid fa-utensils me-2"></i> Quản lý Thực đơn
                </a>
            </li>

            <hr>

            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Plays" ? "active" : "")" asp-controller="Log" asp-action="Plays">
                    <i class="fa-solid fa-play me-2"></i> Lịch sử nghe
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "ScriptRequest" ? "active" : "")" asp-controller="ScriptRequest" asp-action="Index">
                    <i class="fa-solid fa-file-signature me-2"></i> Yêu cầu script
                </a>
            </li>

            @if (User.IsInRole("Admin"))
            {
                <hr>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "User" ? "active" : "")" asp-controller="User" asp-action="Index">
                        <i class="fa-solid fa-users-gear me-2"></i> Quản lý tài khoản
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Heatmap" ? "active" : "")" asp-controller="Heatmap" asp-action="Index">
                        <i class="fa-solid fa-fire me-2" style="color: #e74c3c;"></i> Bản đồ nhiệt (Heatmap)
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Pending" ? "active" : "")" asp-controller="ScriptRequest" asp-action="Pending">
                        <i class="fa-solid fa-list-check me-2"></i> Duyệt script
                    </a>
                </li>
            }
        </ul>

        <div class="logout-container w-100">
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link text-danger fw-bold" style="color: #e74c3c !important;" asp-controller="Account" asp-action="Logout">
                        <i class="fa-solid fa-right-from-bracket me-2"></i> Đăng xuất
                    </a>
                </li>
            </ul>
        </div>
    </div>

    <div class="main-content">
        <div class="container-fluid">
            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>