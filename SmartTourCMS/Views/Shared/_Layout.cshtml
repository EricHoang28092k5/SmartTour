<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SmartTour Admin - Dashboard</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <style>
        :root { --sidebar-width: 260px; }
        body { background-color: #f4f7f6; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        
        /* Sidebar xịn sò */
        .sidebar { 
            width: var(--sidebar-width); 
            height: 100vh; 
            background: #2c3e50; 
            position: fixed; 
            left: 0; top: 0; 
            transition: all 0.3s;
            z-index: 1000;
            box-shadow: 4px 0 10px rgba(0,0,0,0.1);
        }
        
        .sidebar-header { padding: 20px; text-align: center; background: #1a252f; color: #f1c40f; font-weight: bold; }
        
        .nav-link { 
            color: #bdc3c7 !important; 
            padding: 15px 25px !important; 
            border-left: 4px solid transparent;
            transition: 0.3s;
        }
        
        .nav-link:hover { background: #34495e; color: #fff !important; border-left: 4px solid #f1c40f; }
        .nav-link.active { background: #34495e; color: #fff !important; border-left: 4px solid #3498db; }

        /* Vùng nội dung bên phải */
        .main-content { 
            margin-left: var(--sidebar-width); 
            padding: 30px; 
            min-height: 100vh;
        }

        hr { border-top: 1px solid #46545f; margin: 10px 20px; }
    </style>
</head>
<body>

    <div class="sidebar">
        <div class="sidebar-header">
            <h3>🚏 SMART TOUR</h3>
        </div>
<ul class="nav flex-column mt-3">
    <li class="nav-item">
        <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")" asp-controller="Home" asp-action="Index">
            <i class="fa-solid fa-chart-line me-2"></i> Bảng điều khiển
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Poi" ? "active" : "")" asp-controller="Poi" asp-action="Index">
            <i class="fa-solid fa-location-dot me-2"></i> Quản lý địa điểm
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Tour" ? "active" : "")" asp-controller="Tour" asp-action="Index">
            <i class="fa-solid fa-route me-2"></i> Quản lý Tour
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Audio" ? "active" : "")" asp-controller="Audio" asp-action="Upload">
            <i class="fa-solid fa-microphone-lines me-2"></i> Thêm Audio
        </a>
    </li>
    <hr>
    <li class="nav-item">
        <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Locations" ? "active" : "")" asp-controller="Log" asp-action="Locations">
            <i class="fa-solid fa-shoe-prints me-2"></i> Lịch sử di chuyển
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Plays" ? "active" : "")" asp-controller="Log" asp-action="Plays">
            <i class="fa-solid fa-play me-2"></i> Lịch sử nghe
        </a>
    </li>
</ul>
    </div>

    <div class="main-content">
        <div class="container-fluid">
            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>