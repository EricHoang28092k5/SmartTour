@model List<SmartTour.Shared.Models.ScriptChangeRequest>
@{
    ViewData["Title"] = "Pending Script Requests";
}

<h3>Yêu cầu chờ duyệt</h3>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>POI</th>
            <th>Lang</th>
            <th>Nội dung</th>
            <th>Người gửi</th>
            <th>Tạo lúc</th>
            <th>Hành động</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Id</td>
            <td>@item.PoiId</td>
            <td>@item.LanguageCode</td>
            <td style="max-width: 350px; white-space: pre-wrap;">@item.NewScript</td>
            <td>@item.CreatedByUserId</td>
            <td>@item.CreatedAt.ToLocalTime()</td>
            <td>
                <form asp-action="Approve" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@item.Id" />
                    <button type="submit" class="btn btn-sm btn-success">Approve</button>
                </form>
                <form asp-action="Reject" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@item.Id" />
                    <input type="text" name="reason" class="form-control form-control-sm d-inline-block" style="width: 140px;" placeholder="Lý do" />
                    <button type="submit" class="btn btn-sm btn-danger">Reject</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>
