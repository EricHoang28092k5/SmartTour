<?xml version="1.0" encoding="utf-8" ?>

<Shell
    x:Class="SmartTourApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:SmartTourApp.Pages">

    <TabBar>

        <ShellContent
        Title="Home"
        Route="home"
        ContentTemplate="{DataTemplate pages:HomePage}" />

        <ShellContent
        Title="Map"
        Route="map"
        ContentTemplate="{DataTemplate pages:MapPage}" />

        <ShellContent
        Title="QR Scan"
        Route="qr"
        ContentTemplate="{DataTemplate pages:QrScannerPage}" />

        <ShellContent
        Title="Settings"
        Route="settings"
        ContentTemplate="{DataTemplate pages:SettingsPage}" />

    </TabBar>

</Shell>