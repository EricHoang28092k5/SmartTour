<?xml version="1.0" encoding="utf-8" ?>
<Shell
    x:Class="SmartTourApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:SmartTourApp.Pages"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit">

    <Shell.Resources>
        <toolkit:MediaElement x:Name="HiddenPlayer" 
                              x:Key="HiddenPlayer"
                              ShouldAutoPlay="False" />
    </Shell.Resources>

    <TabBar>
        <ShellContent Title="Home" Icon="home.png" ContentTemplate="{DataTemplate pages:HomePage}" />
        <ShellContent Title="Map" ContentTemplate="{DataTemplate pages:MapPage}" />
        <ShellContent Title="QR Scan" ContentTemplate="{DataTemplate pages:QrScannerPage}" />
        <ShellContent Title="Settings" ContentTemplate="{DataTemplate pages:SettingsPage}" />
    </TabBar>

</Shell>