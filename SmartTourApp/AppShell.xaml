<Shell
    x:Class="SmartTourApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:SmartTourApp.Pages">

    <TabBar>

        <ShellContent
            Title="Map"
            ContentTemplate="{DataTemplate local:MapPage}" />

        <ShellContent
            Title="QR Scan"
            ContentTemplate="{DataTemplate local:QrScannerPage}" />

        <ShellContent
            Title="Settings"
            ContentTemplate="{DataTemplate local:SettingsPage}" />

    </TabBar>

</Shell>