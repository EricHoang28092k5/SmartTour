<?xml version="1.0" encoding="utf-8" ?>
<Shell
    x:Class="SmartTourApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:SmartTourApp.Pages">

    <TabBar>
        <ShellContent
        x:Name="ContentHome"
        Route="home"
        ContentTemplate="{DataTemplate pages:HomePage}" />

        <ShellContent
        x:Name="ContentMap"
        Route="map"
        ContentTemplate="{DataTemplate pages:MapPage}" />

        <ShellContent
        x:Name="ContentTour"
        Route="tour"
        ContentTemplate="{DataTemplate pages:TourPage}" />

        <ShellContent
        x:Name="ContentSettings"
        Route="settings"
        ContentTemplate="{DataTemplate pages:SettingsPage}" />
    </TabBar>
</Shell>
