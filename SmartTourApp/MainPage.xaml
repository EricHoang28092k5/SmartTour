<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui"
    x:Class="SmartTourApp.MainPage"
    Title="Smart Tour">

    <Grid>

        <mapsui:MapControl
            x:Name="TourMap"/>

        <Border
            BackgroundColor="#FFFFFFDD"
            Padding="10"
            Margin="10"
            VerticalOptions="End">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20" />
            </Border.StrokeShape>

            <VerticalStackLayout>

                <Label
                    Text="POI gần nhất"
                    FontSize="16"
                    FontAttributes="Bold"/>

                <Label
                    x:Name="NearestPoiLabel"
                    FontSize="14"/>

            </VerticalStackLayout>

        </Border>

    </Grid>

</ContentPage>