<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="SmartTourApp.Pages.LoadingPage"
    BackgroundColor="Black">

    <Grid>

        <!-- BACKGROUND IMAGE -->
        <Image
            Source="hauvuong.jpg"
            Aspect="AspectFill" />

        <!-- OVERLAY DARK -->
        <BoxView BackgroundColor="#80000000" />

        <!-- CONTENT -->
        <VerticalStackLayout
            VerticalOptions="Center"
            HorizontalOptions="Center"
            Spacing="25">

            <!-- LOGO -->
            <Image
                x:Name="Logo"
                Source="mappin.png"
                HeightRequest="100"
                Opacity="0"
                Scale="0.8"/>

            <!-- APP NAME -->
            <Label
                Text="SmartTour"
                FontSize="32"
                FontAttributes="Bold"
                TextColor="White"
                Opacity="0"/>

            <!-- STATUS -->
            <Label
                x:Name="StatusLabel"
                Text="Đang khởi động..."
                FontSize="14"
                TextColor="#e2e8f0"
                HorizontalOptions="Center"/>

            <!-- PROGRESS -->
            <ProgressBar
                x:Name="ProgressBar"
                Progress="0"
                WidthRequest="220"
                HeightRequest="6"/>

            <!-- PERCENT -->
            <Label
                x:Name="PercentLabel"
                Text="0%"
                TextColor="White"
                HorizontalOptions="Center"/>

        </VerticalStackLayout>

    </Grid>
</ContentPage>