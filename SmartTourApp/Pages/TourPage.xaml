<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="SmartTourApp.Pages.TourPage"
    BackgroundColor="#F7F8FC"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">

        <!-- ══════════════════════════════════════ -->
        <!--  HEADER                                -->
        <!-- ══════════════════════════════════════ -->
        <Grid Grid.Row="0" BackgroundColor="White" Padding="20,54,20,16">
            <!-- Bottom separator -->
            <BoxView VerticalOptions="End"
                     HorizontalOptions="Fill"
                     HeightRequest="1"
                     BackgroundColor="#EEEEF5"/>

            <Grid ColumnDefinitions="*,Auto">

                <VerticalStackLayout Grid.Column="0" Spacing="2">
                    <Label x:Name="LblSubtitle"
                           Text="HÀNH TRÌNH"
                           FontSize="11"
                           FontAttributes="Bold"
                           TextColor="#5B8CFF"
                           CharacterSpacing="2.5"/>
                    <Label x:Name="LblTitle"
                           Text="Tours"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="#0D0D0D"
                           CharacterSpacing="-0.5"/>
                </VerticalStackLayout>

                <!-- Tour count badge -->
                <Border Grid.Column="1"
                        BackgroundColor="#F0F5FF"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 20"
                        Padding="14,8"
                        VerticalOptions="Center">
                    <Label x:Name="TourCountLabel"
                           Text="0 tours"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="#3461FF"
                           VerticalOptions="Center"/>
                </Border>
            </Grid>
        </Grid>

        <!-- ══════════════════════════════════════ -->
        <!--  TOUR LIST                             -->
        <!-- ══════════════════════════════════════ -->
        <CollectionView x:Name="TourList"
                        Grid.Row="1"
                        Margin="0"
                        SelectionMode="None"
                        BackgroundColor="#F7F8FC">

            <CollectionView.Header>
                <BoxView HeightRequest="16" BackgroundColor="#F7F8FC"/>
            </CollectionView.Header>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <!-- ─── TOUR CARD ─── -->
                    <Border Margin="16,0,16,20"
                            BackgroundColor="White"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 24">

                        <Border.Shadow>
                            <Shadow Brush="#1A1A3E" Offset="0,6" Radius="28" Opacity="0.08"/>
                        </Border.Shadow>

                        <VerticalStackLayout Spacing="0">

                            <!-- ── GRADIENT TOP ACCENT ── -->
                            <Border HeightRequest="4" StrokeThickness="0"
                                    StrokeShape="RoundRectangle 24,24,0,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#3461FF" Offset="0"/>
                                        <GradientStop Color="#7C9FFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>

                            <!-- ── CARD BODY ── -->
                            <VerticalStackLayout Spacing="0" Padding="20,18,20,20">

                                <!-- ROW 1: icon + title + offline badge -->
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14" Margin="0,0,0,12">

                                    <!-- Map icon badge -->
                                    <Border Grid.Column="0"
                                            WidthRequest="48" HeightRequest="48"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 14">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#3461FF" Offset="0"/>
                                                <GradientStop Color="#7C9FFF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Label Text="🗺️"
                                               FontSize="22"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Border>

                                    <!-- Name + stops count -->
                                    <VerticalStackLayout Grid.Column="1" Spacing="5" VerticalOptions="Center">
                                        <Label Text="{Binding Name}"
                                               FontSize="17"
                                               FontAttributes="Bold"
                                               TextColor="#0D0D0D"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="1"/>
                                        <HorizontalStackLayout Spacing="6">
                                            <Border BackgroundColor="#EEF4FF"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 8"
                                                    Padding="8,4">
                                                <Label Text="{Binding Pois.Count, StringFormat='{}{0} điểm dừng'}"
                                                       FontSize="11"
                                                       FontAttributes="Bold"
                                                       TextColor="#3461FF"/>
                                            </Border>
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>

                                    <!-- Offline status badge -->
                                    <Border Grid.Column="2"
                                            x:Name="OfflineBadge"
                                            BackgroundColor="#F0FFF4"
                                            StrokeThickness="1"
                                            Stroke="#BBF7D0"
                                            StrokeShape="RoundRectangle 10"
                                            Padding="8,4"
                                            VerticalOptions="Start">
                                        <Label x:Name="OfflineBadgeLabel"
                                               Text="📶"
                                               FontSize="11"
                                               FontAttributes="Bold"
                                               TextColor="#15803D"/>
                                    </Border>
                                </Grid>

                                <!-- Description -->
                                <Label Text="{Binding Description}"
                                       FontSize="13"
                                       TextColor="#666688"
                                       LineHeight="1.55"
                                       Margin="0,0,0,14"
                                       LineBreakMode="WordWrap"
                                       MaxLines="0"/>

                                <!-- ── STOPS PREVIEW (horizontal pills) ── -->
                                <ScrollView Orientation="Horizontal"
                                            HorizontalScrollBarVisibility="Never"
                                            Margin="0,0,0,16">
                                    <HorizontalStackLayout Spacing="8"
                                                           BindableLayout.ItemsSource="{Binding Pois}">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate>
                                                <Border BackgroundColor="#F4F6FF"
                                                        StrokeThickness="1"
                                                        Stroke="#D0DEFF"
                                                        StrokeShape="RoundRectangle 10"
                                                        Padding="10,6">
                                                    <HorizontalStackLayout Spacing="6">
                                                        <Border WidthRequest="20" HeightRequest="20"
                                                                StrokeThickness="0"
                                                                StrokeShape="RoundRectangle 10">
                                                            <Border.Background>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                    <GradientStop Color="#3461FF" Offset="0"/>
                                                                    <GradientStop Color="#7C9FFF" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Border.Background>
                                                            <Label Text="{Binding OrderIndex}"
                                                                   FontSize="10"
                                                                   FontAttributes="Bold"
                                                                   TextColor="White"
                                                                   HorizontalOptions="Center"
                                                                   VerticalOptions="Center"/>
                                                        </Border>
                                                        <Label Text="{Binding Name}"
                                                               FontSize="12"
                                                               TextColor="#334"
                                                               VerticalOptions="Center"
                                                               LineBreakMode="TailTruncation"
                                                               MaxLines="1"/>
                                                    </HorizontalStackLayout>
                                                </Border>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </HorizontalStackLayout>
                                </ScrollView>

                                <!-- ── OFFLINE DOWNLOAD PROGRESS ── -->
                                <Border x:Name="DownloadProgressBar"
                                        IsVisible="False"
                                        BackgroundColor="#F0F5FF"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 12"
                                        Padding="12,10"
                                        Margin="0,0,0,12">
                                    <VerticalStackLayout Spacing="6">
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                            <ActivityIndicator Grid.Column="0"
                                                               IsRunning="True"
                                                               Color="#3461FF"
                                                               WidthRequest="16" HeightRequest="16"/>
                                            <Label Grid.Column="1"
                                                   x:Name="DownloadProgressLabel"
                                                   Text="Đang tải..."
                                                   FontSize="12"
                                                   FontAttributes="Bold"
                                                   TextColor="#3461FF"
                                                   VerticalOptions="Center"/>
                                            <Label Grid.Column="2"
                                                   x:Name="DownloadPercentLabel"
                                                   Text="0%"
                                                   FontSize="11"
                                                   TextColor="#9BAACC"
                                                   VerticalOptions="Center"/>
                                        </Grid>
                                        <!-- Progress fill bar -->
                                        <Border HeightRequest="4"
                                                BackgroundColor="#D0DEFF"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 2">
                                            <Border x:Name="DownloadFill"
                                                    HeightRequest="4"
                                                    WidthRequest="0"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 2"
                                                    HorizontalOptions="Start">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#3461FF" Offset="0"/>
                                                        <GradientStop Color="#7C9FFF" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                        </Border>
                                    </VerticalStackLayout>
                                </Border>

                                <!-- ── ACTION ROW ── -->
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">

                                    <!-- Download offline button -->
                                    <Border Grid.Column="0"
                                            BackgroundColor="#F4F6FF"
                                            StrokeThickness="1"
                                            Stroke="#D0DEFF"
                                            StrokeShape="RoundRectangle 22"
                                            WidthRequest="48" HeightRequest="48">
                                        <Button x:Name="OfflineBtn"
                                                Text="⬇"
                                                FontSize="18"
                                                TextColor="#3461FF"
                                                BackgroundColor="Transparent"
                                                Clicked="OnDownloadOfflineTapped"
                                                CommandParameter="{Binding .}"
                                                WidthRequest="48"
                                                HeightRequest="48"
                                                Padding="0"/>
                                    </Border>

                                    <!-- Expand / collapse detail -->
                                    <Border Grid.Column="1"
                                            StrokeThickness="1"
                                            Stroke="#E0E7FF"
                                            StrokeShape="RoundRectangle 22"
                                            BackgroundColor="#F8F9FF">
                                        <Button x:Name="ExpandBtn"
                                                Text="Chi tiết ↓"
                                                Clicked="OnExpandTapped"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="Transparent"
                                                TextColor="#555577"
                                                FontSize="13"
                                                HeightRequest="48"
                                                Padding="0"/>
                                    </Border>

                                    <!-- View on map -->
                                    <Border Grid.Column="2"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 22"
                                            WidthRequest="120">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#3461FF" Offset="0"/>
                                                <GradientStop Color="#7C9FFF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.Shadow>
                                            <Shadow Brush="#3461FF" Offset="0,4" Radius="16" Opacity="0.25"/>
                                        </Border.Shadow>
                                        <Button Text="🗺 Bản đồ"
                                                Clicked="StartTourOnMap"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="Transparent"
                                                TextColor="White"
                                                FontSize="13"
                                                FontAttributes="Bold"
                                                HeightRequest="48"
                                                Padding="0"/>
                                    </Border>
                                </Grid>

                                <!-- ── EXPANDED DETAIL ── -->
                                <VerticalStackLayout
                                    IsVisible="{Binding IsExpanded}"
                                    Spacing="0"
                                    Margin="0,20,0,0">

                                    <!-- Divider with label -->
                                    <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="10" Margin="0,0,0,16">
                                        <BoxView Grid.Column="0" HeightRequest="1"
                                                 BackgroundColor="#EEEEEE" VerticalOptions="Center"/>
                                        <Label Grid.Column="1"
                                               x:Name="LblSchedule"
                                               Text="LỊCH TRÌNH"
                                               FontSize="10"
                                               FontAttributes="Bold"
                                               TextColor="#BBBBBB"
                                               CharacterSpacing="2"
                                               VerticalOptions="Center"/>
                                        <BoxView Grid.Column="2" HeightRequest="1"
                                                 BackgroundColor="#EEEEEE" VerticalOptions="Center"/>
                                    </Grid>

                                    <!-- Timeline stops -->
                                    <CollectionView ItemsSource="{Binding Pois}" SelectionMode="None">
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ColumnDefinitions="32,*" Margin="0,0,0,4">
                                                    <Grid Grid.Column="0" RowDefinitions="Auto,*">
                                                        <Border Grid.Row="0"
                                                                WidthRequest="24" HeightRequest="24"
                                                                StrokeThickness="0"
                                                                StrokeShape="RoundRectangle 12"
                                                                HorizontalOptions="Center"
                                                                Margin="0,6,0,0">
                                                            <Border.Background>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                    <GradientStop Color="#3461FF" Offset="0"/>
                                                                    <GradientStop Color="#7C9FFF" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Border.Background>
                                                            <Label Text="{Binding OrderIndex}"
                                                                   FontSize="11"
                                                                   FontAttributes="Bold"
                                                                   TextColor="White"
                                                                   HorizontalOptions="Center"
                                                                   VerticalOptions="Center"/>
                                                        </Border>
                                                        <BoxView Grid.Row="1"
                                                                 WidthRequest="2"
                                                                 BackgroundColor="#E0E7FF"
                                                                 HorizontalOptions="Center"
                                                                 VerticalOptions="Fill"
                                                                 Margin="0,2,0,0"/>
                                                    </Grid>

                                                    <Border Grid.Column="1"
                                                            BackgroundColor="#F7F8FC"
                                                            StrokeThickness="0"
                                                            StrokeShape="RoundRectangle 14"
                                                            Padding="14,10"
                                                            Margin="0,4,0,6">
                                                        <VerticalStackLayout Spacing="3">
                                                            <Label Text="{Binding Name}"
                                                                   FontSize="13"
                                                                   FontAttributes="Bold"
                                                                   TextColor="#1A1A2E"/>
                                                            <Label Text="{Binding OrderIndex, StringFormat='Điểm dừng #{0}'}"
                                                                   FontSize="11"
                                                                   TextColor="#AAAAAA"/>
                                                        </VerticalStackLayout>
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>

                                    <!-- Big CTA inside expanded -->
                                    <Border Margin="0,16,0,0"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 22">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#1A3AFF" Offset="0"/>
                                                <GradientStop Color="#3461FF" Offset="0.5"/>
                                                <GradientStop Color="#7C9FFF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.Shadow>
                                            <Shadow Brush="#3461FF" Offset="0,6" Radius="24" Opacity="0.3"/>
                                        </Border.Shadow>
                                        <Button x:Name="LblStartJourney"
                                                Text="🚀  Bắt đầu hành trình trên bản đồ"
                                                Clicked="StartTourOnMap"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="Transparent"
                                                TextColor="White"
                                                FontSize="15"
                                                FontAttributes="Bold"
                                                HeightRequest="54"
                                                Padding="0"/>
                                    </Border>
                                </VerticalStackLayout>

                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.Footer>
                <BoxView HeightRequest="40" BackgroundColor="#F7F8FC"/>
            </CollectionView.Footer>

        </CollectionView>

    </Grid>
</ContentPage>
