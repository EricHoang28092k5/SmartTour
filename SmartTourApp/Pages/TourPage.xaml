<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="SmartTourApp.Pages.TourPage"
    BackgroundColor="#F8F9FD"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">

        <!-- ══════════════════════════════════════ -->
        <!--  HEADER                                -->
        <!-- ══════════════════════════════════════ -->
        <Grid Grid.Row="0"
              BackgroundColor="White"
              Padding="20,54,20,20">
            <BoxView VerticalOptions="End"
                     HorizontalOptions="Fill"
                     HeightRequest="1"
                     BackgroundColor="#F0F0F5"/>

            <Grid ColumnDefinitions="*,Auto">
                <VerticalStackLayout Grid.Column="0" Spacing="3">
                    <Label Text="HÀNH TRÌNH"
                           FontSize="11"
                           FontAttributes="Bold"
                           TextColor="#1E88E5"
                           CharacterSpacing="2.5"/>
                    <Label Text="Tours"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="#0D0D0D"
                           CharacterSpacing="-0.5"/>
                </VerticalStackLayout>

                <!-- Offline status badge -->
                <Border x:Name="OfflineStatusBadge"
                        Grid.Column="1"
                        BackgroundColor="#F0F7FF"
                        StrokeThickness="1"
                        Stroke="#BBDEFB"
                        StrokeShape="RoundRectangle 20"
                        Padding="12,6"
                        VerticalOptions="Center">
                    <HorizontalStackLayout Spacing="6">
                        <Label x:Name="OfflineStatusIcon"
                               Text="🌐"
                               FontSize="13"
                               VerticalOptions="Center"/>
                        <Label x:Name="OfflineStatusLabel"
                               Text="Online"
                               FontSize="11"
                               FontAttributes="Bold"
                               TextColor="#1565C0"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>
            </Grid>
        </Grid>

        <!-- ══════════════════════════════════════ -->
        <!--  CONTENT                               -->
        <!-- ══════════════════════════════════════ -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="0">

                <!-- ── OFFLINE PREFETCH CARD (Yêu cầu 1) ── -->
                <Border x:Name="PrefetchCard"
                        Margin="16,20,16,0"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 20">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1565C0" Offset="0"/>
                            <GradientStop Color="#1E88E5" Offset="0.6"/>
                            <GradientStop Color="#42A5F5" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="#1565C0" Offset="0,8" Radius="24" Opacity="0.25"/>
                    </Border.Shadow>

                    <VerticalStackLayout Padding="20,18" Spacing="14">

                        <!-- Title row -->
                        <Grid ColumnDefinitions="Auto,*">
                            <Border Grid.Column="0"
                                    WidthRequest="44" HeightRequest="44"
                                    BackgroundColor="#1EFFFFFF"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 14"
                                    Margin="0,0,14,0">
                                <Label Text="📥"
                                       FontSize="22"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>

                            <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                <Label Text="Tải trước để dùng Offline"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="White"/>
                                <Label x:Name="PrefetchSubtitle"
                                       Text="Tải thuyết minh về máy trước khi tour bắt đầu"
                                       FontSize="12"
                                       TextColor="#AADDFF"
                                       LineBreakMode="WordWrap"/>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Progress bar (ẩn khi idle) -->
                        <VerticalStackLayout x:Name="PrefetchProgressSection"
                                             IsVisible="False"
                                             Spacing="8">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label x:Name="PrefetchProgressLabel"
                                       Text="Đang tải..."
                                       FontSize="12"
                                       TextColor="#AADDFF"/>
                                <Label x:Name="PrefetchPercentLabel"
                                       Grid.Column="1"
                                       Text="0%"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="White"/>
                            </Grid>

                            <Border HeightRequest="6"
                                    BackgroundColor="#1EFFFFFF"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 3">
                                <Grid HorizontalOptions="Start" x:Name="PrefetchProgressFillContainer">
                                    <Border x:Name="PrefetchProgressFill"
                                            HeightRequest="6"
                                            WidthRequest="0"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 3"
                                            BackgroundColor="White"
                                            HorizontalOptions="Start"/>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Action button -->
                        <Border StrokeThickness="0"
                                StrokeShape="RoundRectangle 14"
                                BackgroundColor="#1EFFFFFF">
                            <Button x:Name="PrefetchBtn"
                                    Text="⬇  Tải xuống offline"
                                    Clicked="OnPrefetchClicked"
                                    BackgroundColor="Transparent"
                                    TextColor="White"
                                    FontSize="14"
                                    FontAttributes="Bold"
                                    HeightRequest="46"
                                    Padding="0"/>
                        </Border>

                        <!-- Stats row -->
                        <Grid ColumnDefinitions="*,*"
                              x:Name="PrefetchStatsRow"
                              ColumnSpacing="12">
                            <Border Grid.Column="0"
                                    BackgroundColor="#0FFFFFFF"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 10"
                                    Padding="12,8">
                                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                    <Label x:Name="CachedPoiCountLabel"
                                           Text="0"
                                           FontSize="20"
                                           FontAttributes="Bold"
                                           TextColor="White"
                                           HorizontalOptions="Center"/>
                                    <Label Text="Địa điểm đã lưu"
                                           FontSize="10"
                                           TextColor="#AADDFF"
                                           HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Column="1"
                                    BackgroundColor="#0FFFFFFF"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 10"
                                    Padding="12,8">
                                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                    <Label x:Name="PendingLogCountLabel"
                                           Text="0"
                                           FontSize="20"
                                           FontAttributes="Bold"
                                           TextColor="White"
                                           HorizontalOptions="Center"/>
                                    <Label Text="Log chờ đồng bộ"
                                           FontSize="10"
                                           TextColor="#AADDFF"
                                           HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- ── SECTION TITLE ── -->
                <Label Text="DANH SÁCH TOUR"
                       FontSize="11"
                       FontAttributes="Bold"
                       TextColor="#999999"
                       CharacterSpacing="2"
                       Margin="20,28,20,12"/>

                <!-- ── TOUR LIST ── -->
                <CollectionView x:Name="TourList"
                                Margin="16,0,16,32"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeShape="RoundRectangle 20"
                                    BackgroundColor="White"
                                    StrokeThickness="1"
                                    Stroke="#F0F0F5"
                                    Margin="0,0,0,14">
                                <Border.Shadow>
                                    <Shadow Brush="#000000" Offset="0,4" Radius="20" Opacity="0.05"/>
                                </Border.Shadow>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnTourTapped" CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>

                                <VerticalStackLayout Padding="16" Spacing="10">

                                    <!-- Tour header -->
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <Border Grid.Column="0"
                                                WidthRequest="44" HeightRequest="44"
                                                BackgroundColor="#EEF4FF"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 14"
                                                Margin="0,0,12,0">
                                            <Label Text="🗺️"
                                                   FontSize="20"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"/>
                                        </Border>

                                        <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                            <Label Text="{Binding Name}"
                                                   FontSize="16"
                                                   FontAttributes="Bold"
                                                   TextColor="#111111"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="1"/>
                                            <Label Text="{Binding Description}"
                                                   FontSize="12"
                                                   TextColor="#888888"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="1"/>
                                        </VerticalStackLayout>

                                        <!-- Expand indicator -->
                                        <Label Grid.Column="2"
                                               Text="{Binding IsExpanded, Converter={StaticResource BoolToExpandIcon}}"
                                               FontSize="18"
                                               TextColor="#AAAAAA"
                                               VerticalOptions="Center"/>
                                    </Grid>

                                    <!-- POI count badge -->
                                    <HorizontalStackLayout Spacing="8">
                                        <Border BackgroundColor="#EEF4FF"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 8"
                                                Padding="8,4">
                                            <Label Text="{Binding Pois.Count, StringFormat='{0} điểm dừng'}"
                                                   FontSize="11"
                                                   FontAttributes="Bold"
                                                   TextColor="#1E88E5"/>
                                        </Border>
                                    </HorizontalStackLayout>

                                    <!-- Expanded POI list -->
                                    <VerticalStackLayout x:Name="PoiListInTour"
                                                         IsVisible="{Binding IsExpanded}"
                                                         Spacing="8">
                                        <BoxView HeightRequest="1" BackgroundColor="#F0F0F5"/>

                                        <CollectionView ItemsSource="{Binding Pois}"
                                                        SelectionMode="None">
                                            <CollectionView.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                                          Padding="4,8"
                                                          ColumnSpacing="10">
                                                        <Border Grid.Column="0"
                                                                WidthRequest="28" HeightRequest="28"
                                                                BackgroundColor="#F0F5FF"
                                                                StrokeThickness="0"
                                                                StrokeShape="RoundRectangle 14">
                                                            <Label Text="{Binding OrderIndex}"
                                                                   FontSize="12"
                                                                   FontAttributes="Bold"
                                                                   TextColor="#1E88E5"
                                                                   HorizontalOptions="Center"
                                                                   VerticalOptions="Center"/>
                                                        </Border>

                                                        <Label Grid.Column="1"
                                                               Text="{Binding Name}"
                                                               FontSize="13"
                                                               TextColor="#333333"
                                                               VerticalOptions="Center"/>

                                                        <Border Grid.Column="2"
                                                                WidthRequest="32" HeightRequest="32"
                                                                BackgroundColor="#EEF4FF"
                                                                StrokeThickness="0"
                                                                StrokeShape="RoundRectangle 16"
                                                                VerticalOptions="Center">
                                                            <Border.GestureRecognizers>
                                                                <TapGestureRecognizer
                                                                    Tapped="GoToMapFromTour"
                                                                    CommandParameter="{Binding PoiId}"/>
                                                            </Border.GestureRecognizers>
                                                            <Label Text="🧭"
                                                                   FontSize="14"
                                                                   HorizontalOptions="Center"
                                                                   VerticalOptions="Center"/>
                                                        </Border>
                                                    </Grid>
                                                </DataTemplate>
                                            </CollectionView.ItemTemplate>
                                        </CollectionView>
                                    </VerticalStackLayout>

                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
