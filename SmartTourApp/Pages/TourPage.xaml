<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="SmartTourApp.Pages.TourPage"
    BackgroundColor="#F2F4F8">

    <Grid RowDefinitions="Auto,*">

        <!-- HEADER -->
        <Grid Padding="20,40,20,20">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1E88E5" Offset="0"/>
                    <GradientStop Color="#42A5F5" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <VerticalStackLayout Spacing="6">
                <Label Text="🧭 Tours"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="White"/>

                <Label Text="Khám phá theo hành trình được thiết kế sẵn"
                       FontSize="14"
                       TextColor="#E3F2FD"/>
            </VerticalStackLayout>
        </Grid>

        <!-- LIST -->
        <CollectionView x:Name="TourList"
                        Grid.Row="1"
                        Margin="16,10"
                        SelectionMode="None">

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <!-- CARD -->
                    <Border StrokeShape="RoundRectangle 24"
                            BackgroundColor="White"
                            Padding="18"
                            Margin="0,0,0,18">

                        <Border.Shadow>
                            <Shadow Brush="#00000020"
                                    Offset="0,6"
                                    Radius="12"/>
                        </Border.Shadow>

                        <VerticalStackLayout Spacing="14">

                            <!-- TITLE -->
                            <Label Text="{Binding Name}"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="#111"/>

                            <!-- DESCRIPTION -->
                            <Label Text="{Binding Description}"
                                   FontSize="13"
                                   TextColor="#666"/>

                            <!-- META -->
                            <Grid ColumnDefinitions="Auto,*"
                                  ColumnSpacing="10">

                                <Border BackgroundColor="#E3F2FD"
                                        StrokeShape="RoundRectangle 12"
                                        Padding="8,4">

                                    <Label Text="{Binding Pois.Count, StringFormat='{}{0} điểm'}"
                                           FontSize="12"
                                           TextColor="#1E88E5"/>
                                </Border>

                                <Label Grid.Column="1"
                                       Text="Tap để xem hành trình"
                                       FontSize="12"
                                       TextColor="#999"
                                       VerticalOptions="Center"/>
                            </Grid>

                            <!-- ACTION -->
                            <Grid ColumnDefinitions="*,Auto">

                                <Button Text="Chi tiết"
                                        Clicked="OpenTour"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#1E88E5"
                                        TextColor="White"
                                        CornerRadius="18"
                                        HeightRequest="40"/>

                                <Button Grid.Column="1"
                                        Text="▶"
                                        Clicked="StartTour"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#4CAF50"
                                        TextColor="White"
                                        WidthRequest="44"
                                        HeightRequest="40"
                                        CornerRadius="18"/>
                            </Grid>

                            <!-- EXPAND -->
                            <VerticalStackLayout
                                IsVisible="{Binding IsExpanded}"
                                Spacing="14">

                                <BoxView HeightRequest="1"
                                         Color="#EEE"/>

                                <!-- TIMELINE -->
                                <CollectionView ItemsSource="{Binding Pois}"
                                                SelectionMode="None">

                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>

                                            <Grid ColumnDefinitions="40,*">

                                                <!-- TIMELINE -->
                                                <Grid RowDefinitions="Auto,*">

                                                    <BoxView HeightRequest="10"
                                                             WidthRequest="10"
                                                             CornerRadius="5"
                                                             Color="#1E88E5"
                                                             HorizontalOptions="Center"/>

                                                    <BoxView Grid.Row="1"
                                                             WidthRequest="2"
                                                             Color="#E0E0E0"
                                                             VerticalOptions="Fill"
                                                             HorizontalOptions="Center"/>
                                                </Grid>

                                                <!-- CONTENT -->
                                                <Border Grid.Column="1"
                                                        BackgroundColor="#FAFBFF"
                                                        StrokeShape="RoundRectangle 16"
                                                        Padding="12"
                                                        Margin="0,0,0,10">

                                                    <VerticalStackLayout Spacing="4">

                                                        <Label Text="{Binding Name}"
                                                               FontSize="14"
                                                               FontAttributes="Bold"
                                                               TextColor="#222"/>

                                                        <Label Text="{Binding OrderIndex, StringFormat='Stop #{0}'}"
                                                               FontSize="11"
                                                               TextColor="#888"/>

                                                    </VerticalStackLayout>
                                                </Border>

                                            </Grid>

                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>

                                </CollectionView>

                                <!-- START BIG BUTTON -->
                                <Button Text="🚀 Bắt đầu hành trình"
                                        Clicked="StartTour"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#111"
                                        TextColor="White"
                                        CornerRadius="22"
                                        HeightRequest="48"/>

                            </VerticalStackLayout>

                        </VerticalStackLayout>

                    </Border>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>
</ContentPage>