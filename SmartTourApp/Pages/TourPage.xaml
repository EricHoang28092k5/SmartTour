<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="SmartTourApp.Pages.TourPage"
    BackgroundColor="#FFFFFF"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">

        <!-- ══════════════════════════════════════ -->
        <!--  HEADER                                -->
        <!-- ══════════════════════════════════════ -->
        <Grid Grid.Row="0" BackgroundColor="White" Padding="20,54,20,20">
            <BoxView VerticalOptions="End"
                     HorizontalOptions="Fill"
                     HeightRequest="1"
                     BackgroundColor="#F0F0F5"/>

            <Grid ColumnDefinitions="*,Auto">

                <VerticalStackLayout Grid.Column="0" Spacing="3">
                    <Label Text="HÀNH TRÌNH"
                           FontSize="11"
                           FontAttributes="Bold"
                           TextColor="#1E88E5"
                           CharacterSpacing="2.5"/>
                    <Label Text="Tours"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="#0D0D0D"
                           CharacterSpacing="-0.5"/>
                </VerticalStackLayout>

                <!-- Tour count badge -->
                <Border Grid.Column="1"
                        BackgroundColor="#F0F5FF"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 20"
                        Padding="14,8"
                        VerticalOptions="Center">
                    <HorizontalStackLayout Spacing="6">
                        <Label x:Name="TourCountLabel"
                               Text="0 tour"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="#1E88E5"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>
            </Grid>
        </Grid>

        <!-- ══════════════════════════════════════ -->
        <!--  TOUR LIST                             -->
        <!-- ══════════════════════════════════════ -->
        <CollectionView x:Name="TourList"
                        Grid.Row="1"
                        Margin="0"
                        SelectionMode="None"
                        BackgroundColor="#F8F9FD">

            <CollectionView.Header>
                <BoxView HeightRequest="12" BackgroundColor="#F8F9FD"/>
            </CollectionView.Header>

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <!-- ─── TOUR CARD ─── -->
                    <Border Margin="16,0,16,16"
                            BackgroundColor="White"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 24">

                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,4" Radius="24" Opacity="0.07"/>
                        </Border.Shadow>

                        <VerticalStackLayout Spacing="0">

                            <!-- ── TOP ACCENT BAR ── -->
                            <BoxView HeightRequest="3"
                                     CornerRadius="24,24,0,0"
                                     BackgroundColor="#1E88E5"/>

                            <!-- ── CARD BODY ── -->
                            <VerticalStackLayout Spacing="0" Padding="20,18,20,18">

                                <!-- ROW 1: icon + title + poi count -->
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14" Margin="0,0,0,10">

                                    <!-- Map icon badge -->
                                    <Border Grid.Column="0"
                                            WidthRequest="46" HeightRequest="46"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 14">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#1565C0" Offset="0"/>
                                                <GradientStop Color="#42A5F5" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Label Text="🗺️"
                                               FontSize="22"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Border>

                                    <!-- Name + stops count -->
                                    <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                        <Label Text="{Binding Name}"
                                               FontSize="17"
                                               FontAttributes="Bold"
                                               TextColor="#0D0D0D"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="1"/>
                                        <HorizontalStackLayout Spacing="6">
                                            <Border BackgroundColor="#EEF4FF"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 8"
                                                    Padding="8,3">
                                                <Label Text="{Binding Pois.Count, StringFormat='{}{0} điểm dừng'}"
                                                       FontSize="11"
                                                       FontAttributes="Bold"
                                                       TextColor="#1E88E5"/>
                                            </Border>
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                </Grid>

                                <!-- Description (nếu có) -->
                                <Label Text="{Binding Description}"
                                       FontSize="13"
                                       TextColor="#777777"
                                       LineHeight="1.5"
                                       Margin="0,0,0,14"
                                       LineBreakMode="WordWrap"
                                       MaxLines="0" />

                                <!-- ── STOPS PREVIEW (pills ngang) ── -->
                                <ScrollView Orientation="Horizontal"
                                            HorizontalScrollBarVisibility="Never"
                                            Margin="0,0,0,16">
                                    <HorizontalStackLayout x:Name="StopsLayout"
                                                           Spacing="6"
                                                           BindableLayout.ItemsSource="{Binding Pois}">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate>
                                                <Border BackgroundColor="#F4F6FF"
                                                        StrokeThickness="1"
                                                        Stroke="#D0DEFF"
                                                        StrokeShape="RoundRectangle 10"
                                                        Padding="10,5">
                                                    <HorizontalStackLayout Spacing="5">
                                                        <Border WidthRequest="18" HeightRequest="18"
                                                                BackgroundColor="#1E88E5"
                                                                StrokeThickness="0"
                                                                StrokeShape="RoundRectangle 9">
                                                            <Label Text="{Binding OrderIndex}"
                                                                   FontSize="10"
                                                                   FontAttributes="Bold"
                                                                   TextColor="White"
                                                                   HorizontalOptions="Center"
                                                                   VerticalOptions="Center"/>
                                                        </Border>
                                                        <Label Text="{Binding Name}"
                                                               FontSize="12"
                                                               TextColor="#334"
                                                               VerticalOptions="Center"
                                                               LineBreakMode="TailTruncation"
                                                               MaxLines="1"/>
                                                    </HorizontalStackLayout>
                                                </Border>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </HorizontalStackLayout>
                                </ScrollView>

                                <!-- ── ACTION ROW ── -->
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">

                                    <!-- Expand / collapse detail -->
                                    <Border Grid.Column="0"
                                            StrokeThickness="1.5"
                                            Stroke="#E0E7FF"
                                            StrokeShape="RoundRectangle 22"
                                            BackgroundColor="#F8F9FF">
                                        <Button x:Name="ExpandBtn"
                                                Text="Chi tiết ↓"
                                                Clicked="OnExpandTapped"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="Transparent"
                                                TextColor="#555577"
                                                FontSize="13"
                                                HeightRequest="44"
                                                Padding="0"/>
                                    </Border>

                                    <!-- Play tour on map -->
                                    <Border Grid.Column="1"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 22"
                                            WidthRequest="120">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#1565C0" Offset="0"/>
                                                <GradientStop Color="#42A5F5" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Button Text="🗺 Xem bản đồ"
                                                Clicked="StartTourOnMap"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="Transparent"
                                                TextColor="White"
                                                FontSize="13"
                                                FontAttributes="Bold"
                                                HeightRequest="44"
                                                Padding="0"/>
                                    </Border>
                                </Grid>

                                <!-- ── EXPANDED DETAIL ── -->
                                <VerticalStackLayout
                                    IsVisible="{Binding IsExpanded}"
                                    Spacing="0"
                                    Margin="0,18,0,0">

                                    <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="10" Margin="0,0,0,14">
                                        <BoxView Grid.Column="0" HeightRequest="1" BackgroundColor="#EEEEEE" VerticalOptions="Center"/>
                                        <Label Grid.Column="1"
                                               Text="LỊCH TRÌNH"
                                               FontSize="10"
                                               FontAttributes="Bold"
                                               TextColor="#BBBBBB"
                                               CharacterSpacing="2"
                                               VerticalOptions="Center"/>
                                        <BoxView Grid.Column="2" HeightRequest="1" BackgroundColor="#EEEEEE" VerticalOptions="Center"/>
                                    </Grid>

                                    <!-- Timeline -->
                                    <CollectionView ItemsSource="{Binding Pois}" SelectionMode="None">
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ColumnDefinitions="32,*" Margin="0,0,0,4">
                                                    <Grid Grid.Column="0" RowDefinitions="Auto,*">
                                                        <Border Grid.Row="0"
                                                                WidthRequest="22" HeightRequest="22"
                                                                BackgroundColor="#1E88E5"
                                                                StrokeThickness="2"
                                                                Stroke="White"
                                                                StrokeShape="RoundRectangle 11"
                                                                HorizontalOptions="Center"
                                                                Margin="0,8,0,0">
                                                            <Label Text="{Binding OrderIndex}"
                                                                   FontSize="11"
                                                                   FontAttributes="Bold"
                                                                   TextColor="White"
                                                                   HorizontalOptions="Center"
                                                                   VerticalOptions="Center"/>
                                                        </Border>
                                                        <BoxView Grid.Row="1"
                                                                 WidthRequest="2"
                                                                 BackgroundColor="#DDDDDD"
                                                                 HorizontalOptions="Center"
                                                                 VerticalOptions="Fill"
                                                                 Margin="0,2,0,0"/>
                                                    </Grid>

                                                    <Border Grid.Column="1"
                                                            BackgroundColor="#F8F9FD"
                                                            StrokeThickness="0"
                                                            StrokeShape="RoundRectangle 14"
                                                            Padding="12,10"
                                                            Margin="0,4,0,6">
                                                        <VerticalStackLayout Spacing="2">
                                                            <Label Text="{Binding Name}"
                                                                   FontSize="13"
                                                                   FontAttributes="Bold"
                                                                   TextColor="#222222"/>
                                                            <Label Text="{Binding OrderIndex, StringFormat='Điểm dừng #{0}'}"
                                                                   FontSize="11"
                                                                   TextColor="#AAAAAA"/>
                                                        </VerticalStackLayout>
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>

                                    <!-- Big CTA inside expanded -->
                                    <Border Margin="0,12,0,0"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 22">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#0D47A1" Offset="0"/>
                                                <GradientStop Color="#1E88E5" Offset="0.6"/>
                                                <GradientStop Color="#42A5F5" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Button Text="🚀  Bắt đầu hành trình trên bản đồ"
                                                Clicked="StartTourOnMap"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="Transparent"
                                                TextColor="White"
                                                FontSize="15"
                                                FontAttributes="Bold"
                                                HeightRequest="52"
                                                Padding="0"/>
                                    </Border>
                                </VerticalStackLayout>

                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.Footer>
                <BoxView HeightRequest="32" BackgroundColor="#F8F9FD"/>
            </CollectionView.Footer>

        </CollectionView>

    </Grid>
</ContentPage>
