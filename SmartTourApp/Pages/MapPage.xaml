<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui"
    x:Class="SmartTourApp.Pages.MapPage"
    Title="Map"
    BackgroundColor="White">

    <Grid>

        <!-- ================= MAP ================= -->
        <mapsui:MapControl
            x:Name="TourMap"
            VerticalOptions="Fill"
            HorizontalOptions="Fill"/>

        <!-- ================= FLOAT BUTTONS ================= -->
        <VerticalStackLayout
            Spacing="12"
            Margin="0,0,16,220"
            HorizontalOptions="End"
            VerticalOptions="End">

            <!-- Locate Me -->
            <Border WidthRequest="52" HeightRequest="52"
                    BackgroundColor="White"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 26">
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.12"/>
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="LocateUser_Clicked"/>
                </Border.GestureRecognizers>
                <Label Text="📍" FontSize="20"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Border>

            <!-- Zoom controls -->
            <Border BackgroundColor="White"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 26">
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.12"/>
                </Border.Shadow>
                <VerticalStackLayout>
                    <Label Text="+"
                           FontSize="24"
                           FontAttributes="Bold"
                           Padding="14,10"
                           TextColor="#333"
                           HorizontalTextAlignment="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="ZoomIn_Clicked"/>
                        </Label.GestureRecognizers>
                    </Label>
                    <BoxView HeightRequest="1" Color="#F0F0F0" Margin="8,0"/>
                    <Label Text="−"
                           FontSize="24"
                           FontAttributes="Bold"
                           Padding="14,10"
                           TextColor="#333"
                           HorizontalTextAlignment="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="ZoomOut_Clicked"/>
                        </Label.GestureRecognizers>
                    </Label>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>

        <!-- =============================================================== -->
        <!--  BOTTOM POI CARD — Yêu cầu 3:                                   -->
        <!--  • Rounded tất cả 4 góc (CornerRadius="20")                     -->
        <!--  • Margin để "nổi" trên bản đồ                                  -->
        <!--  • Tap toàn card → PoiDetailPage                                -->
        <!--  • Các nút con ngăn sự kiện nổi bong bóng lên card              -->
        <!-- =============================================================== -->
        <Border
            x:Name="PoiCard"
            IsVisible="False"
            VerticalOptions="End"
            BackgroundColor="White"
            StrokeThickness="0"
            Margin="16,0,16,24">

            <!-- Yêu cầu 3: Bo đều cả 4 góc, trông như card nổi trên map -->
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20"/>
            </Border.StrokeShape>

            <Border.Shadow>
                <Shadow Brush="#000000" Offset="0,6" Radius="32" Opacity="0.14"/>
            </Border.Shadow>

            <!--
                Yêu cầu 3: TapGestureRecognizer trên toàn Card → mở PoiDetailPage
                Các nút con dùng InputTransparent hoặc e.Handled để chặn bubbling
            -->
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="PoiCard_Tapped"/>
            </Border.GestureRecognizers>

            <VerticalStackLayout Spacing="0" Padding="18,16,18,18">

                <!-- Header Row: Name + Distance + Icon buttons -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,12">

                    <VerticalStackLayout Grid.Column="0" Spacing="3" VerticalOptions="Center">
                        <Label x:Name="NearestPoiLabel"
                               Text=""
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#111111"
                               LineBreakMode="TailTruncation"
                               MaxLines="1"/>
                        <HorizontalStackLayout Spacing="6">
                            <Label Text="📍" FontSize="11" VerticalOptions="Center"/>
                            <Label x:Name="PoiDistanceLabel"
                                   Text=""
                                   FontSize="12"
                                   TextColor="#888888"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <!--
                        Yêu cầu 3: Các nút icon (save, share, close) bên phải.
                        Được bọc trong Grid riêng có GestureRecognizer.
                        Dùng cờ _isActionButtonTapped trong code-behind để chặn
                        sự kiện nổi bong bóng lên PoiCard_Tapped.
                    -->
                    <HorizontalStackLayout Grid.Column="1"
                                           Spacing="10"
                                           VerticalOptions="Start">

                        <!-- Bookmark -->
                        <Border WidthRequest="36" HeightRequest="36"
                                BackgroundColor="#F5F5FA"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 18">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="Save_Clicked"/>
                            </Border.GestureRecognizers>
                            <Image Source="bookmark.png"
                                   WidthRequest="18" HeightRequest="18"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   InputTransparent="True"/>
                        </Border>

                        <!-- Share -->
                        <Border WidthRequest="36" HeightRequest="36"
                                BackgroundColor="#F5F5FA"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 18">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="Share_Clicked"/>
                            </Border.GestureRecognizers>
                            <Image Source="share.png"
                                   WidthRequest="18" HeightRequest="18"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   InputTransparent="True"/>
                        </Border>

                        <!-- Close -->
                        <Border WidthRequest="36" HeightRequest="36"
                                BackgroundColor="#FFF0F0"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 18">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="CloseCard_Clicked"/>
                            </Border.GestureRecognizers>
                            <Image Source="close.png"
                                   WidthRequest="18" HeightRequest="18"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   InputTransparent="True"/>
                        </Border>
                    </HorizontalStackLayout>
                </Grid>

                <!-- Divider -->
                <BoxView HeightRequest="1" BackgroundColor="#F2F2F2" Margin="0,0,0,14"/>

                <!-- Action Buttons Row -->
                <ScrollView Orientation="Horizontal"
                            HorizontalScrollBarVisibility="Never">
                    <HorizontalStackLayout Spacing="10">

                        <!-- Đường đi — bọc trong Border có GestureRecognizer riêng -->
                        <Border Style="{StaticResource ActionBtn}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="Route_Clicked_Action"/>
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="6"
                                                   VerticalOptions="Center"
                                                   InputTransparent="True">
                                <Image Source="route.png" WidthRequest="18" HeightRequest="18"
                                       InputTransparent="True"/>
                                <Label Text="Đường đi" Style="{StaticResource ActionText}"
                                       InputTransparent="True"/>
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Bắt đầu -->
                        <Border Style="{StaticResource ActionBtn}">
                            <HorizontalStackLayout Spacing="6"
                                                   VerticalOptions="Center"
                                                   InputTransparent="True">
                                <Image Source="navigation.png" WidthRequest="18" HeightRequest="18"
                                       VerticalOptions="Center" InputTransparent="True"/>
                                <Label Text="Bắt đầu" Style="{StaticResource ActionText}"
                                       VerticalOptions="Center" InputTransparent="True"/>
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Gọi -->
                        <Border Style="{StaticResource ActionBtn}">
                            <HorizontalStackLayout Spacing="6"
                                                   VerticalOptions="Center"
                                                   InputTransparent="True">
                                <Image Source="call.png" WidthRequest="18" HeightRequest="18"
                                       VerticalOptions="Center" InputTransparent="True"/>
                                <Label Text="Gọi" Style="{StaticResource ActionText}"
                                       VerticalOptions="Center" InputTransparent="True"/>
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Lưu -->
                        <Border Style="{StaticResource ActionBtn}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="Save_Clicked"/>
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="6"
                                                   VerticalOptions="Center"
                                                   InputTransparent="True">
                                <Image Source="bookmark.png" WidthRequest="18" HeightRequest="18"
                                       VerticalOptions="Center" InputTransparent="True"/>
                                <Label Text="Lưu" Style="{StaticResource ActionText}"
                                       VerticalOptions="Center" InputTransparent="True"/>
                            </HorizontalStackLayout>
                        </Border>

                    </HorizontalStackLayout>
                </ScrollView>

                <!-- Route loading indicator -->
                <HorizontalStackLayout x:Name="RouteLoadingRow"
                                       IsVisible="False"
                                       Spacing="8"
                                       Margin="0,12,0,0"
                                       HorizontalOptions="Center">
                    <ActivityIndicator IsRunning="True" Color="#1E88E5" WidthRequest="18" HeightRequest="18"/>
                    <Label Text="Đang tính đường đi..." FontSize="12" TextColor="#888" VerticalOptions="Center"/>
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </Border>

    </Grid>
</ContentPage>
