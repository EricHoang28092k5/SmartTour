<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui"
             x:Class="SmartTourApp.Pages.MapPage"
             Title="Map"
             BackgroundColor="White"
             Shell.NavBarIsVisible="False">

    <Grid>
        <!-- ================= MAP ================= -->
        <mapsui:MapControl x:Name="TourMap"
                           VerticalOptions="Fill"
                           HorizontalOptions="Fill"/>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- TOUR MODE BANNER — hiện khi đang ở tour map mode           -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Border x:Name="TourModeBanner"
            VerticalOptions="Start"
            HorizontalOptions="Fill"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 0,0,20,20"
            Margin="12,50,12,0"  IsVisible="False"
            TranslationY="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#1565C0" Offset="0"/>
                    <GradientStop Color="#1E88E5" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Shadow>
                <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.18"/>
            </Border.Shadow>
            <Grid ColumnDefinitions="Auto,*,Auto" Padding="14,11" ColumnSpacing="10">
                <!-- Tour icon -->
                <Border Grid.Column="0"
                        WidthRequest="30" HeightRequest="30"
                        BackgroundColor="#1EFFFFFF"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 15">
                    <Label Text="🗺️" FontSize="15"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>

                <!-- Tour name -->
                <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                    <Label x:Name="TourBannerLabel"
                           Text="Tour đang hoạt động"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="White"
                           LineBreakMode="TailTruncation"
                           MaxLines="1"/>
                    <Label x:Name="TourBannerSubLabel"
                           Text="Đường đỏ = lộ trình tour"
                           FontSize="11"
                           TextColor="#BBDEFF"/>
                </VerticalStackLayout>

                <!-- Exit tour button -->
                <Border Grid.Column="2"
                        BackgroundColor="#33FFFFFF"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 12"
                        Padding="12,5">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnExitTourTapped"/>
                    </Border.GestureRecognizers>
                    <Label Text="✕ Thoát tour"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="White"/>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- OFFLINE STATUS BANNER — hiện khi mất mạng                  -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Border x:Name="OfflineBanner"
                VerticalOptions="Start"
                HorizontalOptions="Fill"
                BackgroundColor="#CC1A1A2E"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 0,0,16,16"
                Margin="12,44,12,0"
                IsVisible="False"
                TranslationY="-80">
            <Grid ColumnDefinitions="Auto,*,Auto" Padding="14,10" ColumnSpacing="10">
                <Ellipse Grid.Column="0"
                         WidthRequest="8" HeightRequest="8"
                         Fill="#FF6B6B"
                         VerticalOptions="Center"/>
                <Label Grid.Column="1"
                       x:Name="OfflineBannerLabel"
                       Text="Chế độ ngoại tuyến — bản đồ chỉ hiện vùng đã tải"
                       FontSize="12"
                       FontAttributes="Bold"
                       TextColor="White"
                       VerticalOptions="Center"/>
                <Border Grid.Column="2"
                        BackgroundColor="#33FFFFFF"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 10"
                        Padding="10,4">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnOfflineBannerDownloadTap"/>
                    </Border.GestureRecognizers>
                    <Label Text="Tải bản đồ"
                           FontSize="11"
                           FontAttributes="Bold"
                           TextColor="#A0CFFF"/>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- DOWNLOAD PROGRESS OVERLAY                                   -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Border x:Name="DownloadProgressCard"
                VerticalOptions="Start"
                HorizontalOptions="Fill"
                BackgroundColor="White"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 0,0,20,20"
                Margin="12,44,12,0"
                IsVisible="False">
            <Border.Shadow>
                <Shadow Brush="#000000" Offset="0,4" Radius="20" Opacity="0.12"/>
            </Border.Shadow>
            <VerticalStackLayout Padding="16,14" Spacing="10">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                    <ActivityIndicator Grid.Column="0"
                                       x:Name="DownloadSpinner"
                                       IsRunning="True"
                                       Color="#1E88E5"
                                       WidthRequest="20" HeightRequest="20"/>
                    <Label Grid.Column="1"
                           x:Name="DownloadStatusLabel"
                           Text="Đang tải bản đồ..."
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="#111111"
                           VerticalOptions="Center"/>
                    <Border Grid.Column="2"
                            BackgroundColor="#FFF0F0"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 10"
                            Padding="10,4">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCancelDownloadTap"/>
                        </Border.GestureRecognizers>
                        <Label Text="Hủy"
                               FontSize="11"
                               FontAttributes="Bold"
                               TextColor="#E53935"/>
                    </Border>
                </Grid>
                <Grid RowDefinitions="Auto,Auto" RowSpacing="4">
                    <Border Grid.Row="0"
                            HeightRequest="5"
                            BackgroundColor="#EEF4FF"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 3">
                        <Grid HorizontalOptions="Start">
                            <Border x:Name="DownloadProgressFill"
                                    HeightRequest="5"
                                    WidthRequest="0"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 3"
                                    HorizontalOptions="Start">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#1565C0" Offset="0"/>
                                        <GradientStop Color="#42A5F5" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                    </Border>
                    <Grid Grid.Row="1" ColumnDefinitions="*,Auto">
                        <Label x:Name="DownloadProgressLabel"
                               Text="0%"
                               FontSize="11"
                               TextColor="#888888"/>
                        <Label Grid.Column="1"
                               x:Name="DownloadTileCountLabel"
                               Text=""
                               FontSize="11"
                               TextColor="#888888"/>
                    </Grid>
                </Grid>
            </VerticalStackLayout>
        </Border>

        <!-- ================= FLOAT BUTTONS ================= -->
        <VerticalStackLayout Spacing="12"
                             Margin="0,0,16,220"
                             HorizontalOptions="End"
                             VerticalOptions="End">

            <!-- Locate Me -->
            <Border WidthRequest="52" HeightRequest="52"
                    BackgroundColor="White"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 26">
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.12"/>
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="LocateUser_Clicked"/>
                </Border.GestureRecognizers>
                <Label Text="📍" FontSize="20"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Border>

            <!-- Offline Map Download Button -->
            <Border x:Name="DownloadMapBtn"
                    WidthRequest="52" HeightRequest="52"
                    BackgroundColor="White"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 26">
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.12"/>
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnDownloadMapTapped"/>
                </Border.GestureRecognizers>
                <Grid>
                    <Label x:Name="DownloadMapIcon"
                           Text="⬇"
                           FontSize="20"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           TextColor="#1E88E5"/>
                    <Ellipse x:Name="ConnectivityDot"
                             WidthRequest="10" HeightRequest="10"
                             Fill="#4CAF50"
                             HorizontalOptions="End"
                             VerticalOptions="Start"
                             Margin="0,8,8,0"/>
                </Grid>
            </Border>

            <!-- Zoom controls -->
            <Border BackgroundColor="White"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 26">
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.12"/>
                </Border.Shadow>
                <VerticalStackLayout>
                    <Label Text="+" FontSize="24" FontAttributes="Bold"
                           Padding="14,10" TextColor="#333"
                           HorizontalTextAlignment="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="ZoomIn_Clicked"/>
                        </Label.GestureRecognizers>
                    </Label>
                    <BoxView HeightRequest="1" Color="#F0F0F0" Margin="8,0"/>
                    <Label Text="−" FontSize="24" FontAttributes="Bold"
                           Padding="14,10" TextColor="#333"
                           HorizontalTextAlignment="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="ZoomOut_Clicked"/>
                        </Label.GestureRecognizers>
                    </Label>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>

        <!-- =============================================================== -->
        <!-- BOTTOM POI CARD                                                 -->
        <!-- =============================================================== -->
        <Border x:Name="PoiCard"
                IsVisible="False"
                VerticalOptions="End"
                BackgroundColor="White"
                StrokeThickness="0"
                Margin="16,0,16,24">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#000000" Offset="0,6" Radius="32" Opacity="0.14"/>
            </Border.Shadow>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="PoiCard_Tapped"/>
            </Border.GestureRecognizers>
            <VerticalStackLayout Spacing="0" Padding="18,16,18,18">

                <!-- Tour step indicator (chỉ hiện trong tour mode) -->
                <Border x:Name="TourStepIndicator"
                        IsVisible="False"
                        BackgroundColor="#EEF4FF"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 10"
                        Padding="10,5"
                        HorizontalOptions="Start"
                        Margin="0,0,0,10">
                    <HorizontalStackLayout Spacing="6">
                        <Border x:Name="TourStepBadge"
                                WidthRequest="22" HeightRequest="22"
                                BackgroundColor="#DC2626"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 11">
                            <Label x:Name="TourStepNumber"
                                   Text="1"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                        <Label x:Name="TourStepLabel"
                               Text="Điểm 1 trong tour"
                               FontSize="12"
                               FontAttributes="Bold"
                               TextColor="#1E88E5"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>

                <!-- Header Row: Name + Distance + Icon buttons -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                    <VerticalStackLayout Grid.Column="0" Spacing="3" VerticalOptions="Center">
                        <Label x:Name="NearestPoiLabel"
                               Text=""
                               FontSize="18" FontAttributes="Bold"
                               TextColor="#111111"
                               LineBreakMode="TailTruncation" MaxLines="1"/>
                        <HorizontalStackLayout Spacing="6">
                            <Label Text="📍" FontSize="11" VerticalOptions="Center"/>
                            <Label x:Name="PoiDistanceLabel"
                                   Text="" FontSize="12" TextColor="#888888"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                    <HorizontalStackLayout Grid.Column="1" Spacing="10" VerticalOptions="Start">
                        <!-- Bookmark -->
                        <Border WidthRequest="36" HeightRequest="36"
                                BackgroundColor="#F5F5FA" StrokeThickness="0"
                                StrokeShape="RoundRectangle 18">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="Save_Clicked"/>
                            </Border.GestureRecognizers>
                            <Image Source="bookmark.png" WidthRequest="18" HeightRequest="18"
                                   HorizontalOptions="Center" VerticalOptions="Center"
                                   InputTransparent="True"/>
                        </Border>
                        <!-- Share -->
                        <Border WidthRequest="36" HeightRequest="36"
                                BackgroundColor="#F5F5FA" StrokeThickness="0"
                                StrokeShape="RoundRectangle 18">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="Share_Clicked"/>
                            </Border.GestureRecognizers>
                            <Image Source="share.png" WidthRequest="18" HeightRequest="18"
                                   HorizontalOptions="Center" VerticalOptions="Center"
                                   InputTransparent="True"/>
                        </Border>
                        <!-- Close -->
                        <Border WidthRequest="36" HeightRequest="36"
                                BackgroundColor="#FFF0F0" StrokeThickness="0"
                                StrokeShape="RoundRectangle 18">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="CloseCard_Clicked"/>
                            </Border.GestureRecognizers>
                            <Image Source="close.png" WidthRequest="18" HeightRequest="18"
                                   HorizontalOptions="Center" VerticalOptions="Center"
                                   InputTransparent="True"/>
                        </Border>
                    </HorizontalStackLayout>
                </Grid>

                <!-- Divider -->
                <BoxView HeightRequest="1" BackgroundColor="#F2F2F2" Margin="0,0,0,14"/>

                <!-- Action Buttons Row -->
                <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                    <HorizontalStackLayout Spacing="10">
                        <!-- Đường đi -->
                        <Border Style="{StaticResource ActionBtn}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="Route_Clicked_Action"/>
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="6" VerticalOptions="Center"
                                                   InputTransparent="True">
                                <Image Source="route.png" WidthRequest="18" HeightRequest="18"
                                       InputTransparent="True"/>
                                <Label Text="Đường đi"
                                       Style="{StaticResource ActionText}"
                                       InputTransparent="True"/>
                            </HorizontalStackLayout>
                        </Border>
                        <!-- Bắt đầu -->
                        <Border Style="{StaticResource ActionBtn}">
                            <HorizontalStackLayout Spacing="6" VerticalOptions="Center"
                                                   InputTransparent="True">
                                <Image Source="navigation.png" WidthRequest="18" HeightRequest="18"
                                       VerticalOptions="Center" InputTransparent="True"/>
                                <Label Text="Bắt đầu"
                                       Style="{StaticResource ActionText}"
                                       VerticalOptions="Center" InputTransparent="True"/>
                            </HorizontalStackLayout>
                        </Border>
                        <!-- Gọi -->
                        <Border Style="{StaticResource ActionBtn}">
                            <HorizontalStackLayout Spacing="6" VerticalOptions="Center"
                                                   InputTransparent="True">
                                <Image Source="call.png" WidthRequest="18" HeightRequest="18"
                                       VerticalOptions="Center" InputTransparent="True"/>
                                <Label Text="Gọi"
                                       Style="{StaticResource ActionText}"
                                       VerticalOptions="Center" InputTransparent="True"/>
                            </HorizontalStackLayout>
                        </Border>
                        <!-- Lưu -->
                        <Border Style="{StaticResource ActionBtn}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="Save_Clicked"/>
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="6" VerticalOptions="Center"
                                                   InputTransparent="True">
                                <Image Source="bookmark.png" WidthRequest="18" HeightRequest="18"
                                       VerticalOptions="Center" InputTransparent="True"/>
                                <Label Text="Lưu"
                                       Style="{StaticResource ActionText}"
                                       VerticalOptions="Center" InputTransparent="True"/>
                            </HorizontalStackLayout>
                        </Border>
                    </HorizontalStackLayout>
                </ScrollView>

                <!-- Route loading indicator -->
                <HorizontalStackLayout x:Name="RouteLoadingRow"
                                       IsVisible="False" Spacing="8"
                                       Margin="0,12,0,0"
                                       HorizontalOptions="Center">
                    <ActivityIndicator IsRunning="True" Color="#1E88E5"
                                       WidthRequest="18" HeightRequest="18"/>
                    <Label Text="Đang tính đường đi..."
                           FontSize="12" TextColor="#888"
                           VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
