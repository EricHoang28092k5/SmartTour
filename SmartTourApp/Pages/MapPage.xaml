<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui"
             x:Class="SmartTourApp.Pages.MapPage"
             Title="Map"
             BackgroundColor="White"
             Shell.NavBarIsVisible="False">

    <Grid>
        <!-- ================= MAP ================= -->
        <mapsui:MapControl x:Name="TourMap"
                           VerticalOptions="Fill"
                           HorizontalOptions="Fill"/>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- OFFLINE STATUS BANNER — hiện khi mất mạng                  -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Border x:Name="OfflineBanner"
                VerticalOptions="Start"
                HorizontalOptions="Fill"
                BackgroundColor="#CC1A1A2E"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 0,0,16,16"
                Margin="12,44,12,0"
                IsVisible="False"
                TranslationY="-80">
            <Grid ColumnDefinitions="Auto,*,Auto" Padding="14,10" ColumnSpacing="10">
                <Ellipse Grid.Column="0"
                         WidthRequest="8" HeightRequest="8"
                         Fill="#FF6B6B"
                         VerticalOptions="Center"/>
                <Label Grid.Column="1"
                       x:Name="OfflineBannerLabel"
                       Text="Chế độ ngoại tuyến — bản đồ chỉ hiện vùng đã tải"
                       FontSize="12"
                       FontAttributes="Bold"
                       TextColor="White"
                       VerticalOptions="Center"/>
                <Border Grid.Column="2"
                        BackgroundColor="#33FFFFFF"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 10"
                        Padding="10,4">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnOfflineBannerDownloadTap"/>
                    </Border.GestureRecognizers>
                    <Label x:Name="OfflineBannerDownloadLabel"
                           Text="Tải bản đồ"
                           FontSize="11"
                           FontAttributes="Bold"
                           TextColor="#A0CFFF"/>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- DOWNLOAD PROGRESS OVERLAY                                   -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Border x:Name="DownloadProgressCard"
                VerticalOptions="Start"
                HorizontalOptions="Fill"
                BackgroundColor="White"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 0,0,20,20"
                Margin="12,44,12,0"
                IsVisible="False">
            <Border.Shadow>
                <Shadow Brush="#000000" Offset="0,4" Radius="20" Opacity="0.12"/>
            </Border.Shadow>
            <VerticalStackLayout Padding="16,14" Spacing="10">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                    <ActivityIndicator Grid.Column="0"
                                       x:Name="DownloadSpinner"
                                       IsRunning="True"
                                       Color="#1E88E5"
                                       WidthRequest="20" HeightRequest="20"/>
                    <Label Grid.Column="1"
                           x:Name="DownloadStatusLabel"
                           Text="Đang tải bản đồ..."
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="#111111"
                           VerticalOptions="Center"/>
                    <Border Grid.Column="2"
                            BackgroundColor="#FFF0F0"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 10"
                            Padding="10,4">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCancelDownloadTap"/>
                        </Border.GestureRecognizers>
                        <Label x:Name="DownloadCancelLabel"
                               Text="Hủy"
                               FontSize="11"
                               FontAttributes="Bold"
                               TextColor="#E53935"/>
                    </Border>
                </Grid>
                <Grid RowDefinitions="Auto,Auto" RowSpacing="4">
                    <Border Grid.Row="0"
                            HeightRequest="5"
                            BackgroundColor="#EEF4FF"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 3">
                        <Grid HorizontalOptions="Start">
                            <Border x:Name="DownloadProgressFill"
                                    HeightRequest="5"
                                    WidthRequest="0"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 3"
                                    HorizontalOptions="Start">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#1565C0" Offset="0"/>
                                        <GradientStop Color="#42A5F5" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                    </Border>
                    <Grid Grid.Row="1" ColumnDefinitions="*,Auto">
                        <Label x:Name="DownloadProgressLabel"
                               Text="0%"
                               FontSize="11"
                               TextColor="#888888"/>
                        <Label Grid.Column="1"
                               x:Name="DownloadTileCountLabel"
                               Text=""
                               FontSize="11"
                               TextColor="#888888"/>
                    </Grid>
                </Grid>
            </VerticalStackLayout>
        </Border>

        <!-- ================= FLOAT BUTTONS ================= -->
        <VerticalStackLayout Spacing="12"
                             Margin="0,0,16,220"
                             HorizontalOptions="End"
                             VerticalOptions="End">

            <!-- Locate Me -->
            <Border WidthRequest="52" HeightRequest="52"
                    BackgroundColor="White"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 26">
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.12"/>
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="LocateUser_Clicked"/>
                </Border.GestureRecognizers>
                <Label Text="📍" FontSize="20"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Border>

            <!-- Offline Map Download Button -->
            <Border x:Name="DownloadMapBtn"
                    WidthRequest="52" HeightRequest="52"
                    BackgroundColor="White"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 26">
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.12"/>
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnDownloadMapTapped"/>
                </Border.GestureRecognizers>
                <Grid>
                    <Label x:Name="DownloadMapIcon"
                           Text="⬇"
                           FontSize="20"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           TextColor="#1E88E5"/>
                    <Ellipse x:Name="ConnectivityDot"
                             WidthRequest="10" HeightRequest="10"
                             Fill="#4CAF50"
                             HorizontalOptions="End"
                             VerticalOptions="Start"
                             Margin="0,8,8,0"/>
                </Grid>
            </Border>

            <!-- Zoom controls -->
            <Border BackgroundColor="White"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 26">
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.12"/>
                </Border.Shadow>
                <VerticalStackLayout>
                    <Label Text="+" FontSize="24" FontAttributes="Bold"
                           Padding="14,10" TextColor="#333"
                           HorizontalTextAlignment="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="ZoomIn_Clicked"/>
                        </Label.GestureRecognizers>
                    </Label>
                    <BoxView HeightRequest="1" Color="#F0F0F0" Margin="8,0"/>
                    <Label Text="−" FontSize="24" FontAttributes="Bold"
                           Padding="14,10" TextColor="#333"
                           HorizontalTextAlignment="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="ZoomOut_Clicked"/>
                        </Label.GestureRecognizers>
                    </Label>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>

        <!-- =============================================================== -->
        <!-- BOTTOM POI CARD                                                 -->
        <!-- =============================================================== -->
        <Border x:Name="PoiCard"
                IsVisible="False"
                VerticalOptions="End"
                BackgroundColor="White"
                StrokeThickness="0"
                Margin="16,0,16,24">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#000000" Offset="0,6" Radius="32" Opacity="0.14"/>
            </Border.Shadow>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="PoiCard_Tapped"/>
            </Border.GestureRecognizers>
            <VerticalStackLayout Spacing="0" Padding="18,16,18,18">

                <!-- Header Row: Name + Distance + Icon buttons -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                    <VerticalStackLayout Grid.Column="0" Spacing="3" VerticalOptions="Center">
                        <!-- YC3: DisplayName label — sẽ được cập nhật theo ngôn ngữ -->
                        <Label x:Name="NearestPoiLabel"
                               Text=""
                               FontSize="18" FontAttributes="Bold"
                               TextColor="#111111"
                               LineBreakMode="TailTruncation" MaxLines="1"/>
                        <HorizontalStackLayout Spacing="6">
                            <Label Text="📍" FontSize="11" VerticalOptions="Center"/>
                            <Label x:Name="PoiDistanceLabel"
                                   Text="" FontSize="12" TextColor="#888888"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                    <HorizontalStackLayout Grid.Column="1" Spacing="10" VerticalOptions="Start">
                        <!-- Close -->
                        <Border WidthRequest="36" HeightRequest="36"
                                BackgroundColor="#FFF0F0" StrokeThickness="0"
                                StrokeShape="RoundRectangle 18">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="CloseCard_Clicked"/>
                            </Border.GestureRecognizers>
                            <Image Source="close.png" WidthRequest="18" HeightRequest="18"
                                   HorizontalOptions="Center" VerticalOptions="Center"
                                   InputTransparent="True"/>
                        </Border>
                    </HorizontalStackLayout>
                </Grid>

                <!-- Divider -->
                <BoxView HeightRequest="1" BackgroundColor="#F2F2F2" Margin="0,0,0,14"/>

                <!-- YC2: Nút "Chỉ đường" → Mở Google Maps navigation -->
                <!-- YC3: Label đồng bộ ngôn ngữ qua LblDirectionsBtn -->
                <Border x:Name="DirectionsBtnContainer"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 16"
                        HeightRequest="48">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1565C0" Offset="0"/>
                            <GradientStop Color="#1E88E5" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="#1565C0" Offset="0,4" Radius="12" Opacity="0.3"/>
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <!-- YC2: Handler mở Google Maps navigation -->
                        <TapGestureRecognizer Tapped="OnOpenGoogleMapsTapped"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="8"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           InputTransparent="True">
                        <Label Text="🗺️"
                               FontSize="16"
                               VerticalOptions="Center"
                               InputTransparent="True"/>
                        <!-- YC3: Text thay đổi theo ngôn ngữ được chọn ở Settings -->
                        <Label x:Name="LblDirectionsBtn"
                               Text="Chỉ đường"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="White"
                               VerticalOptions="Center"
                               InputTransparent="True"/>
                    </HorizontalStackLayout>
                </Border>

                <!-- Route loading indicator (kept for compatibility) -->
                <HorizontalStackLayout x:Name="RouteLoadingRow"
                                       IsVisible="False" Spacing="8"
                                       Margin="0,12,0,0"
                                       HorizontalOptions="Center">
                    <ActivityIndicator IsRunning="True" Color="#1E88E5"
                                       WidthRequest="18" HeightRequest="18"/>
                    <Label x:Name="RouteLoadingLabel"
                           Text="Đang tính đường đi..."
                           FontSize="12" TextColor="#888"
                           VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
