<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui"
    x:Class="SmartTourApp.Pages.MapPage"
    Title="Map"
    BackgroundColor="White">

    <Grid>

        <!-- ================= MAP ================= -->
        <mapsui:MapControl
            x:Name="TourMap"
            VerticalOptions="Fill"
            HorizontalOptions="Fill"/>


        <!-- =============== FLOATING BUTTONS =============== -->
        <VerticalStackLayout
            Spacing="14"
            Margin="0,0,18,160"
            HorizontalOptions="End"
            VerticalOptions="End">

            <!-- USER LOCATION BUTTON -->
            <Border
                WidthRequest="58"
                HeightRequest="58"
                BackgroundColor="White"
                Shadow="0,6,18,#33000000">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="29"/>
                </Border.StrokeShape>

                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="LocateUser_Clicked"/>
                </Border.GestureRecognizers>

                <Label
                    Text="📍"
                    FontSize="24"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"/>

            </Border>


            <!-- ZOOM BUTTON GROUP -->
            <Border
                WidthRequest="58"
                BackgroundColor="White"
                Shadow="0,6,18,#33000000">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="29"/>
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="0">

                    <!-- ZOOM IN -->
                    <Label
                        Text="+"
                        FontSize="28"
                        Padding="16"
                        HorizontalTextAlignment="Center">

                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="ZoomIn_Clicked"/>
                        </Label.GestureRecognizers>

                    </Label>

                    <BoxView
                        HeightRequest="1"
                        Color="#EEEEEE"/>

                    <!-- ZOOM OUT -->
                    <Label
                        Text="-"
                        FontSize="28"
                        Padding="16"
                        HorizontalTextAlignment="Center">

                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="ZoomOut_Clicked"/>
                        </Label.GestureRecognizers>

                    </Label>

                </VerticalStackLayout>

            </Border>

        </VerticalStackLayout>


        <!-- ================= BOTTOM POI CARD ================= -->
        <Border
            Margin="16,0,16,22"
            Padding="18"
            BackgroundColor="White"
            VerticalOptions="End"
            Shadow="0,-6,24,#22000000">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="26"/>
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="10">

                <!-- DRAG HANDLE -->
                <BoxView
                    HeightRequest="4"
                    WidthRequest="42"
                    HorizontalOptions="Center"
                    CornerRadius="2"
                    Color="#DDDDDD"/>

                <Label
                    Text="POI gần nhất"
                    FontSize="13"
                    TextColor="#777"
                    HorizontalOptions="Center"/>

                <Label
                    x:Name="NearestPoiLabel"
                    Text="Đang tìm POI..."
                    FontSize="22"
                    FontAttributes="Bold"
                    TextColor="Black"
                    HorizontalOptions="Center"/>

            </VerticalStackLayout>

        </Border>

    </Grid>

</ContentPage>