<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui"
    x:Class="SmartTourApp.Pages.MapPage"
    Title="Map"
    BackgroundColor="White">

    <Grid>

        <!-- ================= MAP ================= -->
        <mapsui:MapControl
            x:Name="TourMap"
            VerticalOptions="Fill"
            HorizontalOptions="Fill"/>


        <!-- ================= FLOAT BUTTONS ================= -->
        <VerticalStackLayout
            Spacing="14"
            Margin="0,0,18,160"
            HorizontalOptions="End"
            VerticalOptions="End">

            <Border WidthRequest="56" HeightRequest="56"
                    BackgroundColor="White"
                    Shadow="0,6,18,#33000000">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="28"/>
                </Border.StrokeShape>

                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="LocateUser_Clicked"/>
                </Border.GestureRecognizers>

                <Label Text="📍" FontSize="22"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Border>

            <Border WidthRequest="56"
                    BackgroundColor="White"
                    Shadow="0,6,18,#33000000">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="28"/>
                </Border.StrokeShape>

                <VerticalStackLayout>

                    <Label Text="+"
                           FontSize="26"
                           Padding="14"
                           HorizontalTextAlignment="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="ZoomIn_Clicked"/>
                        </Label.GestureRecognizers>
                    </Label>

                    <BoxView HeightRequest="1" Color="#EEE"/>

                    <Label Text="-"
                           FontSize="26"
                           Padding="14"
                           HorizontalTextAlignment="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="ZoomOut_Clicked"/>
                        </Label.GestureRecognizers>
                    </Label>

                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>


        <!-- ================= 🔥 NEW BOTTOM CARD ================= -->
        <Border
    x:Name="PoiCard"
    IsVisible="False"
    VerticalOptions="End"
    Padding="18,14,18,18"
    BackgroundColor="White"
    Shadow="0,-6,24,#22000000"
    Margin="0">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="26,26,0,0"/>
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="10">

                <!-- HANDLE -->
                <BoxView HeightRequest="4"
                 WidthRequest="42"
                 HorizontalOptions="Center"
                 CornerRadius="2"
                 Color="#DDDDDD"/>

                <!-- 🔥 HEADER FIX CHUẨN -->
                <Grid ColumnDefinitions="*,Auto"
              VerticalOptions="Start">

                    <!-- TEXT (FIX TRÀN) -->
                    <Label
                x:Name="NearestPoiLabel"
                Text=""
                FontSize="22"
                FontAttributes="Bold"
                TextColor="Black"
                LineBreakMode="TailTruncation"
                MaxLines="1"
                VerticalOptions="Center"/>

                    <!-- 🔥 ICON GÓC PHẢI -->
                    <HorizontalStackLayout
                Grid.Column="1"
                Spacing="12"
                VerticalOptions="Start"
                HorizontalOptions="End">

                        <!-- Bookmark -->
                        <Image Source="bookmark.png"
                                WidthRequest="20"
                                HeightRequest="20">
                            <Image.GestureRecognizers>
                                <TapGestureRecognizer Tapped="Save_Clicked"/>
                            </Image.GestureRecognizers>
                        </Image>
                        <Image Source="share.png"
                                WidthRequest="20"
                                HeightRequest="20">     
                            <Image.GestureRecognizers>
                                <TapGestureRecognizer Tapped="Save_Clicked"/>
                            </Image.GestureRecognizers>
                        </Image>
                        <Image Source="close.png"
                                WidthRequest="20"
                                HeightRequest="20">
                            <Image.GestureRecognizers>
                                <TapGestureRecognizer Tapped="Save_Clicked"/>
                            </Image.GestureRecognizers>
                        </Image>

                    </HorizontalStackLayout>

                </Grid>

                <!-- ACTION BAR -->
                <ScrollView
            Orientation="Horizontal"
            HorizontalScrollBarVisibility="Never">
                    <!-- 🔥 ẨN THANH XÁM -->

                    <HorizontalStackLayout Spacing="12">

                        <Border Style="{StaticResource ActionBtn}">
                            <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                <Image
                                    Source="route.png"
                                    WidthRequest="18"
                                    HeightRequest="18"
                                    VerticalOptions="Center"/>
                                <Label
                                    Text="Đường đi"
                                    Style="{StaticResource ActionText}"
                                    VerticalOptions="Center"/>

                            </HorizontalStackLayout>
                        </Border>

                        <Border Style="{StaticResource ActionBtn}">
                            <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                <Image
                                    Source="navigation.png"
                                    WidthRequest="18"
                                    HeightRequest="18"
                                    VerticalOptions="Center"/>
                                <Label
                                    Text="Bắt đầu"
                                    Style="{StaticResource ActionText}"
                                    VerticalOptions="Center"/>

                            </HorizontalStackLayout>
                        </Border>

                        <Border Style="{StaticResource ActionBtn}">
                            <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                <Image
                                    Source="call.png"
                                    WidthRequest="18"
                                    HeightRequest="18"
                                    VerticalOptions="Center"/>
                                <Label
                                    Text="Gọi"
                                    Style="{StaticResource ActionText}"
                                    VerticalOptions="Center"/>

                            </HorizontalStackLayout>
                        </Border>

                        <Border Style="{StaticResource ActionBtn}">
                            <HorizontalStackLayout Spacing="6" VerticalOptions="Center">

                                <Image
                                    Source="bookmark.png"
                                    WidthRequest="18"
                                    HeightRequest="18"
                                    VerticalOptions="Center"/>

                                                        <Label
                                    Text="Lưu"
                                    Style="{StaticResource ActionText}"
                                    VerticalOptions="Center"/>

                            </HorizontalStackLayout>
                        </Border>

                    </HorizontalStackLayout>

                </ScrollView>

            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>