<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui"
    x:Class="SmartTourApp.Pages.MapPage"
    Title="Map"
    BackgroundColor="White">

    <Grid>

        <!-- ================= MAP ================= -->
        <mapsui:MapControl
            x:Name="TourMap"
            VerticalOptions="Fill"
            HorizontalOptions="Fill"/>

        <!-- ================= FLOAT BUTTONS ================= -->
        <VerticalStackLayout
            Spacing="12"
            Margin="0,0,16,180"
            HorizontalOptions="End"
            VerticalOptions="End">

            <!-- Locate Me -->
            <Border WidthRequest="52" HeightRequest="52"
                    BackgroundColor="White"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 26">
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.12"/>
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="LocateUser_Clicked"/>
                </Border.GestureRecognizers>
                <Label Text="📍" FontSize="20"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Border>

            <!-- Zoom controls -->
            <Border BackgroundColor="White"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 26">
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.12"/>
                </Border.Shadow>
                <VerticalStackLayout>
                    <Label Text="+"
                           FontSize="24"
                           FontAttributes="Bold"
                           Padding="14,10"
                           TextColor="#333"
                           HorizontalTextAlignment="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="ZoomIn_Clicked"/>
                        </Label.GestureRecognizers>
                    </Label>
                    <BoxView HeightRequest="1" Color="#F0F0F0" Margin="8,0"/>
                    <Label Text="−"
                           FontSize="24"
                           FontAttributes="Bold"
                           Padding="14,10"
                           TextColor="#333"
                           HorizontalTextAlignment="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="ZoomOut_Clicked"/>
                        </Label.GestureRecognizers>
                    </Label>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>

        <!-- ================= BOTTOM POI CARD ================= -->
        <Border
            x:Name="PoiCard"
            IsVisible="False"
            VerticalOptions="End"
            BackgroundColor="White"
            StrokeThickness="0"
            Margin="0">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="28,28,0,0"/>
            </Border.StrokeShape>

            <Border.Shadow>
                <Shadow Brush="#000000" Offset="0,-6" Radius="28" Opacity="0.10"/>
            </Border.Shadow>

            <VerticalStackLayout Spacing="0" Padding="20,14,20,20">

                <!-- Handle -->
                <BoxView HeightRequest="4" WidthRequest="38"
                         HorizontalOptions="Center"
                         CornerRadius="2"
                         BackgroundColor="#E0E0E0"
                         Margin="0,0,0,14"/>

                <!-- Header Row: Name + Icons -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,14">

                    <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                        <Label x:Name="NearestPoiLabel"
                               Text=""
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="#111111"
                               LineBreakMode="TailTruncation"
                               MaxLines="1"/>
                        <Label x:Name="PoiDistanceLabel"
                               Text=""
                               FontSize="12"
                               TextColor="#888888"/>
                    </VerticalStackLayout>

                    <!-- Right icons -->
                    <HorizontalStackLayout Grid.Column="1" Spacing="14" VerticalOptions="Start">
                        <Image Source="bookmark.png" WidthRequest="22" HeightRequest="22">
                            <Image.GestureRecognizers>
                                <TapGestureRecognizer Tapped="Save_Clicked"/>
                            </Image.GestureRecognizers>
                        </Image>
                        <Image Source="share.png" WidthRequest="22" HeightRequest="22">
                            <Image.GestureRecognizers>
                                <TapGestureRecognizer Tapped="Share_Clicked"/>
                            </Image.GestureRecognizers>
                        </Image>
                        <!-- CLOSE BUTTON -->
                        <Image Source="close.png" WidthRequest="22" HeightRequest="22">
                            <Image.GestureRecognizers>
                                <TapGestureRecognizer Tapped="CloseCard_Clicked"/>
                            </Image.GestureRecognizers>
                        </Image>
                    </HorizontalStackLayout>
                </Grid>

                <!-- Divider -->
                <BoxView HeightRequest="1" BackgroundColor="#F2F2F2" Margin="0,0,0,14"/>

                <!-- Action Buttons Row -->
                <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                    <HorizontalStackLayout Spacing="10">

                        <!-- Đường đi -->
                        <Border Style="{StaticResource ActionBtn}">
                            <Grid>
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="Route_Clicked"/>
                                </Grid.GestureRecognizers>
                                <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                    <Image Source="route.png" WidthRequest="18" HeightRequest="18"/>
                                    <Label Text="Đường đi" Style="{StaticResource ActionText}"/>
                                </HorizontalStackLayout>
                            </Grid>
                        </Border>

                        <!-- Bắt đầu -->
                        <Border Style="{StaticResource ActionBtn}">
                            <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                <Image Source="navigation.png" WidthRequest="18" HeightRequest="18" VerticalOptions="Center"/>
                                <Label Text="Bắt đầu" Style="{StaticResource ActionText}" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Gọi -->
                        <Border Style="{StaticResource ActionBtn}">
                            <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                <Image Source="call.png" WidthRequest="18" HeightRequest="18" VerticalOptions="Center"/>
                                <Label Text="Gọi" Style="{StaticResource ActionText}" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Lưu -->
                        <Border Style="{StaticResource ActionBtn}">
                            <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                <Image Source="bookmark.png" WidthRequest="18" HeightRequest="18" VerticalOptions="Center"/>
                                <Label Text="Lưu" Style="{StaticResource ActionText}" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>

                    </HorizontalStackLayout>
                </ScrollView>

                <!-- Route loading indicator -->
                <HorizontalStackLayout x:Name="RouteLoadingRow"
                                       IsVisible="False"
                                       Spacing="8"
                                       Margin="0,12,0,0"
                                       HorizontalOptions="Center">
                    <ActivityIndicator IsRunning="True" Color="#1E88E5" WidthRequest="18" HeightRequest="18"/>
                    <Label Text="Đang tính đường đi..." FontSize="12" TextColor="#888" VerticalOptions="Center"/>
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </Border>

    </Grid>
</ContentPage>
