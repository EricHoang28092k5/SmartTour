<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui"
             x:Class="SmartTourApp.Pages.MapPage"
             Title="Map"
             BackgroundColor="White">

    <Grid>

        <!-- MAP -->
        <mapsui:MapControl x:Name="TourMap"/>

        <!-- FLOAT BUTTONS -->
        <VerticalStackLayout Spacing="14"
                             Margin="0,0,18,200"
                             HorizontalOptions="End"
                             VerticalOptions="End">

            <Border WidthRequest="58" HeightRequest="58" BackgroundColor="White">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="29"/>
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="LocateUser_Clicked"/>
                </Border.GestureRecognizers>
                <Label Text="📍" FontSize="24"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Border>

            <Border WidthRequest="58" BackgroundColor="White">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="29"/>
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="0">
                    <Label Text="+" FontSize="28" Padding="16">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="ZoomIn_Clicked"/>
                        </Label.GestureRecognizers>
                    </Label>

                    <BoxView HeightRequest="1" Color="#EEE"/>

                    <Label Text="-" FontSize="28" Padding="16">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="ZoomOut_Clicked"/>
                        </Label.GestureRecognizers>
                    </Label>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>

        <!-- BOTTOM SHEET -->
        <Border x:Name="BottomSheet"
                BackgroundColor="White"
                VerticalOptions="End"
                HeightRequest="120"
                TranslationY="400"
                Shadow="0,-8,30,#22000000">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="28"/>
            </Border.StrokeShape>

            <Border.GestureRecognizers>
                <PanGestureRecognizer PanUpdated="OnPanUpdated"/>
            </Border.GestureRecognizers>

            <Grid RowDefinitions="Auto,Auto,Auto,*" Padding="16">

                <!-- HANDLE -->
                <BoxView HeightRequest="5"
                         WidthRequest="50"
                         CornerRadius="3"
                         Color="#DDD"
                         HorizontalOptions="Center"/>

                <!-- TITLE -->
                <VerticalStackLayout Grid.Row="1" Spacing="4">
                    <Label Text="POI gần nhất"
                           FontSize="13"
                           TextColor="#777"
                           HorizontalOptions="Center"/>

                    <Label x:Name="NearestPoiLabel"
                           Text="Đang tìm POI..."
                           FontSize="22"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <!-- IMAGE -->
                <Image x:Name="PoiImage"
                       Grid.Row="2"
                       HeightRequest="150"
                       Aspect="AspectFill"
                       Margin="0,12,0,0"
                       IsVisible="False"/>

                <!-- DETAILS -->
                <ScrollView x:Name="DetailSection"
                            Grid.Row="3"
                            IsVisible="False">

                    <VerticalStackLayout Spacing="10" Margin="0,10,0,0">

                        <Label x:Name="PoiDescription"
                               FontSize="14"
                               TextColor="#555"/>

                        <Button Text="▶ Nghe thuyết minh"
                                Clicked="PlayAudio_Clicked"/>

                    </VerticalStackLayout>
                </ScrollView>

            </Grid>
        </Border>

    </Grid>
</ContentPage>