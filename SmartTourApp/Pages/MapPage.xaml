<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui"
    x:Class="SmartTourApp.Pages.MapPage">

    <Grid>

        <mapsui:MapControl
            x:Name="TourMap"/>

        <Border
            BackgroundColor="#CCFFFFFF"
            Margin="15"
            Padding="12"
            VerticalOptions="End">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20"/>
            </Border.StrokeShape>

            <Label
                x:Name="NearestPoiLabel"
                Text="Đang tìm POI..."
                FontSize="18"
                FontAttributes="Bold"
                TextColor="Black"/>
        </Border>

    </Grid>

</ContentPage>