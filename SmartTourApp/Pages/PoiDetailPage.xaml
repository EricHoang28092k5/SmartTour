<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="SmartTourApp.Pages.PoiDetailPage"
    BackgroundColor="#0D0F14"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*, Auto">

        <!-- ================= CONTENT ================= -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0">

                <!-- ========== IMAGE HEADER ========== -->
                <Grid HeightRequest="360">
                    <Image x:Name="PoiImage"
                           Aspect="AspectFill"/>

                    <!-- Gradient overlay: transparent top → dark bottom -->
                    <BoxView>
                        <BoxView.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#00000000" Offset="0.0"/>
                                <GradientStop Color="#55000000" Offset="0.5"/>
                                <GradientStop Color="#EE0D0F14" Offset="1.0"/>
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>

                    <!-- POI Name + Status pinned to bottom-left -->
                    <VerticalStackLayout VerticalOptions="End"
                                         HorizontalOptions="Start"
                                         Margin="20,0,20,24"
                                         Spacing="8">

                        <HorizontalStackLayout Spacing="8">
                            <Border x:Name="OpenStatusBadge"
                                    BackgroundColor="#1A00FF88"
                                    StrokeThickness="1"
                                    Stroke="#4400FF88"
                                    StrokeShape="RoundRectangle 20"
                                    Padding="10,4">
                                <Label x:Name="OpenStatus"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       TextColor="#00FF88"
                                       CharacterSpacing="0.5"/>
                            </Border>

                            <Label x:Name="OpenDetail"
                                   FontSize="12"
                                   TextColor="#AAAAAA"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <Label x:Name="PoiName"
                               FontSize="28"
                               FontAttributes="Bold"
                               TextColor="White"
                               LineHeight="1.2"
                               CharacterSpacing="-0.3"/>
                    </VerticalStackLayout>
                </Grid>

                <!-- ========== TABS ========== -->
                <Grid Margin="16,20,16,0"
                      ColumnDefinitions="*,*"
                      ColumnSpacing="10">

                    <Border x:Name="OverviewTabBorder"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 16">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1976D2" Offset="0"/>
                                <GradientStop Color="#5B8CFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Button x:Name="OverviewTab"
                                Text="Tổng quan"
                                Clicked="ShowOverview"
                                BackgroundColor="Transparent"
                                TextColor="White"
                                FontSize="14"
                                FontAttributes="Bold"
                                HeightRequest="46"/>
                    </Border>

                    <Border x:Name="MenuTabBorder"
                            Grid.Column="1"
                            BackgroundColor="#1A1E2E"
                            StrokeThickness="1"
                            Stroke="#2E3350"
                            StrokeShape="RoundRectangle 16">
                        <Button x:Name="MenuTab"
                                Text="Thực đơn"
                                Clicked="ShowMenu"
                                BackgroundColor="Transparent"
                                TextColor="#888"
                                FontSize="14"
                                HeightRequest="46"/>
                    </Border>
                </Grid>

                <!-- ========== OVERVIEW SECTION ========== -->
                <VerticalStackLayout x:Name="OverviewSection"
                                     Margin="16,20,16,40"
                                     Spacing="12">

                    <Label Text="GIỚI THIỆU"
                           FontSize="11"
                           FontAttributes="Bold"
                           TextColor="#5B8CFF"
                           CharacterSpacing="2"/>

                    <Label x:Name="PoiDescription"
                           FontSize="14.5"
                           TextColor="#CCCCCC"
                           LineHeight="1.65"/>
                </VerticalStackLayout>

                <!-- ========== MENU SECTION ========== -->
                <CollectionView x:Name="FoodList"
                                Margin="16,20,16,40"
                                IsVisible="False">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeShape="RoundRectangle 20"
                                    BackgroundColor="#181C2A"
                                    StrokeThickness="1"
                                    Stroke="#252940"
                                    Margin="0,0,0,14">
                                <Grid ColumnDefinitions="110,*">
                                    <Image Source="{Binding ImageUrl}"
                                           HeightRequest="100"
                                           Aspect="AspectFill">
                                        <Image.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnFoodImageTapped"/>
                                        </Image.GestureRecognizers>
                                    </Image>

                                    <VerticalStackLayout Grid.Column="1"
                                                         Padding="14,12"
                                                         Spacing="4">
                                        <Label Text="{Binding Name}"
                                               FontAttributes="Bold"
                                               FontSize="14"
                                               TextColor="White"/>
                                        <Label Text="{Binding Description}"
                                               FontSize="12"
                                               TextColor="#666"
                                               LineHeight="1.4"/>
                                        <Label Text="{Binding Price, StringFormat='{}{0:N0} đ'}"
                                               TextColor="#5B8CFF"
                                               FontAttributes="Bold"
                                               FontSize="14"
                                               Margin="0,6,0,0"/>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <!-- =============================================================== -->
        <!--              AUDIO CONTROL BAR — Clean White Card Design        -->
        <!-- =============================================================== -->
        <Border x:Name="AudioBar"
                Grid.Row="1"
                BackgroundColor="White"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 28,28,0,0">

            <Border.Shadow>
                <Shadow Brush="#000000" Offset="0,-4" Radius="24" Opacity="0.14"/>
            </Border.Shadow>

            <VerticalStackLayout Spacing="0" Padding="20,18,20,32">

                <!-- ── Top pill handle ── -->
                <BoxView WidthRequest="36"
                         HeightRequest="4"
                         CornerRadius="2"
                         BackgroundColor="#E0E0E0"
                         HorizontalOptions="Center"
                         Margin="0,0,0,16"/>

                <!-- ── Track Info Row ── -->
                <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,14" ColumnSpacing="12">

                    <!-- Album art / waveform icon -->
                    <Border Grid.Column="0"
                            WidthRequest="44"
                            HeightRequest="44"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 12">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#4A90E2" Offset="0"/>
                                <GradientStop Color="#5B8CFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <!-- Waveform dots -->
                        <HorizontalStackLayout Spacing="2"
                                               VerticalOptions="Center"
                                               HorizontalOptions="Center">
                            <BoxView WidthRequest="3" HeightRequest="8"  CornerRadius="2" BackgroundColor="White" Opacity="0.6"/>
                            <BoxView WidthRequest="3" HeightRequest="18" CornerRadius="2" BackgroundColor="White" Opacity="0.8"/>
                            <BoxView WidthRequest="3" HeightRequest="26" CornerRadius="2" BackgroundColor="White"/>
                            <BoxView WidthRequest="3" HeightRequest="14" CornerRadius="2" BackgroundColor="White" Opacity="0.75"/>
                            <BoxView WidthRequest="3" HeightRequest="6"  CornerRadius="2" BackgroundColor="White" Opacity="0.5"/>
                        </HorizontalStackLayout>
                    </Border>

                    <!-- Track title / subtitle -->
                    <VerticalStackLayout Grid.Column="1"
                                          VerticalOptions="Center"
                                          Spacing="2">
                        <Label Text="Audio Guide"
                               TextColor="#1A1A2E"
                               FontSize="15"
                               FontAttributes="Bold"/>
                        <Label Text="Thuyết minh điểm tham quan"
                               FontSize="11"
                               TextColor="#9B9BAA"/>
                    </VerticalStackLayout>

                    <!-- Time remaining badge -->
                    <Border Grid.Column="2"
                            BackgroundColor="#F0F4FF"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 10"
                            Padding="10,5"
                            VerticalOptions="Center">
                        <Label x:Name="TotalTimeLabel"
                               Text="00:00"
                               FontSize="12"
                               FontAttributes="Bold"
                               TextColor="#5B8CFF"/>
                    </Border>
                </Grid>

                <!-- ── Progress Slider with inline time ── -->
                <Grid RowDefinitions="Auto,Auto" Margin="0,0,0,6">

                    <Slider x:Name="ProgressSlider"
                            Grid.Row="0"
                            Minimum="0"
                            Maximum="0"
                            DragStarted="OnSeekStarted"
                            DragCompleted="OnSeekCompleted"
                            ValueChanged="OnSeek"
                            ThumbColor="#5B8CFF"
                            MinimumTrackColor="#5B8CFF"
                            MaximumTrackColor="#E8ECFF"
                            HeightRequest="28"/>

                    <!-- Time labels below slider -->
                    <Grid Grid.Row="1"
                          ColumnDefinitions="Auto,*,Auto"
                          Margin="4,-4,4,0">
                        <Label x:Name="CurrentTimeLabel"
                               Text="00:00"
                               FontSize="11"
                               FontAttributes="Bold"
                               TextColor="#5B8CFF"/>
                        <Label Grid.Column="2"
                               Text="Còn lại"
                               FontSize="11"
                               TextColor="#BBBBCC"/>
                    </Grid>
                </Grid>

                <!-- ── Playback Controls Row ── -->
                <Grid ColumnDefinitions="*,Auto,Auto,Auto,*"
                      ColumnSpacing="16"
                      HorizontalOptions="Center"
                      Margin="0,10,0,0">

                    <!-- Skip Back 5s -->
                    <Border Grid.Column="1"
                            WidthRequest="52"
                            HeightRequest="52"
                            BackgroundColor="#F5F6FA"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 26">
                        <Button x:Name="SkipBackBtn"
                                BackgroundColor="Transparent"
                                WidthRequest="52"
                                HeightRequest="52"
                                Clicked="OnSkipBack"
                                Text="↺"
                                FontSize="22"
                                TextColor="#4A5568"/>
                    </Border>

                    <!-- PLAY / PAUSE toggle button (single button, icon toggled in code-behind) -->
                    <Border x:Name="PlayBtnContainer"
                            Grid.Column="2"
                            WidthRequest="68"
                            HeightRequest="68"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 34">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#3A7BD5" Offset="0"/>
                                <GradientStop Color="#5B8CFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Shadow>
                            <Shadow Brush="#5B8CFF" Offset="0,4" Radius="16" Opacity="0.45"/>
                        </Border.Shadow>
                        <!-- Unified Play/Pause button — icon toggled via code-behind -->
                        <Button x:Name="PlayBtn"
                                Text="▶"
                                FontSize="26"
                                Clicked="OnPlayClicked"
                                BackgroundColor="Transparent"
                                TextColor="White"
                                WidthRequest="68"
                                HeightRequest="68"/>
                    </Border>

                    <!-- Skip Forward 5s -->
                    <Border Grid.Column="3"
                            WidthRequest="52"
                            HeightRequest="52"
                            BackgroundColor="#F5F6FA"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 26">
                        <Button x:Name="SkipFwdBtn"
                                BackgroundColor="Transparent"
                                WidthRequest="52"
                                HeightRequest="52"
                                Clicked="OnSkipForward"
                                Text="↻"
                                FontSize="22"
                                TextColor="#4A5568"/>
                    </Border>
                </Grid>

                <!-- ── Stop button — subtle, below controls ── -->
                <Button x:Name="StopBtn"
                        Text="■  Dừng phát"
                        FontSize="13"
                        TextColor="#FF6B6B"
                        BackgroundColor="Transparent"
                        HorizontalOptions="Center"
                        Margin="0,10,0,0"
                        Padding="20,8"
                        Clicked="OnStopClicked"/>

                <!-- Hidden Pause button kept for code-behind compatibility — not visible in UI -->
                <Button x:Name="PauseBtn"
                        IsVisible="False"
                        IsEnabled="False"
                        Clicked="OnPauseClicked"/>

                <!-- Hidden container kept for ShowMenu/ShowOverview compatibility -->
                <Border x:Name="PauseBtnContainer"
                        IsVisible="False"
                        WidthRequest="0"
                        HeightRequest="0"/>

            </VerticalStackLayout>
        </Border>

        <!-- ================= IMAGE VIEWER ================= -->
        <Grid x:Name="ImageViewer"
              Grid.RowSpan="2"
              BackgroundColor="#EE000000"
              IsVisible="False"
              Opacity="0">

            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="CloseImageViewer"/>
            </Grid.GestureRecognizers>

            <Image x:Name="PreviewImage"
                   Aspect="AspectFit"
                   Scale="0.8"
                   Margin="24"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"/>

            <Label Text="Nhấn để đóng"
                   TextColor="#44FFFFFF"
                   FontSize="12"
                   HorizontalOptions="Center"
                   VerticalOptions="End"
                   Margin="0,0,0,40"/>
        </Grid>

    </Grid>
</ContentPage>
