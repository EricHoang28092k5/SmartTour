<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="SmartTourApp.Pages.PoiDetailPage"
    Title="POI Detail">

    <ScrollView>

        <VerticalStackLayout Padding="20">

            <Image
                x:Name="PoiImage"
                HeightRequest="200"
                Aspect="AspectFill"/>

            <Label
                x:Name="PoiName"
                FontSize="24"
                FontAttributes="Bold"/>

            <Label
                x:Name="PoiDescription"
                FontSize="16"/>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>