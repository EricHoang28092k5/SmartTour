<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="SmartTourApp.Pages.PoiDetailPage"
    BackgroundColor="White"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*, Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0">

                <Grid HeightRequest="320">
                    <Image x:Name="PoiImage"
                            Aspect="AspectFill"/>

                    <BoxView>
                        <BoxView.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#00000000" Offset="0.0"/>
                                <GradientStop Color="#33000000" Offset="0.5"/>
                                <GradientStop Color="#CCffffff" Offset="1.0"/>
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>

                    <Border
                        WidthRequest="40"
                        HeightRequest="40"
                        BackgroundColor="White"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 20"
                        HorizontalOptions="Start"
                        VerticalOptions="Start"
                        Margin="16,52,0,0">
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="8" Opacity="0.12"/>
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBackTapped"/>
                        </Border.GestureRecognizers>
                        <Label Text="‹"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="#1A1A2E"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               Margin="0,0,0,2"/>
                    </Border>

                    <VerticalStackLayout VerticalOptions="End"
                                         HorizontalOptions="Start"
                                         Margin="20,0,20,20"
                                         Spacing="6">

                        <HorizontalStackLayout Spacing="8">
                            <Border x:Name="OpenStatusBadge"
                                    BackgroundColor="#1A00FF88"
                                    StrokeThickness="1"
                                    Stroke="#4400FF88"
                                    StrokeShape="RoundRectangle 20"
                                    Padding="10,4">
                                <Label x:Name="OpenStatus"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       TextColor="#00FF88"
                                       CharacterSpacing="0.5"/>
                            </Border>

                            <Label x:Name="OpenDetail"
                                   FontSize="12"
                                   TextColor="#666666"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <Label x:Name="PoiName"
                               FontSize="26"
                               FontAttributes="Bold"
                               TextColor="#1A1A2E"
                               LineHeight="1.2"
                               CharacterSpacing="-0.3"/>
                    </VerticalStackLayout>
                </Grid>

                <Grid Margin="16,16,16,0"
                      ColumnDefinitions="*,*"
                      ColumnSpacing="10">

                    <Border x:Name="OverviewTabBorder"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 14">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1976D2" Offset="0"/>
                                <GradientStop Color="#5B8CFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Button x:Name="OverviewTab"
                                Text="Tổng quan"
                                Clicked="ShowOverview"
                                BackgroundColor="Transparent"
                                TextColor="White"
                                FontSize="14"
                                FontAttributes="Bold"
                                HeightRequest="44"/>
                    </Border>

                    <Border x:Name="MenuTabBorder"
                            Grid.Column="1"
                            BackgroundColor="#F5F6FA"
                            StrokeThickness="1"
                            Stroke="#E8ECF0"
                            StrokeShape="RoundRectangle 14">
                        <Button x:Name="MenuTab"
                                Text="Thực đơn"
                                Clicked="ShowMenu"
                                BackgroundColor="Transparent"
                                TextColor="#9B9BAA"
                                FontSize="14"
                                HeightRequest="44"/>
                    </Border>
                </Grid>

                <VerticalStackLayout x:Name="OverviewSection"
                                     Margin="16,16,16,40"
                                     Spacing="10">

                    <Label Text="GIỚI THIỆU"
                           FontSize="11"
                           FontAttributes="Bold"
                           TextColor="#5B8CFF"
                           CharacterSpacing="2"/>

                    <Label x:Name="PoiDescription"
                           FontSize="14.5"
                           TextColor="#444455"
                           LineHeight="1.65"/>
                </VerticalStackLayout>

                <CollectionView x:Name="FoodList"
                                Margin="16,16,16,40"
                                IsVisible="False">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeShape="RoundRectangle 16"
                                    BackgroundColor="White"
                                    StrokeThickness="1"
                                    Stroke="#EEEEF5"
                                    Margin="0,0,0,12">
                                <Border.Shadow>
                                    <Shadow Brush="#000000" Offset="0,2" Radius="8" Opacity="0.06"/>
                                </Border.Shadow>
                                <Grid ColumnDefinitions="110,*">
                                    <Image Source="{Binding ImageUrl}"
                                           HeightRequest="100"
                                           Aspect="AspectFill">
                                        <Image.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnFoodImageTapped"/>
                                        </Image.GestureRecognizers>
                                    </Image>

                                    <VerticalStackLayout Grid.Column="1"
                                                         Padding="14,12"
                                                         Spacing="4">
                                        <Label Text="{Binding Name}"
                                               FontAttributes="Bold"
                                               FontSize="14"
                                               TextColor="#1A1A2E"/>
                                        <Label Text="{Binding Description}"
                                               FontSize="12"
                                               TextColor="#888"
                                               LineHeight="1.4"/>
                                        <Label Text="{Binding Price, StringFormat='{}{0:N0} đ'}"
                                               TextColor="#5B8CFF"
                                               FontAttributes="Bold"
                                               FontSize="14"
                                               Margin="0,6,0,0"/>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!--  AUDIO CONTROL — Redesigned: clean light mode player card   -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Border x:Name="AudioBar"
                Grid.Row="1"
                BackgroundColor="#FAFBFF"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 28,28,0,0">

            <Border.Shadow>
                <Shadow Brush="#1A1A2E" Offset="0,-6" Radius="32" Opacity="0.07"/>
            </Border.Shadow>

            <VerticalStackLayout Spacing="0" Padding="20,14,20,36">

                <!-- Drag handle -->
                <BoxView WidthRequest="40"
                         HeightRequest="4"
                         CornerRadius="2"
                         BackgroundColor="#DDE1F0"
                         HorizontalOptions="Center"
                         Margin="0,0,0,16"/>

                <!-- ── Header row: icon + title + duration badge ── -->
                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="12"
                      Margin="0,0,0,16">

                    <!-- Waveform icon box -->
                    <Border Grid.Column="0"
                            WidthRequest="46"
                            HeightRequest="46"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 14">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#3461FF" Offset="0"/>
                                <GradientStop Color="#7C9FFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <!-- Mini waveform bars -->
                        <HorizontalStackLayout Spacing="3"
                                               VerticalOptions="Center"
                                               HorizontalOptions="Center">
                            <BoxView WidthRequest="3" HeightRequest="10" CornerRadius="2" BackgroundColor="White" Opacity="0.55"/>
                            <BoxView WidthRequest="3" HeightRequest="20" CornerRadius="2" BackgroundColor="White" Opacity="0.78"/>
                            <BoxView WidthRequest="3" HeightRequest="28" CornerRadius="2" BackgroundColor="White"/>
                            <BoxView WidthRequest="3" HeightRequest="16" CornerRadius="2" BackgroundColor="White" Opacity="0.7"/>
                            <BoxView WidthRequest="3" HeightRequest="8"  CornerRadius="2" BackgroundColor="White" Opacity="0.45"/>
                        </HorizontalStackLayout>
                    </Border>

                    <!-- Title + subtitle -->
                    <VerticalStackLayout Grid.Column="1"
                                         VerticalOptions="Center"
                                         Spacing="3">
                        <Label Text="Audio Guide"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="#1A1A2E"
                               CharacterSpacing="-0.2"/>
                        <Label Text="Thuyết minh điểm tham quan"
                               FontSize="11"
                               TextColor="#9BA3C4"/>
                    </VerticalStackLayout>

                    <!-- Total duration pill -->
                    <Border Grid.Column="2"
                            BackgroundColor="#EEF1FF"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 20"
                            Padding="12,6"
                            VerticalOptions="Center">
                        <Label x:Name="TotalTimeLabel"
                               Text="00:00"
                               FontSize="12"
                               FontAttributes="Bold"
                               TextColor="#3461FF"/>
                    </Border>
                </Grid>

                <!-- ── Progress track ── -->
                <Grid RowDefinitions="Auto,Auto" Margin="0,0,0,0">

                    <!-- Track background + fill -->
                    <Border Grid.Row="0"
                            HeightRequest="5"
                            BackgroundColor="#E8ECFF"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 3"
                            Margin="0,0,0,0">
                        <Grid HorizontalOptions="Start" x:Name="ProgressFillContainer">
                            <Border x:Name="ProgressFill"
                                    HeightRequest="5"
                                    WidthRequest="0"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 3"
                                    HorizontalOptions="Start">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#3461FF" Offset="0"/>
                                        <GradientStop Color="#7C9FFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Transparent slider overlay for touch -->
                    <Slider x:Name="ProgressSlider"
                            Grid.Row="0"
                            Minimum="0"
                            Maximum="0"
                            DragStarted="OnSeekStarted"
                            DragCompleted="OnSeekCompleted"
                            ValueChanged="OnSeek"
                            ThumbColor="Transparent"
                            MinimumTrackColor="Transparent"
                            MaximumTrackColor="Transparent"
                            HeightRequest="26"
                            Margin="0,-10,0,0"/>

                    <!-- Time labels -->
                    <Grid Grid.Row="1"
                          ColumnDefinitions="Auto,*,Auto"
                          Margin="2,6,2,0">
                        <Label x:Name="CurrentTimeLabel"
                               Text="00:00"
                               FontSize="11"
                               FontAttributes="Bold"
                               TextColor="#3461FF"/>
                        <Label Grid.Column="2"
                               x:Name="RemainingTimeLabel"
                               Text="00:00"
                               FontSize="11"
                               TextColor="#C0C6E0"/>
                    </Grid>
                </Grid>

                <!-- ── Controls row ── -->
                <Grid ColumnDefinitions="*,Auto,Auto,Auto,*"
                      ColumnSpacing="0"
                      HorizontalOptions="Fill"
                      Margin="0,20,0,0">

                    <!-- Skip back -->
                    <Border Grid.Column="1"
                            WidthRequest="50"
                            HeightRequest="50"
                            BackgroundColor="#F0F3FF"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 25"
                            Margin="0,0,14,0">
                        <Button x:Name="SkipBackBtn"
                                BackgroundColor="Transparent"
                                WidthRequest="50"
                                HeightRequest="50"
                                Clicked="OnSkipBack"
                                Text="↺"
                                FontSize="20"
                                TextColor="#3461FF"/>
                    </Border>

                    <!-- Play / Pause main button -->
                    <Border x:Name="PlayBtnContainer"
                            Grid.Column="2"
                            WidthRequest="64"
                            HeightRequest="64"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 32"
                            HorizontalOptions="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#3461FF" Offset="0"/>
                                <GradientStop Color="#6B8FFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Shadow>
                            <Shadow Brush="#3461FF" Offset="0,6" Radius="20" Opacity="0.3"/>
                        </Border.Shadow>
                        <Button x:Name="PlayBtn"
                                Text="▶"
                                FontSize="24"
                                Clicked="OnPlayClicked"
                                BackgroundColor="Transparent"
                                TextColor="White"
                                WidthRequest="64"
                                HeightRequest="64"/>
                    </Border>

                    <!-- Skip forward -->
                    <Border Grid.Column="3"
                            WidthRequest="50"
                            HeightRequest="50"
                            BackgroundColor="#F0F3FF"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 25"
                            Margin="14,0,0,0">
                        <Button x:Name="SkipFwdBtn"
                                BackgroundColor="Transparent"
                                WidthRequest="50"
                                HeightRequest="50"
                                Clicked="OnSkipForward"
                                Text="↻"
                                FontSize="20"
                                TextColor="#3461FF"/>
                    </Border>
                </Grid>

                <!-- Stop button -->
                <Button x:Name="StopBtn"
                        Text="■  Dừng phát"
                        FontSize="12"
                        FontAttributes="Bold"
                        TextColor="#FF5A5A"
                        BackgroundColor="Transparent"
                        HorizontalOptions="Center"
                        Margin="0,12,0,0"
                        Padding="24,8"
                        IsVisible="False"
                        Clicked="OnStopClicked"/>

                <!-- Hidden pause/container kept for XAML compat -->
                <Button x:Name="PauseBtn" IsVisible="False" IsEnabled="False" Clicked="OnPauseClicked"/>
                <Border x:Name="PauseBtnContainer" IsVisible="False" WidthRequest="0" HeightRequest="0"/>

            </VerticalStackLayout>
        </Border>

        <!-- ── Image lightbox overlay ── -->
        <Grid x:Name="ImageViewer"
              Grid.RowSpan="2"
              BackgroundColor="#EE000000"
              IsVisible="False"
              Opacity="0">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="CloseImageViewer"/>
            </Grid.GestureRecognizers>
            <Image x:Name="PreviewImage"
                   Aspect="AspectFit"
                   Scale="0.8"
                   Margin="24"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"/>
            <Label Text="Nhấn để đóng"
                   TextColor="#44FFFFFF"
                   FontSize="12"
                   HorizontalOptions="Center"
                   VerticalOptions="End"
                   Margin="0,0,0,40"/>
        </Grid>

    </Grid>
</ContentPage>
