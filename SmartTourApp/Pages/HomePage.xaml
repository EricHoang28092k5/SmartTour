<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="SmartTourApp.Pages.HomePage"
    BackgroundColor="#F6F7FB">

    <Grid RowDefinitions="Auto,*" Padding="16">

        <!-- HEADER -->
        <VerticalStackLayout Grid.Row="0" Spacing="4">
            <Label Text="SmartTour"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="#111"/>

            <Label Text="Địa điểm gần bạn"
                   FontSize="14"
                   TextColor="#777"/>
        </VerticalStackLayout>

        <!-- LIST -->
        <CollectionView
            Grid.Row="1"
            x:Name="PoiList"
            Margin="0,10,0,0"
            SelectionMode="None"
            ItemsLayout="VerticalList"
            ItemSizingStrategy="MeasureAllItems">

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <Grid Padding="8"
                          Margin="0,0,0,10"
                          ColumnDefinitions="80,*"
                          HeightRequest="90">

                        <!-- IMAGE -->
                        <Image
                            WidthRequest="80"
                            HeightRequest="80"
                            Aspect="AspectFill"
                            Source="{Binding ImageUrl}" />

                        <!-- CONTENT -->
                        <VerticalStackLayout Grid.Column="1"
                                             Padding="8,0"
                                             Spacing="2">

                            <Label Text="{Binding Name}"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   LineBreakMode="TailTruncation"/>

                            <Label Text="{Binding Description}"
                                   FontSize="12"
                                   TextColor="#2979FF"/>

                        </VerticalStackLayout>

                    </Grid>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>

</ContentPage>