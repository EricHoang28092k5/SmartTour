<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="SmartTourApp.Pages.HomePage"
    BackgroundColor="#F6F7FB">

    <ScrollView>
        <VerticalStackLayout Spacing="24">

            <!-- HERO -->
            <Grid HeightRequest="280">
                <Image x:Name="HeroImage"
                       Aspect="AspectFill"
                       Opacity="0"/>

                <BoxView Background="#80000000"/>

                <VerticalStackLayout Padding="20"
                                     VerticalOptions="End"
                                     Spacing="6">

                    <Label Text="📍 Gần bạn nhất"
                           FontSize="12"
                           TextColor="White"/>

                    <Label x:Name="HeroTitle"
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="White"/>

                    <Label x:Name="HeroDistance"
                           FontSize="14"
                           TextColor="White"/>

                    <Button x:Name="HeroPlayBtn"
                            Text="🎧 Nghe ngay"
                            Clicked="PlayNearest"
                            BackgroundColor="White"
                            TextColor="#1976D2"
                            CornerRadius="18"/>
                </VerticalStackLayout>
            </Grid>

            <Label Text="✨ Địa điểm gần bạn"
                   Margin="16,0"
                   FontSize="20"
                   FontAttributes="Bold"/>

            <!-- LIST -->
            <CollectionView x:Name="PoiList" Margin="16,0" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border StrokeShape="RoundRectangle 18" BackgroundColor="White" Margin="0,0,0,16">
                            <Grid ColumnDefinitions="120,*,60" HeightRequest="130">

                                <Image Source="{Binding ImageUrl}" Aspect="AspectFill"/>

                                <VerticalStackLayout Grid.Column="1" Padding="12" Spacing="6">
                                    <Label Text="{Binding Name}" FontSize="15" FontAttributes="Bold"/>
                                    <Label Text="{Binding Description}" FontSize="12" TextColor="#777"/>
                                    <Label Text="⭐ Popular" FontSize="11" TextColor="#999"/>
                                </VerticalStackLayout>

                                <!-- AUDIO BUTTON -->
                                <Grid Grid.Column="2" VerticalOptions="Center" HorizontalOptions="Center">
                                    <Border WidthRequest="44" HeightRequest="44"
                BackgroundColor="#1976D2"
                StrokeShape="RoundRectangle 22">

                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer 
                    Tapped="PlayPoiAudio"
                    CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>

                                        <Label Text="▶"
                   FontSize="18"
                   TextColor="White"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"/>
                                    </Border>
                                </Grid>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>