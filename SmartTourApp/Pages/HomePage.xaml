<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="SmartTourApp.Pages.HomePage"
    BackgroundColor="#FFFFFF"
    Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- ══════════════════════════════════════ -->
            <!--  HERO SECTION                          -->
            <!-- ══════════════════════════════════════ -->
            <Grid HeightRequest="340">

                <!-- Background image -->
                <Image x:Name="HeroImage"
                       Aspect="AspectFill"
                       Opacity="0"/>

                <!-- Dark gradient overlay -->
                <BoxView>
                    <BoxView.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#00000000" Offset="0.0"/>
                            <GradientStop Color="#55000000" Offset="0.5"/>
                            <GradientStop Color="#DD000000" Offset="1.0"/>
                        </LinearGradientBrush>
                    </BoxView.Background>
                </BoxView>

                <!-- Top bar -->
                <Grid ColumnDefinitions="*,Auto"
                      Padding="20,54,20,0"
                      VerticalOptions="Start">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label x:Name="AppNameLabel"
                               Text="SmartTour"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="#AAFFFFFF"
                               CharacterSpacing="2"/>
                        <Label x:Name="GreetingLabel"
                               Text="Chào buổi sáng 👋"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="White"/>
                    </VerticalStackLayout>

                    <!-- Notification bell -->
                    <Border Grid.Column="1"
                            WidthRequest="44" HeightRequest="44"
                            BackgroundColor="#33FFFFFF"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 22"
                            VerticalOptions="Center">
                        <Label Text="🔔" FontSize="18"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                </Grid>

                <!-- Hero content -->
                <VerticalStackLayout Padding="20,0,20,24"
                                     VerticalOptions="End"
                                     Spacing="8">

                    <!-- Nearest badge -->
                    <Border BackgroundColor="#1EFFFFFF"
                            StrokeThickness="1"
                            Stroke="#44FFFFFF"
                            StrokeShape="RoundRectangle 20"
                            Padding="10,4"
                            HorizontalOptions="Start">
                        <Label x:Name="LblNearestBadge"
                               Text="📍 Gần bạn nhất"
                               FontSize="11"
                               FontAttributes="Bold"
                               TextColor="White"
                               CharacterSpacing="0.3"/>
                    </Border>

                    <Label x:Name="HeroTitle"
                           Text="Đang tải..."
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="White"
                           LineHeight="1.1"
                           CharacterSpacing="-0.3"/>

                    <Label x:Name="HeroDistance"
                           Text=""
                           FontSize="13"
                           TextColor="#CCFFFFFF"/>

                    <!-- CTA row -->
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10" Margin="0,4,0,0">
                        <Border StrokeThickness="0"
                                StrokeShape="RoundRectangle 24"
                                BackgroundColor="White">
                            <Border.Shadow>
                                <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.15"/>
                            </Border.Shadow>
                            <Button x:Name="HeroPlayBtn"
                                    Text="🎧  Nghe ngay"
                                    Clicked="PlayNearest"
                                    BackgroundColor="Transparent"
                                    TextColor="#3461FF"
                                    FontAttributes="Bold"
                                    FontSize="14"
                                    HeightRequest="48"
                                    Padding="0"/>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Grid>

            <Border Margin="20,20,20,12"
                    Stroke="#E8ECF4"
                    StrokeThickness="1"
                    BackgroundColor="#F9FAFD"
                    StrokeShape="RoundRectangle 16"
                    Padding="12">
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <Label Text="🔎" FontSize="16" VerticalOptions="Center"/>
                        <SearchBar x:Name="PoiSearchBar"
                                   Grid.Column="1"
                                   Placeholder="Tìm địa điểm..."
                                   SearchCommandParameter="{x:Null}"
                                   SearchButtonPressed="OnSearchSubmitted"
                                   TextChanged="OnSearchChanged"
                                   BackgroundColor="Transparent"/>
                    </Grid>

                    <Grid ColumnDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="8">
                        <Button x:Name="DistanceAllBtn" Text="Tất cả" Clicked="OnDistanceChipClicked" CommandParameter="all" HeightRequest="34" CornerRadius="14" BackgroundColor="#3563FF" TextColor="White" FontSize="12"/>
                        <Button x:Name="Distance1Btn" Grid.Column="1" Text="&lt; 1km" Clicked="OnDistanceChipClicked" CommandParameter="1" HeightRequest="34" CornerRadius="14" BackgroundColor="#EEF2FF" TextColor="#3C4A67" FontSize="12"/>
                        <Button x:Name="Distance3Btn" Grid.Column="2" Text="&lt; 3km" Clicked="OnDistanceChipClicked" CommandParameter="3" HeightRequest="34" CornerRadius="14" BackgroundColor="#EEF2FF" TextColor="#3C4A67" FontSize="12"/>
                        <Button x:Name="Distance5Btn" Grid.Column="3" Text="&lt; 5km" Clicked="OnDistanceChipClicked" CommandParameter="5" HeightRequest="34" CornerRadius="14" BackgroundColor="#EEF2FF" TextColor="#3C4A67" FontSize="12"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- ══════════════════════════════════════ -->
            <!--  POI LIST                              -->
            <!-- ══════════════════════════════════════ -->
            <CollectionView x:Name="PoiList"
                            Margin="16,0,16,36"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border StrokeShape="RoundRectangle 22"
                                BackgroundColor="White"
                                StrokeThickness="0"
                                Margin="0,0,0,16">

                            <Border.Shadow>
                                <Shadow Brush="#1A1A3E" Offset="0,5" Radius="24" Opacity="0.07"/>
                            </Border.Shadow>

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Tapped="OpenDetailTap"
                                    CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>

                            <!-- YC1: Giảm chiều cao card vì bỏ description -->
                            <Grid ColumnDefinitions="108,*" HeightRequest="90">

                                <!-- IMAGE -->
                                <Border StrokeShape="RoundRectangle 20,0,0,20"
                                        StrokeThickness="0"
                                        Grid.Column="0">
                                    <Image Source="{Binding ImageUrl}"
                                           Aspect="AspectFill"/>
                                </Border>

                                <!-- INFO: Bỏ description, chỉ giữ tên -->
                                <Grid Grid.Column="1"
                                      RowDefinitions="*,Auto"
                                      Padding="14,10,14,10">

                                    <!-- YC1: Chỉ hiển thị tên, bỏ description -->
                                    <Label Grid.Row="0"
                                           Text="{Binding DisplayName}"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="#111111"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="2"
                                           VerticalOptions="Center"/>

                                    <!-- Actions row -->
                                    <Grid Grid.Row="1"
                                          ColumnDefinitions="*,Auto,Auto"
                                          ColumnSpacing="8">

                                        <!-- Play -->
                                        <Border Grid.Column="1"
                                                WidthRequest="36" HeightRequest="36"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 18"
                                                VerticalOptions="Center">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#3461FF" Offset="0"/>
                                                    <GradientStop Color="#7C9FFF" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Tapped="PlayPoiAudio"
                                                    CommandParameter="{Binding .}"/>
                                            </Border.GestureRecognizers>
                                            <Label Text="▶"
                                                   FontSize="13"
                                                   TextColor="White"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"/>
                                        </Border>

                                        <!-- Route -->
                                        <Border Grid.Column="2"
                                                WidthRequest="36" HeightRequest="36"
                                                BackgroundColor="#EEFAF2"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 18"
                                                VerticalOptions="Center">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Tapped="GoToMapRoute"
                                                    CommandParameter="{Binding .}"/>
                                            </Border.GestureRecognizers>
                                            <Label Text="🧭"
                                                   FontSize="14"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"/>
                                        </Border>

                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
