<ContentPage
xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
x:Class="SmartTourApp.Pages.HomePage">

    <ScrollView>

        <VerticalStackLayout Padding="20" Spacing="15">

            <Label
Text="LINH ỨNG ĐÀ NẴNG"
FontSize="28"
FontAttributes="Bold"/>

            <Label
Text="Chào mừng bạn đến với SmartTour"/>

            <Button
Text="Tạo Tour mới"
HeightRequest="50"
BackgroundColor="#ff8c6b"
TextColor="White"/>

            <Label
Text="Tour gợi ý"
FontAttributes="Bold"
FontSize="18"/>

            <CollectionView x:Name="TourList"/>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>