<ContentPage
 xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
 x:Class="SmartTourApp.Pages.SettingsPage">

    <VerticalStackLayout Padding="20" Spacing="20">

        <Label
    Text="Ngôn ngữ"
    FontAttributes="Bold"/>

        <Picker
    x:Name="LangPicker"
    Title="Chọn ngôn ngữ">

            <Picker.Items>
                <x:String>vi</x:String>
                <x:String>en</x:String>
                <x:String>ja</x:String>
            </Picker.Items>

        </Picker>

        <Button
    Text="Lưu"
    Clicked="Save"/>

    </VerticalStackLayout>

</ContentPage>